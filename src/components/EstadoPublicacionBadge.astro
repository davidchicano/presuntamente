---
// EstadoPublicacionBadge — badge del ciclo de vida editorial de una ficha de Caso.
//
// Por defecto: pastilla con dot + etiqueta (comportamiento original).
// Props opcionales:
//   compact   — tamaño reducido para tablas
//   dotOnly   — misma pastilla sin texto (solo dot + fondo)
//   hover     — con dotOnly, envuelve en HoverCard con panel teñido
//   listado   — atajo para /casos: compact + reglas dot-only/hover en
//               beta_publica/publicado; badge con texto en estados excepcionales
//
// Canon visual: DESIGN.md + caso.schema.json (enum estado_publicacion).

import HoverCard from '@/components/HoverCard.astro';

type EstadoPublicacion =
  | 'pendiente'
  | 'borrador'
  | 'beta_publica'
  | 'en_revision'
  | 'publicado'
  | 'retirado_temporalmente'
  | 'retirado_definitivamente';

interface Props {
  estado: EstadoPublicacion;
  compact?: boolean;
  dotOnly?: boolean;
  hover?: boolean;
  /** Atajo editorial para la columna Caso en /casos. Implica compact. */
  listado?: boolean;
  /** Nota del panel hover; default = copy canónica por estado. */
  hoverNota?: string;
}

const {
  estado,
  compact = false,
  dotOnly = false,
  hover = false,
  listado = false,
  hoverNota,
} = Astro.props;

const LABELS: Record<EstadoPublicacion, string> = {
  pendiente: 'Pendiente',
  borrador: 'Borrador',
  beta_publica: 'Beta pública',
  en_revision: 'En revisión',
  publicado: 'Publicado',
  retirado_temporalmente: 'Retirado temp.',
  retirado_definitivamente: 'Retirado',
};

const NOTAS: Record<EstadoPublicacion, string> = {
  pendiente: 'En cola; aún no se ha empezado a trabajar la ficha.',
  borrador: 'Ficha en desarrollo; no accesible en producción.',
  beta_publica: 'Publicada con huecos editoriales menores.',
  en_revision: 'Revisión interna antes de darla por cerrada.',
  publicado: 'Ficha al máximo de lo que el inventario permite hoy.',
  retirado_temporalmente: 'Retirada temporalmente del catálogo público.',
  retirado_definitivamente: 'Retirada definitivamente del catálogo público.',
};

/** En listado, estos estados llevan etiqueta visible (sin hover). */
const ESTADOS_TEXTO_EN_LISTADO = new Set<EstadoPublicacion>([
  'pendiente',
  'borrador',
  'en_revision',
  'retirado_temporalmente',
  'retirado_definitivamente',
]);

const estadoSlug = estado.replace(/_/g, '-');
const textoVisibleEnListado = listado && ESTADOS_TEXTO_EN_LISTADO.has(estado);
const effectiveCompact = compact || listado;
const effectiveDotOnly = textoVisibleEnListado ? false : dotOnly || listado;
const effectiveHover = textoVisibleEnListado ? false : hover || (listado && effectiveDotOnly);
const notaHover = hoverNota ?? NOTAS[estado];

const badgeClass = [
  'estado-pub-badge',
  `estado-pub-badge--${estadoSlug}`,
  effectiveCompact && 'estado-pub-badge--compact',
  effectiveDotOnly && 'estado-pub-badge--dot-only',
];
---

{effectiveHover ? (
  <div class="estado-pub-badge-wrap">
    <HoverCard side="top" align="start" openDelay={80} closeDelay={120}>
      <span
        slot="trigger"
        class:list={badgeClass}
        aria-label={`Estado de la ficha: ${LABELS[estado]}`}
      >
        <span class="estado-pub-badge__dot" aria-hidden="true"></span>
      </span>
      <div
        slot="content"
        class:list={[
          'estado-pub-badge__hover',
          `estado-pub-badge__hover--${estadoSlug}`,
        ]}
      >
        <p class="estado-pub-badge__hover-title">{LABELS[estado]}</p>
        <p class="estado-pub-badge__hover-note">{notaHover}</p>
      </div>
    </HoverCard>
  </div>
) : (
  <span
    class:list={badgeClass}
    aria-label={effectiveDotOnly ? `Estado de la ficha: ${LABELS[estado]}` : undefined}
  >
    <span class="estado-pub-badge__dot" aria-hidden="true"></span>
    {!effectiveDotOnly && (
      <span class="estado-pub-badge__label">{LABELS[estado]}</span>
    )}
  </span>
)}

<style>
  .estado-pub-badge-wrap :global(.hcard) {
    flex-shrink: 0;
    max-width: none;
  }

  .estado-pub-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.02em;
    padding: 0.12em 0.38em;
    border-radius: 2px;
    white-space: nowrap;
  }

  .estado-pub-badge--compact {
    font-size: 0.72rem;
    padding: 0.1em 0.32em;
  }

  .estado-pub-badge--dot-only {
    gap: 0;
    vertical-align: middle;
    justify-content: center;
    align-items: center;
  }
  .estado-pub-badge--dot-only .estado-pub-badge__dot {
    margin-top: 0;
  }
  .estado-pub-badge--dot-only:not(.estado-pub-badge--compact) {
    padding: 0.28em 0.34em;
  }
  .estado-pub-badge--dot-only.estado-pub-badge--compact {
    padding: 4px 5px;
    min-inline-size: 18px;
    min-block-size: 16px;
  }

  .estado-pub-badge__dot {
    flex-shrink: 0;
    inline-size: 0.5em;
    block-size: 0.5em;
    margin-top: 0.08em;
    border-radius: 50%;
    background: currentColor;
  }

  .estado-pub-badge__label {
    line-height: 1.2;
  }

  .estado-pub-badge--pendiente {
    color: var(--color-fg-muted, #6c6f73);
    background: var(--color-desmentido-bg, #f0f0f0);
  }

  .estado-pub-badge--borrador {
    color: var(--color-rol-investigado);
    background: var(--color-investigado-bg, #f7f0dd);
  }

  .estado-pub-badge--beta-publica {
    color: var(--color-accent-secondary-text);
    background: var(--color-accent-secondary-soft, #f7ecc5);
  }

  .estado-pub-badge--en-revision {
    color: var(--color-accent-secondary-text);
    background: color-mix(in srgb, var(--color-accent-secondary-soft, #f7ecc5) 55%, transparent);
  }

  .estado-pub-badge--en-revision .estado-pub-badge__dot {
    background: transparent;
    box-shadow: inset 0 0 0 1.5px currentColor;
  }

  .estado-pub-badge--publicado {
    color: var(--color-acreditado);
    background: var(--color-acreditado-bg, #eef4ef);
  }

  .estado-pub-badge--retirado-temporalmente,
  .estado-pub-badge--retirado-definitivamente {
    color: #8e2424;
    background: #f9ecec;
  }

  /* Resto de estados → tokens dark-aware. Sólo el rojo "retirado" usa par
     fijo propio, así que es lo único que el tema oscuro reescribe aquí. */
  :global(html[data-theme="dark"]) .estado-pub-badge--retirado-temporalmente,
  :global(html[data-theme="dark"]) .estado-pub-badge--retirado-definitivamente {
    color: #e0a4a4;
    background: #2a1414;
  }
</style>

<style is:global>
  .estado-pub-badge-wrap .hcard__content {
    padding: 0;
    border: none;
    background: transparent;
    box-shadow: none;
  }

  .estado-pub-badge__hover {
    display: flex;
    flex-direction: column;
    gap: 4px;
    max-width: 240px;
    padding: 8px 10px;
    border: 1px solid var(--color-accent);
    border-radius: 0;
    box-shadow: 0 6px 14px -10px rgba(0, 0, 0, 0.28);
  }

  .estado-pub-badge__hover-title {
    margin: 0;
    font: 600 12px/1.3 var(--font-sans);
    color: inherit;
  }

  .estado-pub-badge__hover-note {
    margin: 0;
    font: 400 11px/1.4 var(--font-sans);
    color: color-mix(in srgb, currentColor 72%, transparent);
  }

  .estado-pub-badge__hover--pendiente {
    color: var(--color-fg-muted, #6c6f73);
    background: var(--color-desmentido-bg, #f0f0f0);
  }

  .estado-pub-badge__hover--borrador {
    color: var(--color-rol-investigado);
    background: var(--color-investigado-bg, #f7f0dd);
  }

  .estado-pub-badge__hover--beta-publica {
    color: var(--color-accent-secondary-text);
    background: var(--color-accent-secondary-soft, #f7ecc5);
  }

  .estado-pub-badge__hover--en-revision {
    color: var(--color-accent-secondary-text);
    background: color-mix(in srgb, var(--color-accent-secondary-soft, #f7ecc5) 55%, transparent);
  }

  .estado-pub-badge__hover--publicado {
    color: var(--color-acreditado);
    background: var(--color-acreditado-bg, #eef4ef);
  }

  .estado-pub-badge__hover--retirado-temporalmente,
  .estado-pub-badge__hover--retirado-definitivamente {
    color: #8e2424;
    background: #f9ecec;
  }

  html[data-theme="dark"] .estado-pub-badge__hover--retirado-temporalmente,
  html[data-theme="dark"] .estado-pub-badge__hover--retirado-definitivamente {
    color: #e0a4a4;
    background: #2a1414;
  }
</style>
