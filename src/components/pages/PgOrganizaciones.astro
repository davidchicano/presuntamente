---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CustomSelect from '@/components/CustomSelect.astro';
import OrientacionBadge from '@/components/OrientacionBadge.astro';
import NaturalezaBadge from '@/components/NaturalezaBadge.astro';
import { getCollection } from 'astro:content';
import { tipoOrgLabel, type Lang } from '@/lib/labels';

interface Props { lang?: Lang; }
const { lang = 'es' } = Astro.props;

const [organizacionesCol, rolesCol, casosCol, hechosCol, hitosCol] = await Promise.all([
  getCollection('organizaciones'),
  getCollection('roles'),
  getCollection('casos'),
  getCollection('hechos'),
  getCollection('hitos'),
]);

const orgs = organizacionesCol
  .map((o) => {
    // Casos donde esta organización aparece (como órgano judicial,
    // querellante, en hechos o como afectada en hitos).
    const casosIds = new Set<string>();
    for (const c of casosCol) if (c.data.organo_judicial_id === o.data.id || c.data.querellante_inicial_id === o.data.id) casosIds.add(c.data.id);
    for (const r of rolesCol) if (r.data.sujeto_tipo === 'organizacion' && r.data.sujeto_organizacion_id === o.data.id) casosIds.add(r.data.caso_id);
    for (const h of hechosCol) {
      const orgs = (h.data as { organizaciones_implicadas?: string[] }).organizaciones_implicadas;
      if (orgs?.includes(o.data.id)) casosIds.add(h.data.caso_id);
    }
    for (const h of hitosCol) {
      if (h.data.organizaciones_afectadas?.includes(o.data.id)) casosIds.add(h.data.caso_id);
    }
    const editorial = o.data as {
      naturaleza_editorial?: string;
      orientacion_editorial_declarada?: { valor: string };
      orientacion_editorial_percibida?: { valor: string };
    };
    return {
      slug: o.data.id,
      nombre: o.data.nombre,
      tipo: o.data.tipo,
      tipoLabel: tipoOrgLabel(o.data.tipo),
      localidad: (o.data as { localidad?: string }).localidad,
      casosCount: casosIds.size,
      naturaleza: editorial.naturaleza_editorial,
      orientacionDeclarada: editorial.orientacion_editorial_declarada?.valor,
      orientacionPercibida: editorial.orientacion_editorial_percibida?.valor,
    };
  })
  .sort((a, b) => a.nombre.localeCompare(b.nombre, 'es'));

const strings = {
  title: 'Organizaciones citadas',
  description:
    'Listado de organizaciones (órganos judiciales, fiscalías, partidos, empresas, organismos públicos, asociaciones) referenciadas en los procedimientos.',
  eyebrow: 'Sección 3 · Organizaciones',
  sub:
    'Entidades colectivas con relevancia procesal en los casos: órganos judiciales, fiscalías, ' +
    'unidades policiales, organismos públicos, empresas investigadas, partidos, asociaciones de acusación popular y medios.',
};

function searchBlob(o: (typeof orgs)[number]): string {
  return [o.nombre, o.tipoLabel, o.localidad].filter(Boolean).join(' ').toLowerCase();
}

// Lista única de tipos presentes hoy para alimentar el filtro.
const tiposPresentes = Array.from(new Set(orgs.map((o) => o.tipo)))
  .map((t) => ({ valor: t, label: tipoOrgLabel(t) }))
  .sort((a, b) => a.label.localeCompare(b.label, 'es'));
---

<BaseLayout
  title={strings.title}
  lang={lang}
  description={strings.description}
  activeNav="organizaciones"
  breadcrumb={[
    { label: 'Inicio', href: lang === 'ca' ? '/cat' : '/' },
    { label: 'Organizaciones' },
  ]}
>
  <section class="page-id">
    <div>
      <p class="page-id__eyebrow">{strings.eyebrow}</p>
      <h1 class="page-id__title">{strings.title}</h1>
      <p class="page-id__sub">{strings.sub}</p>
    </div>
    <div class="page-id__meta">
      <span>Total: <span data-total>{orgs.length}</span></span>
      <span>·</span>
      <span>Mostrando: <span data-shown>{orgs.length}</span></span>
    </div>
  </section>

  <header class="sec-h">
    <span class="num">3.1</span>
    <h2>Filtros</h2>
  </header>

  <form class="filter-bar" method="get" role="search" aria-label="Filtrar organizaciones" data-orgs-filters>
    <div class="field">
      <label for="q">Buscar</label>
      <input id="q" name="q" type="search" placeholder="Nombre, tipo, localidad…" autocomplete="off" />
    </div>
    <div class="field">
      <label for="tipo">Tipo</label>
      <CustomSelect
        id="tipo"
        name="tipo"
        value="all"
        ariaLabel="Filtrar por tipo de organización"
        options={[
          { value: 'all', label: 'Todos' },
          ...tiposPresentes.map((t) => ({ value: t.valor, label: t.label })),
        ]}
      />
    </div>
    <button class="btn" type="reset">Limpiar</button>
  </form>

  <header class="sec-h">
    <span class="num">3.2</span>
    <h2>Listado</h2>
    <span class="right">orden: alfabético</span>
  </header>

  <div class="tbl-scroll">
  <table class="tbl" data-orgs>
    <thead>
      <tr>
        <th style="width: 32%;">Organización</th>
        <th style="width: 18%;">Tipo</th>
        <th style="width: 28%;">Clasificación editorial</th>
        <th style="width: 12%;">Localidad</th>
        <th style="width: 10%;" class="c-num">Casos</th>
      </tr>
    </thead>
    <tbody>
      {orgs.map((o) => (
        <tr class="is-link" data-row data-tipo={o.tipo} data-search={searchBlob(o)}>
          <td>
            <a href={`/organizaciones/${o.slug}`}>
              <span class="c-name">{o.nombre}</span>
            </a>
          </td>
          <td><span class="badge badge--cat">{o.tipoLabel}</span></td>
          <td>
            {o.tipo === 'medio_comunicacion' ? (
              <div class="orgs-clasif">
                {o.naturaleza && <NaturalezaBadge naturaleza={o.naturaleza} size="sm" />}
                {o.orientacionDeclarada && (
                  <OrientacionBadge
                    valor={o.orientacionDeclarada}
                    size="sm"
                    title="Orientación declarada por el propio medio"
                  />
                )}
                {!o.naturaleza && !o.orientacionDeclarada && (
                  <span class="orgs-clasif__dash">—</span>
                )}
              </div>
            ) : (
              <span class="orgs-clasif__dash">—</span>
            )}
          </td>
          <td class="c-mono">{o.localidad ?? '—'}</td>
          <td class="c-num">{o.casosCount}</td>
        </tr>
      ))}
    </tbody>
  </table>
  </div>

  <p class="empty-state" data-empty hidden>Sin resultados para los filtros actuales.</p>
</BaseLayout>

<script is:inline>
  (() => {
    const form = document.querySelector('[data-orgs-filters]');
    const table = document.querySelector('[data-orgs]');
    if (!form || !table) return;
    const rows = Array.from(table.querySelectorAll('[data-row]'));
    const shown = document.querySelector('[data-shown]');
    const empty = document.querySelector('[data-empty]');
    const qInput = form.querySelector('#q');
    const tipoSel = form.querySelector('input[name="tipo"]');
    function resyncCustomSelects() {
      form.querySelectorAll('[data-csel]').forEach((csel) => {
        const hidden = csel.querySelector('[data-csel-value]');
        const label = csel.querySelector('[data-csel-label]');
        if (!hidden || !label) return;
        const opt = csel.querySelector(`[data-csel-opt][data-value="${hidden.value}"]`);
        if (opt) {
          label.textContent = opt.textContent.trim();
          csel.querySelectorAll('[data-csel-opt]').forEach((o) => o.setAttribute('aria-selected', o === opt ? 'true' : 'false'));
        }
      });
    }
    function apply() {
      const q = (qInput.value || '').trim().toLowerCase();
      const tipo = tipoSel.value;
      let visible = 0;
      for (const row of rows) {
        const matchQ = !q || (row.dataset.search || '').includes(q);
        const matchT = tipo === 'all' || row.dataset.tipo === tipo;
        const show = matchQ && matchT;
        row.hidden = !show;
        if (show) visible++;
      }
      if (shown) shown.textContent = String(visible);
      if (empty) empty.hidden = visible !== 0;
    }
    form.addEventListener('input', apply);
    form.addEventListener('change', apply);
    form.addEventListener('submit', (e) => { e.preventDefault(); apply(); });
    form.addEventListener('reset', () => setTimeout(() => { resyncCustomSelects(); apply(); }, 0));
  })();
</script>

<style>
  .empty-state {
    border: 1px dashed var(--color-border-strong);
    background: var(--color-surface-muted);
    padding: var(--space-4);
    text-align: center;
    font: 400 var(--font-size-1)/1.5 var(--font-sans);
    color: var(--color-fg-muted);
  }
  .orgs-clasif {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.3rem 0.4rem;
    align-items: center;
    vertical-align: middle;
  }
  .orgs-clasif__dash {
    color: var(--color-fg-subtle);
  }
  /* Alinear todos los badges al mismo baseline dentro de la columna,
     independientemente de si vienen de badge (inline-flex) o de
     orient-badge (inline-block). */
  .orgs-clasif > .badge,
  .orgs-clasif > .orient-badge {
    vertical-align: middle;
  }
</style>
