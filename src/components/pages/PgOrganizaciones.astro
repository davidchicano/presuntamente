---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CategoryBadge from '@/components/CategoryBadge.astro';
import CustomSelect from '@/components/CustomSelect.astro';
import CatalogoLeyenda from '@/components/CatalogoLeyenda.astro';
import SectionH from '@/components/SectionH.astro';
import OrientacionBadge from '@/components/OrientacionBadge.astro';
import NaturalezaBadge from '@/components/NaturalezaBadge.astro';
import { getCollection } from 'astro:content';
import { tipoOrgLabel, type Lang } from '@/lib/labels';

// Orden canónico del eje editorial (izquierda → derecha), no alfabético.
// Coincide con el enum de orientacion_editorial_declarada/percibida.
const ORIENTACION_ORDER = [
  'izquierda_radical',
  'izquierda',
  'centro_izquierda',
  'centro',
  'centro_derecha',
  'derecha',
  'derecha_radical',
  'sin_clasificar',
];
const ORIENTACION_LABEL: Record<string, string> = {
  izquierda_radical: 'Izquierda radical',
  izquierda: 'Izquierda',
  centro_izquierda: 'Centro-izquierda',
  centro: 'Centro',
  centro_derecha: 'Centro-derecha',
  derecha: 'Derecha',
  derecha_radical: 'Derecha radical',
  sin_clasificar: 'Sin clasificar',
};

interface Props { lang?: Lang; }
const { lang = 'es' } = Astro.props;

const [organizacionesCol, rolesCol, casosCol, hechosCol, hitosCol] = await Promise.all([
  getCollection('organizaciones'),
  getCollection('roles'),
  getCollection('casos'),
  getCollection('hechos'),
  getCollection('hitos'),
]);

const orgs = organizacionesCol
  .map((o) => {
    // Casos donde esta organización aparece (como órgano judicial,
    // querellante, en hechos o como afectada en hitos).
    const casosIds = new Set<string>();
    for (const c of casosCol) if (c.data.organo_judicial_id === o.data.id || c.data.querellante_inicial_id === o.data.id) casosIds.add(c.data.id);
    for (const r of rolesCol) if (r.data.sujeto_tipo === 'organizacion' && r.data.sujeto_organizacion_id === o.data.id) casosIds.add(r.data.caso_id);
    for (const h of hechosCol) {
      const orgs = (h.data as { organizaciones_implicadas?: string[] }).organizaciones_implicadas;
      if (orgs?.includes(o.data.id)) casosIds.add(h.data.caso_id);
    }
    for (const h of hitosCol) {
      if (h.data.organizaciones_afectadas?.includes(o.data.id)) casosIds.add(h.data.caso_id);
    }
    const editorial = o.data as {
      naturaleza_editorial?: string;
      orientacion_editorial_declarada?: { valor: string };
      orientacion_editorial_percibida?: { valor: string };
    };
    return {
      slug: o.data.id,
      nombre: o.data.nombre,
      tipo: o.data.tipo,
      tipoLabel: tipoOrgLabel(o.data.tipo),
      localidad: (o.data as { localidad?: string }).localidad,
      casosCount: casosIds.size,
      naturaleza: editorial.naturaleza_editorial,
      orientacionDeclarada: editorial.orientacion_editorial_declarada?.valor,
      orientacionPercibida: editorial.orientacion_editorial_percibida?.valor,
    };
  })
  .sort((a, b) => a.nombre.localeCompare(b.nombre, 'es'));

const strings = {
  title: 'Organizaciones citadas',
  description:
    'Listado de organizaciones (órganos judiciales, fiscalías, partidos, empresas, organismos públicos, asociaciones) referenciadas en los procedimientos.',
  eyebrow: 'Sección 3 · Organizaciones',
  sub:
    'Entidades colectivas con relevancia procesal en los casos: órganos judiciales, fiscalías, ' +
    'unidades policiales, organismos públicos, empresas investigadas, partidos, asociaciones de acusación popular y medios.',
};

function searchBlob(o: (typeof orgs)[number]): string {
  return [o.nombre, o.tipoLabel, o.localidad].filter(Boolean).join(' ').toLowerCase();
}

// Lista única de tipos presentes hoy para alimentar el filtro.
const tiposPresentes = Array.from(new Set(orgs.map((o) => o.tipo)))
  .map((t) => ({ valor: t, label: tipoOrgLabel(t) }))
  .sort((a, b) => a.label.localeCompare(b.label, 'es'));

// Orientaciones editoriales realmente presentes (sólo medios las tienen).
// Filtra el dropdown a lo útil. La orientación declarada es la fuente que
// gobierna el filtro; si una org sólo tiene `percibida`, queda fuera.
const orientacionesPresentes = new Set(
  orgs.map((o) => o.orientacionDeclarada).filter(Boolean) as string[],
);
const opcionesOrientacion = ORIENTACION_ORDER
  .filter((v) => orientacionesPresentes.has(v))
  .map((v) => ({ value: v, label: ORIENTACION_LABEL[v] }));
---

<BaseLayout
  title={strings.title}
  lang={lang}
  description={strings.description}
  activeNav="organizaciones"
  breadcrumb={[
    { label: 'Inicio', href: lang === 'ca' ? '/cat' : '/' },
    { label: 'Organizaciones' },
  ]}
>
  <section class="page-id">
    <div>
      <p class="page-id__eyebrow">{strings.eyebrow}</p>
      <h1 class="page-id__title">{strings.title}</h1>
      <p class="page-id__sub">{strings.sub}</p>
    </div>
    <div class="page-id__meta">
      <span>Total: <span data-total>{orgs.length}</span></span>
      <span>·</span>
      <span>Mostrando: <span data-shown>{orgs.length}</span></span>
    </div>
  </section>

  <CatalogoLeyenda
    titulo="Cómo leer este catálogo"
    resumen="Tipo de organización, clasificación editorial (sólo medios) y filtros disponibles."
    ariaLabel="Leyenda del catálogo de organizaciones"
  >
    <section class="cat-legend__section">
      <h3 class="cat-legend__section-title">Tipos de organización</h3>
      <p class="cat-legend__intro">
        Cada organización lleva su tipo como insignia con icono Lucide: órgano judicial,
        fiscalía, unidad policial, organismo público, empresa investigada, partido político,
        asociación de acusación popular, medio de comunicación, sindicato o asociación civil.
      </p>
    </section>
    <section class="cat-legend__section">
      <h3 class="cat-legend__section-title">Clasificación editorial (sólo medios)</h3>
      <p class="cat-legend__inline">
        La columna <strong>Orientación editorial (medios)</strong> aplica únicamente a medios
        de comunicación. Combina la <strong>naturaleza editorial</strong> (generalista político,
        de verificación, especializado, servicio público…) con la <strong>orientación declarada</strong>
        por el propio medio en el eje izquierda-derecha. Los grados de orientación percibida
        externamente se muestran en la ficha del medio, no en este listado. Para el resto de
        organizaciones esta columna queda como «—».
      </p>
    </section>
    <section class="cat-legend__section">
      <h3 class="cat-legend__section-title">Filtros y ordenación</h3>
      <p class="cat-legend__inline">
        Puedes <strong>buscar</strong> por nombre, tipo o localidad; filtrar por
        <strong>tipo de organización</strong> y por <strong>orientación editorial declarada</strong>
        (este filtro descarta automáticamente lo que no es medio). El selector de orden cubre
        <strong>alfabético</strong> y <strong>número de casos</strong> donde la organización aparece.
      </p>
    </section>
    <section class="cat-legend__section">
      <h3 class="cat-legend__section-title">Más detalle metodológico</h3>
      <p class="cat-legend__inline">
        Los criterios editoriales aplicados al inventario (qué entra, cómo se trata cada
        entidad) están en <a href="/sobre#principios">/sobre — Principios editoriales</a>;
        cómo se respaldan los hechos atribuidos a las organizaciones, en
        <a href="/sobre#niveles">/sobre — Niveles de fuente (N1–N4)</a>.
      </p>
    </section>
  </CatalogoLeyenda>

  <SectionH num="3.1" title="Filtros">
    <button
      type="reset"
      form="filters-organizaciones"
      class="sec-h__action"
      aria-label="Limpiar filtros de organizaciones"
    >
      Limpiar filtros
    </button>
  </SectionH>

  <form id="filters-organizaciones" class="filter-bar" method="get" role="search" aria-label="Filtrar organizaciones" data-orgs-filters>
    <div class="field">
      <label for="q">Buscar</label>
      <input id="q" name="q" type="search" placeholder="Nombre, tipo, localidad…" autocomplete="off" />
    </div>
    <div class="field">
      <label for="tipo">Tipo</label>
      <CustomSelect
        id="tipo"
        name="tipo"
        value="all"
        ariaLabel="Filtrar por tipo de organización"
        options={[
          { value: 'all', label: 'Todos' },
          ...tiposPresentes.map((t) => ({ value: t.valor, label: t.label })),
        ]}
      />
    </div>
    <div class="field">
      <label for="orient">Orientación editorial</label>
      <CustomSelect
        id="orient"
        name="orient"
        value="all"
        ariaLabel="Filtrar por orientación editorial declarada (sólo medios)"
        options={[
          { value: 'all', label: 'Todas (incluye no-medios)' },
          ...opcionesOrientacion,
        ]}
      />
    </div>
    <div class="field">
      <label for="order">Ordenar por</label>
      <CustomSelect
        id="order"
        name="order"
        value="alfabetico"
        ariaLabel="Ordenar listado"
        options={[
          { value: 'alfabetico', label: 'Alfabético' },
          { value: 'casos',      label: 'Nº de casos ↓' },
        ]}
      />
    </div>
  </form>

  <header class="sec-h">
    <span class="num">3.2</span>
    <h2>Listado</h2>
    <span class="right" data-listado-meta>orden: alfabético</span>
  </header>

  <div class="tbl-scroll">
  <table class="tbl" data-orgs>
    <thead>
      <tr>
        <th style="width: 32%;">Organización</th>
        <th style="width: 18%;">Tipo</th>
        <th
          style="width: 28%;"
          title="Sólo aplica a medios de comunicación. Para el resto de organizaciones esta columna queda vacía."
        >Orientación editorial (medios)</th>
        <th style="width: 12%;">Localidad</th>
        <th style="width: 10%;" class="c-num">Casos</th>
      </tr>
    </thead>
    <tbody>
      {orgs.map((o) => (
        <tr
          class="is-link"
          data-row
          data-tipo={o.tipo}
          data-orient={o.orientacionDeclarada ?? ''}
          data-casos={o.casosCount}
          data-search={searchBlob(o)}
        >
          <td>
            <a href={`/organizaciones/${o.slug}`}>
              <span class="c-name">{o.nombre}</span>
            </a>
          </td>
          <td>
            <CategoryBadge kind="org" tipo={o.tipo} label={o.tipoLabel} />
          </td>
          <td>
            {o.tipo === 'medio_comunicacion' ? (
              <div class="orgs-clasif">
                {o.naturaleza && <NaturalezaBadge naturaleza={o.naturaleza} size="sm" />}
                {o.orientacionDeclarada && (
                  <OrientacionBadge
                    valor={o.orientacionDeclarada}
                    size="sm"
                    title="Orientación declarada por el propio medio"
                  />
                )}
                {!o.naturaleza && !o.orientacionDeclarada && (
                  <span class="orgs-clasif__dash">—</span>
                )}
              </div>
            ) : (
              <span class="orgs-clasif__dash">—</span>
            )}
          </td>
          <td class="c-mono">{o.localidad ?? '—'}</td>
          <td class="c-num">{o.casosCount}</td>
        </tr>
      ))}
    </tbody>
  </table>
  </div>

  <p class="empty-state" data-empty hidden>Sin resultados para los filtros actuales.</p>
</BaseLayout>

<script is:inline>
  (() => {
    const form = document.querySelector('[data-orgs-filters]');
    const table = document.querySelector('[data-orgs]');
    if (!form || !table) return;
    const rows = Array.from(table.querySelectorAll('[data-row]'));
    const tbody = table.querySelector('tbody');
    const shown = document.querySelector('[data-shown]');
    const empty = document.querySelector('[data-empty]');
    const meta = document.querySelector('[data-listado-meta]');
    const qInput = form.querySelector('#q');
    const tipoSel = form.querySelector('input[name="tipo"]');
    const orientSel = form.querySelector('input[name="orient"]');
    const orderSel = form.querySelector('input[name="order"]');

    const ORDER_LABEL = {
      alfabetico: 'alfabético',
      casos: 'nº de casos',
    };

    function resyncCustomSelects() {
      form.querySelectorAll('[data-csel]').forEach((csel) => {
        const hidden = csel.querySelector('[data-csel-value]');
        const label = csel.querySelector('[data-csel-label]');
        if (!hidden || !label) return;
        const opt = csel.querySelector(`[data-csel-opt][data-value="${hidden.value}"]`);
        if (opt) {
          label.textContent = opt.textContent.trim();
          csel.querySelectorAll('[data-csel-opt]').forEach((o) => o.setAttribute('aria-selected', o === opt ? 'true' : 'false'));
        }
      });
    }

    function apply() {
      const q = (qInput.value || '').trim().toLowerCase();
      const tipo = tipoSel.value;
      const orient = orientSel ? orientSel.value : 'all';
      const order = orderSel ? orderSel.value : 'alfabetico';

      const visible = [];
      for (const row of rows) {
        const matchQ = !q || (row.dataset.search || '').includes(q);
        const matchT = tipo === 'all' || row.dataset.tipo === tipo;
        // Si se filtra por orientación, sólo pasan filas con esa orientación
        // declarada — implícitamente excluye todo lo que no sea medio.
        const matchO = orient === 'all' || row.dataset.orient === orient;
        const show = matchQ && matchT && matchO;
        row.hidden = !show;
        if (show) visible.push(row);
      }

      if (tbody) {
        visible.sort((a, b) => {
          if (order === 'casos') {
            const ca = parseInt(a.dataset.casos || '0', 10);
            const cb = parseInt(b.dataset.casos || '0', 10);
            if (cb !== ca) return cb - ca;
          }
          const na = (a.querySelector('.c-name')?.textContent || '').trim();
          const nb = (b.querySelector('.c-name')?.textContent || '').trim();
          return na.localeCompare(nb, 'es');
        });
        for (const row of visible) tbody.appendChild(row);
      }

      if (shown) shown.textContent = String(visible.length);
      if (empty) empty.hidden = visible.length !== 0;
      if (meta) meta.textContent = `orden: ${ORDER_LABEL[order] || 'alfabético'}`;
    }
    form.addEventListener('input', apply);
    form.addEventListener('change', apply);
    form.addEventListener('submit', (e) => { e.preventDefault(); apply(); });
    form.addEventListener('reset', () => setTimeout(() => { resyncCustomSelects(); apply(); }, 0));
  })();
</script>

<style>
  .empty-state {
    border: 1px dashed var(--color-border-strong);
    background: var(--color-surface-muted);
    padding: var(--space-4);
    text-align: center;
    font: 400 var(--font-size-1)/1.5 var(--font-sans);
    color: var(--color-fg-muted);
  }
  .orgs-clasif {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.3rem 0.4rem;
    align-items: center;
    vertical-align: middle;
  }
  .orgs-clasif__dash {
    color: var(--color-fg-subtle);
  }
  /* Alinear todos los badges al mismo baseline dentro de la columna,
     independientemente de si vienen de badge (inline-flex) o de
     orient-badge (inline-block). */
  .orgs-clasif > .badge,
  .orgs-clasif > .orient-badge {
    vertical-align: middle;
  }
</style>
