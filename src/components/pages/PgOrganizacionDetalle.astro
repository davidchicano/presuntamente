---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionH from '@/components/SectionH.astro';
import OrgGlyph from '@/components/OrgGlyph.astro';
import { tipoOrgLabel, rolLabel, type Lang } from '@/lib/labels';

interface Props { lang?: Lang; organizacion: CollectionEntry<'organizaciones'>; }
const { lang = 'es', organizacion } = Astro.props;
const data = organizacion.data;

const [rolesCol, casosCol, hechosCol, hitosCol, documentosCol] = await Promise.all([
  getCollection('roles'),
  getCollection('casos'),
  getCollection('hechos'),
  getCollection('hitos'),
  getCollection('documentos'),
]);

const casoIndex = new Map(casosCol.map((c) => [c.data.id, c.data]));

// Casos donde aparece esta organización por cualquiera de las vías.
const casoIds = new Set<string>();
for (const c of casosCol) if (c.data.organo_judicial_id === data.id || c.data.querellante_inicial_id === data.id) casoIds.add(c.data.id);
const rolesOrg = rolesCol
  .filter((r) => r.data.sujeto_tipo === 'organizacion' && r.data.sujeto_organizacion_id === data.id)
  .map((r) => ({
    caso_id: r.data.caso_id,
    rol: r.data.rol,
    rolLabel: rolLabel(r.data.rol),
    fecha_inicio: r.data.fecha_inicio,
    fecha_fin: r.data.fecha_fin,
    notas: r.data.notas,
  }));
for (const r of rolesOrg) casoIds.add(r.caso_id);
for (const h of hechosCol) {
  const orgs = (h.data as { organizaciones_implicadas?: string[] }).organizaciones_implicadas;
  if (orgs?.includes(data.id)) casoIds.add(h.data.caso_id);
}
for (const h of hitosCol) {
  if (h.data.organizaciones_afectadas?.includes(data.id)) casoIds.add(h.data.caso_id);
}

const casos = Array.from(casoIds)
  .map((id) => casoIndex.get(id))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));

const documentosProducidos = documentosCol.filter((d) => d.data.productor_organizacion_id === data.id);

const breadcrumb = [
  { label: 'Inicio', href: lang === 'ca' ? '/cat' : '/' },
  { label: 'Organizaciones', href: lang === 'ca' ? '/cat/organizaciones' : '/organizaciones' },
  { label: data.nombre },
];
---

<BaseLayout
  title={data.nombre}
  lang={lang}
  description={data.descripcion_corta ?? data.nombre}
  activeNav="organizaciones"
  breadcrumb={breadcrumb}
>
  <section class="entity-mast">
    <OrgGlyph tipo={data.tipo} size={64} />
    <div class="entity-mast__body">
      <p class="entity-mast__eye">Ficha de organización</p>
      <h1 class="entity-mast__name">{data.nombre}</h1>
      <p class="entity-mast__sub">{tipoOrgLabel(data.tipo)}</p>
      <div class="entity-mast__row">
        {(data as { localidad?: string }).localidad && (
          <><span>{(data as { localidad?: string }).localidad}</span><span class="entity-mast__sep">·</span></>
        )}
        <span><strong>{casos.length}</strong> caso{casos.length === 1 ? '' : 's'} referenciado{casos.length === 1 ? '' : 's'}</span>
        {documentosProducidos.length > 0 && (
          <>
            <span class="entity-mast__sep">·</span>
            <span><strong>{documentosProducidos.length}</strong> documento{documentosProducidos.length === 1 ? '' : 's'} producido{documentosProducidos.length === 1 ? '' : 's'}</span>
          </>
        )}
      </div>
    </div>
  </section>

  {data.descripcion_corta && (
    <>
      <SectionH num="1." title="Descripción" id="descripcion" />
      <div class="prose"><p>{data.descripcion_corta}</p></div>
    </>
  )}

  <SectionH num="2." title="Casos donde aparece" id="casos" right={`${casos.length} caso${casos.length === 1 ? '' : 's'}`} />
  {casos.length === 0 ? (
    <p class="muted">Sin casos registrados.</p>
  ) : (
    <ul class="casos-list">
      {casos.map((c) => (
        <li class="casos-list__item">
          <a href={`/casos/${c.id}`}>
            <span class="c-name">{c.nombre_mediatico}</span>
            <span class="c-name__sub">{c.nombre_oficial}</span>
          </a>
        </li>
      ))}
    </ul>
  )}

  {rolesOrg.length > 0 && (
    <>
      <SectionH num="3." title="Roles procesales asumidos" id="roles" right={`${rolesOrg.length} rol${rolesOrg.length === 1 ? '' : 'es'}`} />
      <table class="tbl">
        <thead>
          <tr>
            <th style="width: 22%;">Periodo</th>
            <th style="width: 28%;">Rol</th>
            <th>Caso</th>
          </tr>
        </thead>
        <tbody>
          {rolesOrg.map((r) => (
            <tr>
              <td class="c-mono">{r.fecha_inicio}{r.fecha_fin ? ` → ${r.fecha_fin}` : ' → vigente'}</td>
              <td><span class="badge">{r.rolLabel}</span></td>
              <td><a href={`/casos/${r.caso_id}`}>{casoIndex.get(r.caso_id)?.nombre_mediatico ?? r.caso_id}</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </>
  )}

  {documentosProducidos.length > 0 && (
    <>
      <SectionH num="4." title="Documentos producidos" id="documentos" right={`${documentosProducidos.length} documento${documentosProducidos.length === 1 ? '' : 's'}`} />
      <ul class="docs-list">
        {documentosProducidos.map((d) => (
          <li>
            <span class:list={['badge', `badge--n${d.data.nivel_fuente}`]}>N{d.data.nivel_fuente}</span>
            <span class="docs-list__title">{d.data.titulo}</span>
            <span class="docs-list__date">{d.data.fecha_documento}</span>
          </li>
        ))}
      </ul>
    </>
  )}

  <SectionH num="5." title="Cómo se ha redactado esta ficha" id="redaccion" />
  <div class="prose">
    <ul class="meta-list">
      <li><strong>Estado de publicación:</strong> {data.estado_publicacion}</li>
      {data.ultima_revision_editorial && (
        <li><strong>Última revisión editorial:</strong> <span class="mono">{data.ultima_revision_editorial}</span></li>
      )}
      {data.url_canonica && (
        <li>
          <strong>Sitio oficial:</strong> <a href={data.url_canonica} target="_blank" rel="noopener">{data.url_canonica} ↗</a>
        </li>
      )}
    </ul>
  </div>
</BaseLayout>

<style>
  .entity-mast {
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-accent);
    background: var(--color-surface);
    padding: 18px 20px;
    margin-bottom: var(--space-4);
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 18px;
  }
  .entity-mast__eye {
    font: 700 11px/1 var(--font-sans);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-accent-secondary-hover);
    margin: 0 0 6px;
  }
  .entity-mast__name {
    font: 700 clamp(1.4rem, 1.2rem + 0.8vw, 1.8rem)/1.15 var(--font-sans);
    letter-spacing: -0.005em;
    margin: 0 0 4px;
  }
  .entity-mast__sub {
    font: 400 13px/1.4 var(--font-sans);
    color: var(--color-fg-muted);
    margin: 0;
  }
  .entity-mast__row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
    margin-top: 10px;
    padding-top: 8px;
    border-top: 1px solid var(--color-border);
    font: 400 12px/1 var(--font-sans);
    color: var(--color-fg-muted);
  }
  .entity-mast__row strong { color: var(--color-fg); font-weight: 600; }
  .entity-mast__sep { color: var(--color-border); }

  .casos-list { list-style: none; padding: 0; margin: 0 0 var(--space-4); border: 1px solid var(--color-border); background: var(--color-surface); }
  .casos-list__item { padding: 12px 16px; border-bottom: 1px solid var(--color-border); }
  .casos-list__item:last-child { border-bottom: 0; }
  .casos-list__item a { color: inherit; text-decoration: none; display: flex; flex-direction: column; gap: 2px; }
  .casos-list__item a:hover { text-decoration: underline; }
  .casos-list__item .c-name { font-weight: 600; }
  .casos-list__item .c-name__sub { font-size: var(--font-size-0); color: var(--color-fg-muted); }

  .docs-list { list-style: none; padding: 0; margin: 0 0 var(--space-4); border: 1px solid var(--color-border); background: var(--color-surface); }
  .docs-list li { padding: 10px 14px; border-bottom: 1px solid var(--color-border); display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
  .docs-list li:last-child { border-bottom: 0; }
  .docs-list__title { flex: 1 1 0; font-weight: 600; }
  .docs-list__date { font-family: var(--font-mono); font-size: 11px; color: var(--color-fg-muted); }

  .meta-list { margin: 0; padding-left: 18px; }
  .meta-list li { margin: 4px 0; }
  .meta-list .mono { font-family: var(--font-mono); font-size: 12px; }
</style>
