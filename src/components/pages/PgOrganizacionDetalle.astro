---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import FichaTocSection from '@/components/FichaTocSection.astro';
import OrgGlyph from '@/components/OrgGlyph.astro';
import RichProse from '@/components/RichProse.astro';
import RolBadge from '@/components/RolBadge.astro';
import VinculosInstitucionalesList from '@/components/VinculosInstitucionalesList.astro';
import GraphConexionesLink from '@/components/GraphConexionesLink.astro';
import CifrasSujetoBloque from '@/components/CifrasSujetoBloque.astro';
import SourceLinkBadge from '@/components/SourceLinkBadge.astro';
import OrientacionBadge from '@/components/OrientacionBadge.astro';
import NaturalezaBadge from '@/components/NaturalezaBadge.astro';
import { tipoOrgLabel, rolLabel, naturalezaVinculoLabel, type Lang } from '@/lib/labels';
import { toImporteEntries, analizarSujeto, type HechoImporteInput } from '@/lib/importe';
import EstadoPublicacionBadge from '@/components/EstadoPublicacionBadge.astro';
import Aclaracion from '@/components/Aclaracion.astro';

type EstadoPub = 'pendiente' | 'borrador' | 'beta_publica' | 'en_revision' | 'publicado' | 'retirado_temporalmente' | 'retirado_definitivamente';
import { documentoRespaldoHref } from '@/lib/documentos';

interface Props { lang?: Lang; organizacion: CollectionEntry<'organizaciones'>; }
const { lang = 'es', organizacion } = Astro.props;
const data = organizacion.data;

const [rolesCol, casosCol, hechosCol, hitosCol, documentosCol, vinculosCol, personasCol, organizacionesCol] = await Promise.all([
  getCollection('roles'),
  getCollection('casos'),
  getCollection('hechos'),
  getCollection('hitos'),
  getCollection('documentos'),
  getCollection('vinculos'),
  getCollection('personas'),
  getCollection('organizaciones'),
]);

const casoIndex = new Map(casosCol.map((c) => [c.data.id, c.data]));
const personaIndex = new Map(personasCol.map((p) => [p.data.id, p.data]));
const orgIndex = new Map(organizacionesCol.map((o) => [o.data.id, o.data]));
const docIndex = new Map(documentosCol.map((d) => [d.data.id, d.data]));

// Cifras económicas atribuidas a esta organización (por papel económico).
const importeEntries = toImporteEntries(
  hechosCol.map((h) => h.data as unknown as HechoImporteInput),
);
const analisisCifras = analizarSujeto(importeEntries, data.id);
const hayCifras = analisisCifras.hayCifras;
const casosNombre: Record<string, string> = Object.fromEntries(
  casosCol.map((c) => [c.data.id, c.data.nombre_mediatico]),
);

// Casos con implicación procesual (rol, hecho, hito, órgano titular o querellante).
const casoIds = new Set<string>();
for (const c of casosCol) if (c.data.organo_judicial_id === data.id || c.data.querellante_inicial_id === data.id) casoIds.add(c.data.id);
const rolesOrg = rolesCol
  .filter((r) => r.data.sujeto_tipo === 'organizacion' && r.data.sujeto_organizacion_id === data.id)
  .map((r) => ({
    caso_id: r.data.caso_id,
    rol: r.data.rol,
    rolLabel: rolLabel(r.data.rol),
    fecha_inicio: r.data.fecha_inicio,
    fecha_fin: r.data.fecha_fin,
    notas: r.data.notas,
  }));
for (const r of rolesOrg) casoIds.add(r.caso_id);
for (const h of hechosCol) {
  const orgs = (h.data as { organizaciones_implicadas?: string[] }).organizaciones_implicadas;
  if (orgs?.includes(data.id)) casoIds.add(h.data.caso_id);
}
for (const h of hitosCol) {
  if (h.data.organizaciones_afectadas?.includes(data.id)) casoIds.add(h.data.caso_id);
}

const casos = Array.from(casoIds)
  .map((id) => casoIndex.get(id))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));

const documentosProducidos = documentosCol.filter((d) => d.data.productor_organizacion_id === data.id);

function personaLabel(id: string): string {
  return personaIndex.get(id)?.nombre_completo ?? id;
}

function orgLabel(id: string): string {
  return orgIndex.get(id)?.nombre ?? id;
}

function personaHref(id: string): string {
  return lang === 'ca' ? `/cat/personas/${id}` : `/personas/${id}`;
}

function orgHref(id: string): string {
  return lang === 'ca' ? `/cat/organizaciones/${id}` : `/organizaciones/${id}`;
}

function formatVinculoDate(value: string, precision?: string): string {
  if (precision === 'anio') return value.slice(0, 4);
  if (precision === 'mes') return value.slice(0, 7);
  return value;
}

function formatVinculoPeriodo(v: {
  desde: string;
  hasta?: string;
  precision_desde?: string;
  precision_hasta?: string;
  vigente?: boolean;
}): string {
  const desde = formatVinculoDate(v.desde, v.precision_desde);
  const hasta = v.hasta
    ? formatVinculoDate(v.hasta, v.precision_hasta)
    : v.vigente
      ? 'vigente'
      : 'sin fecha de cierre';
  return `${desde} → ${hasta}`;
}

function vinculoEntity(v: CollectionEntry<'vinculos'>['data'], side: 'sujeto' | 'objeto') {
  if (side === 'sujeto') {
    if (v.sujeto_persona_id) return { label: personaLabel(v.sujeto_persona_id), href: personaHref(v.sujeto_persona_id) };
    if (v.sujeto_organizacion_id) return { label: orgLabel(v.sujeto_organizacion_id), href: orgHref(v.sujeto_organizacion_id) };
  }
  if (v.objeto_persona_id) return { label: personaLabel(v.objeto_persona_id), href: personaHref(v.objeto_persona_id) };
  if (v.objeto_organizacion_id) return { label: orgLabel(v.objeto_organizacion_id), href: orgHref(v.objeto_organizacion_id) };
  return { label: 'Entidad no resuelta' };
}

const vinculosOrg = vinculosCol
  .filter((v) => v.data.sujeto_organizacion_id === data.id || v.data.objeto_organizacion_id === data.id)
  .filter((v) => v.data.estado_publicacion !== 'retirado_definitivamente')
  .sort((a, b) => b.data.desde.localeCompare(a.data.desde))
  .map((v) => {
    const sujeto = vinculoEntity(v.data, 'sujeto');
    const objeto = vinculoEntity(v.data, 'objeto');
    const primerCaso = v.data.relevancia_para_caso_ids?.[0];
    const caso = primerCaso ? casoIndex.get(primerCaso) : undefined;
    return {
      id: v.data.id,
      naturalezaLabel: naturalezaVinculoLabel(v.data.naturaleza),
      sujetoLabel: sujeto.label,
      sujetoHref: sujeto.href,
      objetoLabel: objeto.label,
      objetoHref: objeto.href,
      descripcion: v.data.descripcion,
      periodo: formatVinculoPeriodo(v.data),
      gobierno: v.data.gobierno_o_legislatura,
      casoLabel: caso?.nombre_mediatico ?? primerCaso,
      casoHref: primerCaso ? `/casos/${primerCaso}` : undefined,
      papel: v.data.sujeto_organizacion_id === data.id ? 'Sujeto' : 'Objeto',
      documentos: v.data.documentos_respaldo.map((ref) => {
        const doc = docIndex.get(ref.documento_id);
        return {
          titulo: doc?.titulo ?? ref.documento_id,
          href: doc
            ? documentoRespaldoHref(doc.id, doc, lang === 'ca' ? '/cat/biblioteca' : '/biblioteca')
            : undefined,
          pasaje: ref.pasaje,
          nota: ref.nota,
        };
      }),
    };
  });

// Bloque editorial sólo para medios de comunicación con clasificación documentada.
const editorialData = data as {
  naturaleza_editorial?: string;
  orientacion_editorial_declarada?: { valor: string; fuente: string; cita: string; url: string; fecha?: string };
  orientacion_editorial_percibida?: { valor: string; fuente: string; cita: string; url: string; fecha?: string };
  grupo_editorial?: { nombre: string; rol: string; cita?: string; url?: string };
  linea_editorial_declarada?: string;
};
const esMedio = data.tipo === 'medio_comunicacion';
const tieneClasificacionEditorial =
  esMedio && Boolean(
    editorialData.naturaleza_editorial ||
      editorialData.orientacion_editorial_declarada ||
      editorialData.orientacion_editorial_percibida ||
      editorialData.grupo_editorial ||
      editorialData.linea_editorial_declarada,
  );

const NATURALEZA_LABEL: Record<string, string> = {
  generalista_politico: 'Generalista político',
  verificacion: 'Verificación',
  especializado_juridico: 'Especializado jurídico',
  especializado_no_politico: 'Especializado',
  servicio_publico_estatal: 'Servicio público estatal',
  servicio_publico_autonomico: 'Servicio público autonómico',
  confesional: 'Confesional',
  otro: 'Otro',
};
const ORIENTACION_LABEL: Record<string, string> = {
  izquierda_extrema: 'Izquierda extrema',
  izquierda: 'Izquierda',
  centroizquierda: 'Centroizquierda',
  centro: 'Centro',
  centroderecha: 'Centroderecha',
  derecha: 'Derecha',
  derecha_extrema: 'Derecha extrema',
  sin_clasificar: 'Sin clasificar',
};
const FUENTE_LABEL: Record<string, string> = {
  estatuto_redaccion: 'Estatuto de Redacción',
  manifiesto_fundacional: 'Manifiesto fundacional',
  declaracion_publica_director: 'Declaración pública del director',
  libro_estilo_publico: 'Libro de estilo público',
  pagina_quienes_somos: 'Página «Quiénes somos»',
  ideario_corporativo: 'Ideario corporativo',
  reuters_institute: 'Reuters Institute',
  cis: 'CIS',
  estudio_academico_revisado: 'Estudio académico revisado',
  clasificacion_iniciativa_publica: 'Iniciativa pública con metodología',
};
const GRUPO_ROL_LABEL: Record<string, string> = {
  matriz: 'Matriz',
  filial_editorial: 'Filial editorial',
  participacion_relevante: 'Participación relevante',
};

// --- Personas relacionadas (inverso del bloque de Persona) -----------------
// Personas con vínculo formal a esta organización: tienen un cargo dirigido
// hacia esta org (objeto_organizacion_id === data.id) Y la naturaleza es
// cargo_* o nombramiento_por_gobierno. Bloque ortogonal a "Relaciones
// institucionales documentadas" — aquí se enseña sólo la persona y su
// cargo, sin documentos de respaldo. Para detalle: ver bloque de vínculos.
const NATURALEZAS_CARGO_PERSONA = new Set([
  'cargo_publico_electo',
  'cargo_publico_designado',
  'cargo_judicial',
  'cargo_organico_partido',
  'cargo_directivo_empresa_publica',
  'cargo_directivo_organizacion_privada',
  'cargo_academico_publico',
  'cargo_organizacion_civica',
  'nombramiento_por_gobierno',
]);
const personasRelacionadas = vinculosCol
  .filter(
    (v) =>
      v.data.objeto_organizacion_id === data.id &&
      v.data.sujeto_persona_id &&
      NATURALEZAS_CARGO_PERSONA.has(v.data.naturaleza) &&
      v.data.estado_publicacion !== 'retirado_definitivamente',
  )
  .sort((a, b) => {
    const aV = a.data.vigente ? 1 : 0;
    const bV = b.data.vigente ? 1 : 0;
    if (aV !== bV) return bV - aV;
    return (b.data.desde ?? '').localeCompare(a.data.desde ?? '');
  })
  .map((v) => ({
    vinculoId: v.data.id,
    personaId: v.data.sujeto_persona_id!,
    personaLabel: personaLabel(v.data.sujeto_persona_id!),
    personaHref: personaHref(v.data.sujeto_persona_id!),
    naturalezaLabel: naturalezaVinculoLabel(v.data.naturaleza),
    descripcion: v.data.descripcion,
    periodo: formatVinculoPeriodo(v.data),
    vigente: v.data.vigente,
  }));

let sectionCounter = 3;
const cifrasSectionNum = hayCifras ? `${sectionCounter++}.` : undefined;
const clasificacionSectionNum = tieneClasificacionEditorial ? `${sectionCounter++}.` : undefined;
const rolesSectionNum = rolesOrg.length > 0 ? `${sectionCounter++}.` : undefined;
const personasRelacionadasSectionNum = personasRelacionadas.length > 0 ? `${sectionCounter++}.` : undefined;
const vinculosSectionNum = vinculosOrg.length > 0 ? `${sectionCounter++}.` : undefined;
const documentosSectionNum = documentosProducidos.length > 0 ? `${sectionCounter++}.` : undefined;
const redaccionSectionNum = `${sectionCounter}.`;

const breadcrumb = [
  { label: 'Inicio', href: lang === 'ca' ? '/cat' : '/' },
  { label: 'Organizaciones', href: lang === 'ca' ? '/cat/organizaciones' : '/organizaciones' },
  { label: data.nombre },
];
const graphHref = `/conexiones?focus=organizacion&id=${data.id}&depth=2&layout=cose`;
---

<BaseLayout
  title={data.nombre}
  lang={lang}
  description={data.descripcion_corta ?? data.nombre}
  activeNav="organizaciones"
  breadcrumb={breadcrumb}
  ogImage={`/og/organizaciones/${data.id}.png`}
  ogType="article"
>
  <div class="ficha-detail">
  <section class="entity-mast">
    <OrgGlyph tipo={data.tipo} size={64} />
    <div class="entity-mast__body">
      <p class="entity-mast__eye">Ficha de organización</p>
      <h1 class="entity-mast__name">{data.nombre}</h1>
      <p class="entity-mast__sub">{tipoOrgLabel(data.tipo)}</p>
      <div class="entity-mast__row">
        {(data as { localidad?: string }).localidad && (
          <><span>{(data as { localidad?: string }).localidad}</span><span class="entity-mast__sep">·</span></>
        )}
        <span><strong>{casos.length}</strong> caso{casos.length === 1 ? '' : 's'} implicado{casos.length === 1 ? '' : 's'}</span>
        {documentosProducidos.length > 0 && (
          <>
            <span class="entity-mast__sep">·</span>
            <span><strong>{documentosProducidos.length}</strong> documento{documentosProducidos.length === 1 ? '' : 's'} producido{documentosProducidos.length === 1 ? '' : 's'}</span>
          </>
        )}
      </div>
      <div class="graph-link-row">
        <GraphConexionesLink href={graphHref} />
      </div>
    </div>
  </section>

  {data.descripcion_corta && (
    <FichaTocSection num="1." title="Descripción" id="descripcion">
      <div class="prose"><RichProse text={data.descripcion_corta} lang={lang} excludeOrgIds={[data.id]} /></div>
    </FichaTocSection>
  )}

  <FichaTocSection num="2." title="Casos implicados" id="casos" right={`${casos.length} caso${casos.length === 1 ? '' : 's'}`}>
    {casos.length === 0 ? (
      <p class="muted">Sin implicación procesal en los casos registrados.</p>
    ) : (
      <ul class="casos-list">
        {casos.map((c) => (
          <li class="casos-list__item">
            <a href={`/casos/${c.id}`}>
              <span class="c-name">{c.nombre_mediatico}</span>
              <span class="c-name__sub">{c.nombre_oficial}</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </FichaTocSection>

  {hayCifras && (
    <FichaTocSection num={cifrasSectionNum!} title="Cifras económicas" id="cifras">
      <CifrasSujetoBloque analisis={analisisCifras} casos={casosNombre} />
    </FichaTocSection>
  )}

  {tieneClasificacionEditorial && (
    <FichaTocSection
      num={clasificacionSectionNum!}
      title="Clasificación editorial"
      id="clasificacion-editorial"
    >
      {(editorialData.naturaleza_editorial || editorialData.orientacion_editorial_declarada) && (
        <div class="clasif-block">
          <div class="clasif-row">
            {editorialData.naturaleza_editorial && (
              <NaturalezaBadge naturaleza={editorialData.naturaleza_editorial} />
            )}
            {editorialData.orientacion_editorial_declarada && (
              <>
                <span class="clasif-sep" aria-hidden="true">›</span>
                <span class="clasif-label">Declarada</span>
                <OrientacionBadge valor={editorialData.orientacion_editorial_declarada.valor} />
              </>
            )}
          </div>
          {editorialData.orientacion_editorial_declarada && (
            <>
              <p class="clasif-source">
                {FUENTE_LABEL[editorialData.orientacion_editorial_declarada.fuente] ??
                  editorialData.orientacion_editorial_declarada.fuente}
                {' · '}
                <a
                  href={editorialData.orientacion_editorial_declarada.url}
                  target="_blank"
                  rel="noopener"
                >
                  Fuente original ↗
                </a>
                {editorialData.orientacion_editorial_declarada.fecha && (
                  <>
                    {' · '}
                    <span class="mono">{editorialData.orientacion_editorial_declarada.fecha}</span>
                  </>
                )}
              </p>
              <blockquote class="clasif-cita">
                «{editorialData.orientacion_editorial_declarada.cita}»
              </blockquote>
            </>
          )}
        </div>
      )}

      {editorialData.orientacion_editorial_percibida && (
        <div class="clasif-block">
          <div class="clasif-row">
            <span class="clasif-label">Percibida (fuente externa)</span>
            <OrientacionBadge valor={editorialData.orientacion_editorial_percibida.valor} />
          </div>
          <p class="clasif-source">
            {FUENTE_LABEL[editorialData.orientacion_editorial_percibida.fuente] ??
              editorialData.orientacion_editorial_percibida.fuente}
            {' · '}
            <a
              href={editorialData.orientacion_editorial_percibida.url}
              target="_blank"
              rel="noopener"
            >
              Estudio o fuente ↗
            </a>
            {editorialData.orientacion_editorial_percibida.fecha && (
              <>
                {' · '}
                <span class="mono">{editorialData.orientacion_editorial_percibida.fecha}</span>
              </>
            )}
          </p>
          <blockquote class="clasif-cita">
            «{editorialData.orientacion_editorial_percibida.cita}»
          </blockquote>
        </div>
      )}

      {editorialData.grupo_editorial && (
        <div class="clasif-block">
          <div class="clasif-row">
            <span class="clasif-label">Grupo editorial</span>
            <strong>{editorialData.grupo_editorial.nombre}</strong>
            <span class="clasif-rol">
              ({GRUPO_ROL_LABEL[editorialData.grupo_editorial.rol] ?? editorialData.grupo_editorial.rol})
            </span>
          </div>
          {editorialData.grupo_editorial.url && (
            <p class="clasif-source">
              <a href={editorialData.grupo_editorial.url} target="_blank" rel="noopener">
                Documento de respaldo ↗
              </a>
            </p>
          )}
          {editorialData.grupo_editorial.cita && (
            <blockquote class="clasif-cita">
              «{editorialData.grupo_editorial.cita}»
            </blockquote>
          )}
        </div>
      )}

      {!editorialData.orientacion_editorial_declarada &&
        !editorialData.orientacion_editorial_percibida &&
        editorialData.linea_editorial_declarada && (
          <div class="clasif-block">
            <span class="clasif-label">Autodefinición editorial</span>
            <blockquote class="clasif-cita">
              «{editorialData.linea_editorial_declarada}»
            </blockquote>
          </div>
        )}

      <Aclaracion nivel="baja">
        Cada valor refleja cómo se clasifica el medio: bien por sus propios documentos
        fundacionales o autoadscripción literal, bien por estudios externos con metodología
        documentada. Sin etiquetas peyorativas, sin valoraciones de veracidad.
        Ver <a href={lang === 'ca' ? '/cat/sobre' : '/sobre'}>metodología</a>.
      </Aclaracion>
    </FichaTocSection>
  )}

  {rolesOrg.length > 0 && (
    <FichaTocSection num={rolesSectionNum!} title="Roles procesales asumidos" id="roles" right={`${rolesOrg.length} rol${rolesOrg.length === 1 ? '' : 'es'}`}>
      <div class="tbl-scroll">
      <table class="tbl">
        <thead>
          <tr>
            <th style="width: 22%;">Periodo</th>
            <th style="width: 28%;">Rol</th>
            <th>Caso</th>
          </tr>
        </thead>
        <tbody>
          {rolesOrg.map((r) => (
            <tr>
              <td class="c-mono">{r.fecha_inicio}{r.fecha_fin ? ` → ${r.fecha_fin}` : ' → vigente'}</td>
              <td><RolBadge rol={r.rol} label={r.rolLabel} /></td>
              <td><a href={`/casos/${r.caso_id}`}>{casoIndex.get(r.caso_id)?.nombre_mediatico ?? r.caso_id}</a></td>
            </tr>
          ))}
        </tbody>
      </table>
      </div>
    </FichaTocSection>
  )}

  {personasRelacionadas.length > 0 && (
    <FichaTocSection
      num={personasRelacionadasSectionNum!}
      title="Cargos y nombramientos documentados"
      id="personas-relacionadas"
      right={`${personasRelacionadas.length} persona${personasRelacionadas.length === 1 ? '' : 's'}`}
    >
      <Aclaracion nivel="media">
        Personas con cargo, designación o nombramiento documentado en esta organización.
        Para el detalle de cada vínculo, ver el bloque de relaciones institucionales.
      </Aclaracion>
      <div class="personas-rel-list">
        {personasRelacionadas.map((pr) => (
          <article class="personas-rel-item" id={`persona-rel-${pr.vinculoId}`}>
            <SourceLinkBadge label={pr.naturalezaLabel} href={`#vinculo-${pr.vinculoId}`} />
            <div class="personas-rel-item__body">
              <p class="personas-rel-item__headline">
                <a href={pr.personaHref}>{pr.personaLabel}</a>
              </p>
              <a class="personas-rel-item__desc" href={`#vinculo-${pr.vinculoId}`}>
                {pr.descripcion}
              </a>
              <p class="personas-rel-item__meta">
                <span>{pr.periodo}</span>
              </p>
            </div>
          </article>
        ))}
      </div>
    </FichaTocSection>
  )}

  {vinculosOrg.length > 0 && (
    <FichaTocSection
      num={vinculosSectionNum!}
      title="Relaciones institucionales documentadas"
      id="contexto-institucional"
      right={`${vinculosOrg.length} vínculo${vinculosOrg.length === 1 ? '' : 's'}`}
    >
      <Aclaracion nivel="media">
        Vínculos formales documentados en los que aparece esta organización. Este bloque
        queda separado de los roles procesales y de los documentos producidos.
      </Aclaracion>
      <VinculosInstitucionalesList rows={vinculosOrg} />
    </FichaTocSection>
  )}

  {documentosProducidos.length > 0 && (
    <FichaTocSection num={documentosSectionNum!} title="Documentos producidos" id="documentos" right={`${documentosProducidos.length} documento${documentosProducidos.length === 1 ? '' : 's'}`}>
      <ul class="docs-list">
        {documentosProducidos.map((d) => (
          <li>
            <span class:list={['badge', `badge--n${d.data.nivel_fuente}`]}>N{d.data.nivel_fuente}</span>
            <span class="docs-list__title">{d.data.titulo}</span>
            <span class="docs-list__date">{d.data.fecha_documento}</span>
          </li>
        ))}
      </ul>
    </FichaTocSection>
  )}

  <FichaTocSection num={redaccionSectionNum} title="Sobre esta ficha" id="redaccion">
    <div class="prose">
      <ul class="meta-list">
        <li>
          <strong>Estado de la ficha:</strong>
          <EstadoPublicacionBadge estado={data.estado_publicacion as EstadoPub} compact />
        </li>
        {data.ultima_revision_editorial && (
          <li><strong>Última revisión editorial:</strong> <span class="mono">{data.ultima_revision_editorial}</span></li>
        )}
        {data.url_canonica && (
          <li>
            <strong>Sitio oficial:</strong> <a href={data.url_canonica} target="_blank" rel="noopener">{data.url_canonica} ↗</a>
          </li>
        )}
      </ul>
    </div>
  </FichaTocSection>
  </div>
</BaseLayout>

