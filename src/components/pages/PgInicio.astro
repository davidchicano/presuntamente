---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PhaseBadge from '@/components/PhaseBadge.astro';
import EstadoPublicacionBadge from '@/components/EstadoPublicacionBadge.astro';
import RolBadge from '@/components/RolBadge.astro';
import PartidoBadge from '@/components/PartidoBadge.astro';
import Aclaracion from '@/components/Aclaracion.astro';
import StackedBar, { type StackSegment } from '@/components/charts/StackedBar.astro';
import Sheet from '@/components/Sheet.astro';
import { rolLabel } from '@/lib/labels';
import { getCollection } from 'astro:content';
import {
  organizacionesAfectadasDeCaso,
  partidosAfectadosIndirectosDeCaso,
} from '@/lib/afectacion';

interface Props {
  lang?: 'es' | 'ca';
}

const { lang = 'es' } = Astro.props;

// --- Cifras del inventario --------------------------------------------------

const [casos, personas, organizaciones, documentos, hitosCol, rolesCol, vinculosCol] = await Promise.all([
  getCollection('casos'),
  getCollection('personas'),
  getCollection('organizaciones'),
  getCollection('documentos'),
  getCollection('hitos'),
  getCollection('roles'),
  getCollection('vinculos'),
]);

const orgIdx = new Map(organizaciones.map((o) => [o.data.id, o.data]));

// --- Teaser visual del hero: casos por fase (enlaza a /graficas) ------------
// Buckets de la secuencia procesal en rampa navy (claro = pronto, oscuro =
// firme) + gris para archivados. Sin leyenda; el detalle vive en /graficas.
const FASE_BUCKETS = [
  { id: 'instruccion', label: 'Instrucción', fases: ['denuncia_o_querella', 'instruccion', 'fase_intermedia'], color: 'color-mix(in srgb, var(--color-accent) 40%, var(--color-surface))' },
  { id: 'juicio', label: 'Juicio oral', fases: ['juicio_oral', 'recurso', 'sentencia_primera_instancia'], color: 'color-mix(in srgb, var(--color-accent) 68%, var(--color-surface))' },
  { id: 'firme', label: 'Sentencia firme', fases: ['sentencia_firme', 'ejecucion'], color: 'var(--color-accent)' },
  { id: 'archivado', label: 'Archivado', fases: ['archivo_provisional', 'archivo_libre'], color: 'var(--color-fg-subtle)' },
];
// Sólo casos en beta pública o superior, igual que /graficas (los esqueletos
// no distorsionan el teaser).
const TEASER_VISIBLES = new Set(['beta_publica', 'en_revision', 'publicado']);
const faseCountHome = new Map<string, number>();
const casosByBucket = new Map<string, Array<{ nombre: string; slug: string }>>();
for (const c of casos) {
  if (!TEASER_VISIBLES.has(c.data.estado_publicacion)) continue;
  faseCountHome.set(c.data.fase_actual, (faseCountHome.get(c.data.fase_actual) ?? 0) + 1);
  const bucket = FASE_BUCKETS.find((b) => b.fases.includes(c.data.fase_actual));
  if (bucket) {
    const arr = casosByBucket.get(bucket.id) ?? [];
    arr.push({ nombre: c.data.nombre_mediatico, slug: c.data.id });
    casosByBucket.set(bucket.id, arr);
  }
}
const totalCasosTeaser = Array.from(faseCountHome.values()).reduce((a, b) => a + b, 0);
const faseTeaserSegments: StackSegment[] = FASE_BUCKETS
  .map((b) => ({
    label: b.label,
    value: b.fases.reduce((a, f) => a + (faseCountHome.get(f) ?? 0), 0),
    color: b.color,
    refKey: `home-fase:${b.id}`,
  }))
  .filter((s) => s.value > 0);
// Drill-down (Sheet): un bloque de contenido por bucket con casos.
const teaserSheets = FASE_BUCKETS
  .map((b) => ({ key: `home-fase:${b.id}`, label: b.label, casos: casosByBucket.get(b.id) ?? [] }))
  .filter((s) => s.casos.length > 0);

// --- Casos destacados ------------------------------------------------------
// Ranking simple: actividad reciente (último hito) y relevancia editorial.
// Excluimos estados no publicables. Sacamos top 2 para que la landing
// muestre algo más que un único pivote (decisión maintainer 2026-05-26).
const RELEVANCIA_RANK: Record<string, number> = { capital: 4, alta: 3, media: 2, baja: 1 };
// Etiqueta corta por naturaleza de afectación DIRECTA usada en el preview
// de casos destacados. Misma convención que /casos: las dos naturalezas con
// equivalente procesal (investigada / perjudicada) reusan RolBadge; ámbito
// administrativo no es rol procesal y se etiqueta como microtag de texto.
const NATURALEZA_A_ROL_DESTACADOS: Record<string, string> = {
  entidad_investigada_en_caso: 'investigado',
  perjudicado_institucional_en_caso: 'perjudicado',
};
const NATURALEZA_A_TAG_DESTACADOS: Record<string, string> = {
  ambito_administrativo_directo_del_acto_en_caso: 'Ámbito del acto',
};
const ESTADOS_VISIBLES = new Set(['beta_publica', 'en_revision', 'publicado']);

function aplanaProsa(raw: string | undefined): string {
  if (!raw) return '';
  return raw.replace(/\s+/g, ' ').trim();
}
function truncarHitoDestacado(s: string, max = 110): string {
  if (!s) return '';
  const flat = s.replace(/\s+/g, ' ').trim();
  if (flat.length <= max) return flat;
  const slice = flat.slice(0, max);
  const lastSpace = slice.lastIndexOf(' ');
  return (lastSpace > 60 ? slice.slice(0, lastSpace) : slice).trim() + '…';
}

const destacados = casos
  .filter((c) => ESTADOS_VISIBLES.has(c.data.estado_publicacion))
  .map((c) => {
    const caso = c.data;
    const hitos = hitosCol
      .filter((h) => h.data.caso_id === caso.id)
      .sort((a, b) => b.data.fecha.localeCompare(a.data.fecha));
    const ultimo = hitos[0]?.data;

    // Afectadas (directa + indirecta) derivadas de VinculoInstitucional vía
    // src/lib/afectacion.ts. Tomamos la primera directa (alfabético) como
    // "organización principal" del caso para el preview compacto.
    const afectadas = organizacionesAfectadasDeCaso(caso.id, vinculosCol, orgIdx);
    const primeraDirecta = afectadas.directas[0];
    const orgPrincipalId = primeraDirecta?.organizacionId;
    const orgPrincipalNombre = primeraDirecta?.nombre;
    const orgPrincipalRol = primeraDirecta ? NATURALEZA_A_ROL_DESTACADOS[primeraDirecta.naturaleza] : undefined;
    const orgPrincipalTag = primeraDirecta ? NATURALEZA_A_TAG_DESTACADOS[primeraDirecta.naturaleza] : undefined;

    // Partidos como chips: sólo las indirectas que son partido_politico.
    // Dedupe ya garantizado por afectacion.ts.
    const partidos = partidosAfectadosIndirectosDeCaso(caso.id, vinculosCol, orgIdx)
      .map((o) => ({ id: o.organizacionId, label: o.siglas ?? o.nombre }));

    const resumenEjecutivo =
      (caso as { descripcion_corta?: string }).descripcion_corta ??
      (caso as { sintesis_caso?: { que_se_investiga?: string } }).sintesis_caso?.que_se_investiga ??
      '';

    return {
      id: caso.id,
      mediatico: caso.nombre_mediatico,
      oficial: caso.nombre_oficial,
      faseActual: caso.fase_actual,
      estadoPublicacion: caso.estado_publicacion,
      descripcion: aplanaProsa(resumenEjecutivo),
      orgPrincipalId,
      orgPrincipalNombre,
      orgPrincipalRol,
      orgPrincipalTag,
      partidos,
      ultimoHitoFecha: ultimo?.fecha,
      ultimoHitoTitulo: ultimo ? truncarHitoDestacado(ultimo.titulo) : undefined,
      ultimoHitoTituloFull: ultimo?.titulo,
      pin: (caso as { pin_destacado?: number }).pin_destacado,
      score: {
        fecha: ultimo?.fecha ?? '0000-00-00',
        relevancia: RELEVANCIA_RANK[caso.nivel_relevancia_editorial ?? 'media'] ?? 2,
      },
    };
  })
  .sort((a, b) => {
    // Override editorial: los casos con pin_destacado van primero (asc por valor).
    // Resto por algoritmo: última fecha de hito desc, luego relevancia desc.
    if (a.pin !== undefined && b.pin === undefined) return -1;
    if (a.pin === undefined && b.pin !== undefined) return 1;
    if (a.pin !== undefined && b.pin !== undefined) return a.pin - b.pin;
    if (a.score.fecha !== b.score.fecha) return b.score.fecha.localeCompare(a.score.fecha);
    return b.score.relevancia - a.score.relevancia;
  })
  .slice(0, 2);

// TODO i18n: rama 'ca' cuando se active el catalán.
const strings = {
  title: 'La corrupción en España, ordenada y con sus fuentes',
  description:
    'Inventario público, interactivo y open-source de los casos de corrupción más relevantes en España.',
  eyebrow: 'Inventario público',
  hero: {
    kicker: 'sin ruido, sin ideología, con fuente',
    title: 'La corrupción en España, ordenada y con sus fuentes.',
    lede:
      'Un mapa público de los casos judiciales relevantes. Cada hecho cita el documento que lo respalda y su nivel de fuente. Imputación nunca equivale a condena.',
    ctaPrimary: { label: 'Explorar casos', href: '/casos' },
    ctaGhost: { label: 'Cómo se redacta', href: '/sobre' },
  },
  reglas: [
    { title: 'Cita siempre', body: 'Cada afirmación cita el documento que la respalda, con su nivel de fuente visible.' },
    { title: 'Sin cuota política', body: 'Casos de cualquier partido, ordenados por relevancia objetiva.' },
    { title: 'Presunción de inocencia', body: 'Investigado, procesado y condenado son cosas distintas — y se distinguen.' },
  ],
  contadores: [
    { label: 'Casos catalogados',       value: casos.length },
    { label: 'Personas con papel formal', value: personas.length },
    { label: 'Organizaciones citadas',  value: organizaciones.length },
    { label: 'Documentos de respaldo',  value: documentos.length },
  ],
  secciones: [
    {
      key: 'casos',
      num: '01',
      title: 'Catálogo de casos',
      desc: 'Todos los procedimientos con su fase, tribunal y último movimiento documentado.',
      href: '/casos',
      cta: 'Ver catálogo',
    },
    {
      key: 'personas',
      num: '02',
      title: 'Personas implicadas',
      desc: 'Índice de personas con cargo o papel formal en cada procedimiento.',
      href: '/personas',
      cta: 'Ver personas',
    },
    {
      key: 'organizaciones',
      num: '03',
      title: 'Organizaciones citadas',
      desc: 'Órganos judiciales, fiscalías, partidos, empresas y organismos públicos referenciados.',
      href: '/organizaciones',
      cta: 'Ver organizaciones',
    },
    {
      key: 'biblioteca',
      num: '04',
      title: 'Biblioteca documental',
      desc: 'Sentencias, autos judiciales, informes policiales y piezas periodísticas de referencia.',
      href: '/biblioteca',
      cta: 'Ver documentos',
    },
  ],
  disclaimer:
    'Las personas mencionadas como investigadas o procesadas se presumen inocentes hasta que recaiga sentencia firme.',
};
---

<BaseLayout
  title={strings.title}
  lang={lang}
  description={strings.description}
  hideSubstrip={true}
>
  <section class="hero">
    <div class="hero__col-text">
      <p class="hero__kicker">{strings.hero.kicker}</p>
      <h1 class="hero__title">{strings.hero.title}</h1>
      <p class="hero__lede">{strings.hero.lede}</p>
      <div class="hero__ctas">
        <a class="cta cta--primary" href={strings.hero.ctaPrimary.href}>
          <span>{strings.hero.ctaPrimary.label}</span>
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a class="cta cta--ghost" href={strings.hero.ctaGhost.href}>
          {strings.hero.ctaGhost.label} →
        </a>
      </div>
    </div>
    <aside class="hero__col-aside" aria-label="Cifras del inventario">
      <div class="hero__stamp">
        <span class="hero__stamp-eye">{strings.eyebrow}<span class="hero__stamp-date"> · desde 2026</span></span>
        <a class="hero__stamp-link" href="/cifras">Ver todas las cifras →</a>
      </div>
      <ul class="hero__cifras">
        {strings.contadores.map((c) => (
          <li>
            <span class="hero__cifra-val">{c.value}</span>
            <span class="hero__cifra-lbl">{c.label}</span>
          </li>
        ))}
      </ul>
      {faseTeaserSegments.length > 0 && (
        <div class="hero__viz">
          <span class="hero__viz-head">
            <span class="hero__viz-label">Casos por fase</span>
            <span class="hero__viz-sub">{totalCasosTeaser} casos en beta o superior</span>
          </span>
          <StackedBar segments={faseTeaserSegments} legend="min" ariaLabel="Distribución de casos por fase procesal" />
        </div>
      )}
      <a class="hero__cifras-more" href="/graficas">
        Ver gráficas →
      </a>
    </aside>
  </section>

  <ol class="reglas" aria-label="Principios del inventario">
    {strings.reglas.map((r) => (
      <li class="regla">
        <h3 class="regla__title">{r.title}</h3>
        <p class="regla__body">{r.body}</p>
      </li>
    ))}
  </ol>

  {destacados.length > 0 && (
    <section class="destacado">
      <header class="destacado__head">
        <span class="destacado__eye">Casos destacados</span>
        <a class="destacado__more" href="/casos">Ver catálogo completo →</a>
      </header>
      <div class="destacado__stack">
        {destacados.map((d) => (
          <a class="destacado__card" href={`/casos/${d.id}`}>
            <div class="destacado__main">
              <div class="destacado__top">
                <PhaseBadge fase={d.faseActual} />
                <EstadoPublicacionBadge estado={d.estadoPublicacion as 'pendiente' | 'borrador' | 'beta_publica' | 'en_revision' | 'publicado' | 'retirado_temporalmente' | 'retirado_definitivamente'} compact />
              </div>
              <h2 class="destacado__name">{d.mediatico}</h2>
              <p class="destacado__oficial">{d.oficial}</p>
              {d.descripcion && (
                <p class="destacado__desc">{d.descripcion}</p>
              )}
            </div>
            <dl class="destacado__meta">
              {d.orgPrincipalNombre && (
                <div>
                  <dt>Organización afectada</dt>
                  <dd>
                    <span>{d.orgPrincipalNombre}</span>
                    {d.orgPrincipalRol && (
                      <RolBadge rol={d.orgPrincipalRol} label={rolLabel(d.orgPrincipalRol)} />
                    )}
                    {d.orgPrincipalTag && (
                      <span class="destacado__tag">{d.orgPrincipalTag}</span>
                    )}
                  </dd>
                </div>
              )}
              {d.partidos.length > 0 && (
                <div>
                  <dt>Partidos alcanzados (indirecta)</dt>
                  <dd class="destacado__partidos">
                    {d.partidos.map((p) => (
                      <PartidoBadge id={p.id} label={p.label} size="sm" asLink={false} />
                    ))}
                  </dd>
                </div>
              )}
              {d.ultimoHitoTitulo && (
                <div class="destacado__last">
                  <dt>Último hito</dt>
                  <dd title={d.ultimoHitoTituloFull}>
                    <span class="destacado__mono">{d.ultimoHitoFecha}</span>
                    <span class="destacado__hito-text"> · {d.ultimoHitoTitulo}</span>
                  </dd>
                </div>
              )}
            </dl>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="secciones">
    <header class="secciones__head">
      <h2>Explora el inventario</h2>
      <p>Cuatro entradas según lo que busques.</p>
    </header>
    <ul class="secciones__list">
      {strings.secciones.map((s) => (
        <li>
          <a class="seccion" href={s.href}>
            <span class="seccion__num">{s.num}</span>
            <div class="seccion__body">
              <h3 class="seccion__title">{s.title}</h3>
              <p class="seccion__desc">{s.desc}</p>
              <span class="seccion__cta">{s.cta} →</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <Aclaracion nivel="baja" class="aclaracion--centered">{strings.disclaimer}</Aclaracion>

  {/* Drill-down del teaser de fase: contenido oculto que clona el Sheet. */}
  <div hidden data-sheet-contents data-pagefind-ignore>
    {teaserSheets.map((s) => (
      <div data-sheet-content={s.key} data-sheet-title={`${s.label} · ${s.casos.length}`}>
        <ul class="sheet-list">
          {s.casos.map((c) => (
            <li><a href={`/casos/${c.slug}`}><span>{c.nombre}</span></a></li>
          ))}
        </ul>
        <a class="sheet-all" href="/casos">Ver todos los casos →</a>
      </div>
    ))}
  </div>
  <Sheet />
</BaseLayout>

<style>
  /* ========== HERO ========== */
  .hero {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-6);
    align-items: center;
    padding: clamp(var(--space-5), 6vw, var(--space-7)) 0 var(--space-6);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-6);
  }
  .hero__kicker {
    font: 700 11px/1 var(--font-sans);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent-secondary-hover);
    margin: 0 0 var(--space-3);
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .hero__kicker::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--color-accent-secondary-hover);
  }
  .hero__title {
    font-family: var(--font-serif), Georgia, serif;
    font-weight: 700;
    font-size: clamp(2rem, 1.4rem + 2.6vw, 3.2rem);
    line-height: 1.08;
    letter-spacing: -0.015em;
    color: var(--color-fg);
    margin: 0 0 var(--space-4);
    text-wrap: balance;
  }
  .hero__lede {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(1.05rem, 1rem + 0.3vw, 1.18rem);
    line-height: 1.55;
    color: var(--color-fg-muted);
    margin: 0 0 var(--space-5);
    max-width: 55ch;
  }
  .hero__ctas {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    align-items: center;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    font: 600 14px/1 var(--font-sans);
    letter-spacing: 0.01em;
    border: 1px solid;
    border-radius: 0;
    cursor: pointer;
    text-decoration: none;
    transition: transform 140ms ease-out, background 140ms ease-out, color 140ms ease-out;
  }
  .cta svg {
    width: 14px;
    height: 14px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: transform 180ms ease-out;
  }
  .cta--primary {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }
  .cta--primary:hover {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
  }
  .cta--primary:hover svg { transform: translateX(3px); }
  .cta--ghost {
    background: transparent;
    color: var(--color-accent);
    border-color: transparent;
    padding: 12px 8px;
    text-decoration: none;
  }
  .cta--ghost:hover {
    color: var(--color-accent-hover);
    background: var(--color-accent-soft);
  }

  /* Aside derecha del hero: "sello" institucional con cifras */
  .hero__col-aside {
    border: 1px solid var(--color-border-strong);
    background: var(--color-surface);
    position: relative;
  }
  .hero__col-aside::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: linear-gradient(
      to right,
      var(--color-accent) 0 50%,
      var(--color-accent-secondary) 50% 100%
    );
  }
  .hero__stamp {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 14px;
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .hero__cifras {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
  .hero__cifras li {
    padding: 14px 16px;
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .hero__cifras li:nth-child(2n) { border-right: 0; }
  .hero__cifras li:nth-last-child(-n+2) { border-bottom: 0; }
  .hero__cifras-more {
    display: block;
    padding: 10px 14px;
    border-top: 1px solid var(--color-border);
    font: 600 12px/1 var(--font-sans);
    letter-spacing: 0.04em;
    color: var(--color-accent);
    text-decoration: none;
    background: var(--color-surface);
    text-align: right;
    transition: background 140ms ease-out, color 140ms ease-out;
  }
  .hero__cifras-more:hover {
    background: var(--color-bg-muted);
    color: var(--color-accent-hover);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  /* Cabecera del sello: enlace "Ver todas las cifras" a la derecha */
  .hero__stamp-link {
    color: var(--color-accent);
    text-decoration: none;
    white-space: nowrap;
    transition: color 140ms ease-out;
  }
  .hero__stamp-link:hover {
    color: var(--color-accent-hover);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  /* Teaser visual estático: mini-barra de casos por fase (no interactiva;
     para ir a las gráficas está el enlace "Ver gráficas" de abajo). */
  .hero__viz {
    padding: 12px 14px 14px;
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
  }
  .hero__viz-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 8px;
  }
  .hero__viz-label {
    font: 600 11px/1 var(--font-sans);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
  }
  .hero__viz-sub {
    font: 500 10px/1 var(--font-mono);
    color: var(--color-fg-subtle);
  }
  .hero__cifra-val {
    font: 700 clamp(1.6rem, 1.2rem + 1vw, 2.2rem)/1 var(--font-sans);
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
  }
