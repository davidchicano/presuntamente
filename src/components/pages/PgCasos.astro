---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CustomSelect from '@/components/CustomSelect.astro';
import MultiSelectFilter from '@/components/MultiSelectFilter.astro';
import CatalogoLeyenda from '@/components/CatalogoLeyenda.astro';
import SectionH from '@/components/SectionH.astro';
import PhaseBadge from '@/components/PhaseBadge.astro';
import EstadoPublicacionBadge from '@/components/EstadoPublicacionBadge.astro';
import RolBadge from '@/components/RolBadge.astro';
import PartidoBadge from '@/components/PartidoBadge.astro';
import { getCollection } from 'astro:content';
import { rolLabel } from '@/lib/labels';
import { organizacionesAfectadasDeCaso } from '@/lib/afectacion';
import { ultimaActualizacionDeCaso } from '@/lib/git-meta';

// En producción los casos en `pendiente`/`borrador` aparecen en la tabla
// pero no son clickables y la ruta /casos/<slug> no se genera (ver
// src/pages/casos/[slug].astro getStaticPaths). En dev local TODO es
// clickable para que el maintainer pueda trabajar fichas en construcción.
const IS_PROD = import.meta.env.PROD;
const ESTADOS_BLOQUEADOS_EN_PROD: ReadonlyArray<string> = ['pendiente', 'borrador'];
type EstadoPublicacion =
  | 'pendiente'
  | 'borrador'
  | 'beta_publica'
  | 'en_revision'
  | 'publicado'
  | 'retirado_temporalmente'
  | 'retirado_definitivamente';

interface Props {
  lang?: 'es' | 'ca';
}

const { lang = 'es' } = Astro.props;

// TODO i18n: cuando se active el catalán, añadir la rama 'ca' en strings y
// crear los wrappers en /src/pages/cat/ que llamen a este componente con
// lang="ca".
const strings = {
  title: 'Catálogo de casos',
  description:
    'Listado público de los procedimientos judiciales relevantes registrados en presuntamente.org.',
  eyebrow: 'Sección 1 · Casos',
  sub:
    'Listado de los procedimientos judiciales relevantes registrados en este sitio. Cada caso ' +
    'enlaza con su ficha completa, sus personas implicadas y los documentos primarios que lo respaldan.',
  leyendaEstadosTitulo: 'Estado de elaboración de la ficha',
  leyendaEstadosIntro:
    'Indica el grado de avance editorial de cada ficha. No debe confundirse con la fase procesal del caso (instrucción, juicio oral, sentencia firme), que se muestra aparte.',
};

const LEYENDA_ESTADOS: ReadonlyArray<{ estado: EstadoPublicacion; nota: string }> = [
  { estado: 'pendiente', nota: 'En cola; aún no se ha empezado a trabajar la ficha.' },
  { estado: 'borrador', nota: 'Ficha en desarrollo; no accesible en producción.' },
  { estado: 'beta_publica', nota: 'Publicada con huecos editoriales menores.' },
  { estado: 'en_revision', nota: 'Revisión interna antes de darla por cerrada.' },
  { estado: 'publicado', nota: 'Ficha al máximo de lo que el inventario permite hoy.' },
  { estado: 'retirado_temporalmente', nota: 'Retirada temporalmente del catálogo público.' },
  { estado: 'retirado_definitivamente', nota: 'Retirada definitivamente del catálogo público.' },
];

// --- Carga desde Content Collections ----------------------------------------

const [casosCol, hitosCol, rolesCol, organizacionesCol, vinculosCol] = await Promise.all([
  getCollection('casos'),
  getCollection('hitos'),
  getCollection('roles'),
  getCollection('organizaciones'),
  getCollection('vinculos'),
]);

// Etiqueta corta por naturaleza de afectación, mostrada bajo el nombre
// de cada organización afectada en la columna del listado. Las dos
// naturalezas con `rol` procesal equivalente reutilizan `RolBadge`; el
// "ámbito administrativo directo" se etiqueta como microtag de texto
// porque no es un rol procesal. Ver docs/diseno/08-afectacion-directa-indirecta.md.
const NATURALEZA_AFECTADA_DIRECTA_ROL: Record<string, string> = {
  entidad_investigada_en_caso: 'investigado',
  perjudicado_institucional_en_caso: 'perjudicado',
};
const NATURALEZA_AFECTADA_DIRECTA_TAG: Record<string, string> = {
  ambito_administrativo_directo_del_acto_en_caso: 'Ámbito del acto',
};

// Truncado del título del último hito para no engordar la fila.
function truncarHito(s: string, max = 90): string {
  if (!s) return '';
  const flat = s.replace(/\s+/g, ' ').trim();
  if (flat.length <= max) return flat;
  const slice = flat.slice(0, max);
  const lastSpace = slice.lastIndexOf(' ');
  return (lastSpace > 50 ? slice.slice(0, lastSpace) : slice).trim() + '…';
}

// Helper: mapeo de fase_actual (10 valores) → bucket de UI (5 valores).
// Coincide con PhaseBadge.astro: instr / intermedia / juicio / firme / archivo.
// Cada bucket tiene su micro-barra de progreso en el badge (F4).
function mapFase(fase: string): { kind: 'instr' | 'intermedia' | 'juicio' | 'firme' | 'archivo'; label: string } {
  if (fase === 'instruccion' || fase === 'denuncia_o_querella') {
    return { kind: 'instr', label: 'Instrucción' };
  }
  if (fase === 'fase_intermedia') {
    return { kind: 'intermedia', label: 'Fase intermedia' };
  }
  if (fase === 'juicio_oral' || fase === 'sentencia_primera_instancia' || fase === 'recurso') {
    return { kind: 'juicio', label: 'Juicio oral' };
  }
  if (fase === 'sentencia_firme' || fase === 'ejecucion') {
    return { kind: 'firme', label: 'Sentencia firme' };
  }
  if (fase === 'archivo_provisional') {
    return { kind: 'archivo', label: 'Archivo provisional' };
  }
  if (fase === 'archivo_libre') {
    return { kind: 'archivo', label: 'Archivo libre' };
  }
  return { kind: 'instr', label: fase };
}

// Orden numérico de la pirámide procesal para ordenar el listado por fase
// ascendente (instrucción → archivo) o descendente. Coincide 1-a-1 con los
// 5 buckets de `mapFase`.
const PHASE_ORDER: Record<string, number> = {
  instr: 1,
  intermedia: 2,
  juicio: 3,
  firme: 4,
  archivo: 5,
};

// "Implicados con rol activo": personas con rol de imputación (investigado,
// procesado, acusado, condenado) cuyo rol no tenga fecha_fin. Decisión
// editorial razonada: en cultura periodística española "implicado" se usa
// específicamente para investigados/imputados, no para todo agente formal
// del procedimiento (juez instructor, fiscal, acusación popular). Si más
// adelante el maintainer prefiere otra definición, ajustar aquí.
const ROLES_IMPUTACION = new Set(['investigado', 'procesado', 'acusado', 'condenado']);

const orgIndex = new Map(organizacionesCol.map((o) => [o.data.id, o.data]));

const casos = casosCol
  .map((c) => {
    const caso = c.data;
    const hitosDelCaso = hitosCol
      .filter((h) => h.data.caso_id === caso.id)
      .sort((a, b) => b.data.fecha.localeCompare(a.data.fecha));
    const ultimo = hitosDelCaso[0]?.data;
    const implicados = rolesCol.filter(
      (r) =>
        r.data.caso_id === caso.id &&
        r.data.sujeto_tipo === 'persona' &&
        ROLES_IMPUTACION.has(r.data.rol) &&
        !r.data.fecha_fin,
    ).length;
    // Organizaciones afectadas (directa + indirecta), derivadas de
    // VinculoInstitucional vía src/lib/afectacion.ts. Dedupe por
    // organizacion_id centralizado en ese módulo (norma 2026-05-27).
    const afectadas = organizacionesAfectadasDeCaso(caso.id, vinculosCol, orgIndex);

    const org = orgIndex.get(caso.organo_judicial_id);
    // Para la columna "Órgano" preferimos el acrónimo cuando existe (AN, JCI 4),
    // y si no, una versión corta del nombre. El detalle pasa a la ficha.
    const organoCorto =
      org?.nombres_alternativos?.[0] ??
      org?.siglas ??
      org?.nombre ??
      caso.organo_judicial_id;
    const fase = mapFase(caso.fase_actual);
    // Fecha del último commit que tocó la carpeta del caso. En Cloudflare
    // Pages con clone shallow puede devolver null para casos no tocados en
    // el HEAD: aceptamos el fallback a "—" en UI / ordenación al final.
    const actualizado = ultimaActualizacionDeCaso(caso.id);
    // Set único de orgIds afectadas (directa OR indirecta) para alimentar
    // el multi-select y la regla de filtrado client-side.
    const orgIdsAfectadas = Array.from(
      new Set([
        ...afectadas.directas.map((o) => o.organizacionId),
        ...afectadas.indirectas.map((o) => o.organizacionId),
      ]),
    );
    return {
      slug: caso.id,
      mediatico: caso.nombre_mediatico,
      oficial: caso.nombre_oficial,
      // Mini-descripción: preferimos `sintesis_caso.que_se_investiga`
      // (resume el caso en una frase) sobre `descripcion_corta` (más larga
      // y a menudo orientada al resumen ejecutivo). Fallback al segundo.
      descripcion:
        (caso as { sintesis_caso?: { que_se_investiga?: string } }).sintesis_caso?.que_se_investiga ??
        (caso as { descripcion_corta?: string }).descripcion_corta ??
        '',
      fase_actual: caso.fase_actual,
      phaseKind: fase.kind,
      phaseOrder: PHASE_ORDER[fase.kind] ?? 9,
      actualizado,
      orgIdsAfectadas,
      estado_publicacion: caso.estado_publicacion as EstadoPublicacion,
      bloqueadoEnProd: IS_PROD && ESTADOS_BLOQUEADOS_EN_PROD.includes(caso.estado_publicacion),
      organo: organoCorto,
      organoFull: org?.nombre ?? caso.organo_judicial_id,
      organoId: caso.organo_judicial_id,
      numero: caso.numero_procedimiento ?? '',
      implicados,
      // Lista de organizaciones afectadas para la columna fusionada.
      // Pre-resuelve el RolBadge / microtag por naturaleza y la etiqueta
      // visible (nombre completo para no-partidos, siglas para partidos).
      afectadasDirectas: afectadas.directas.map((o) => ({
        id: o.organizacionId,
        nombre: o.nombre,
        rol: NATURALEZA_AFECTADA_DIRECTA_ROL[o.naturaleza],
        tag: NATURALEZA_AFECTADA_DIRECTA_TAG[o.naturaleza],
      })),
      afectadasIndirectas: afectadas.indirectas.map((o) => ({
        id: o.organizacionId,
        nombre: o.nombre,
        siglas: o.siglas,
        esPartido: o.tipo === 'partido_politico',
        labelCorto: o.siglas ?? o.nombre,
      })),
      ultimo_hito: ultimo
        ? { fecha: ultimo.fecha, titulo: ultimo.titulo }
        : null,
    };
  })
  // Orden por defecto: último hito ↓ (más reciente primero). Los casos sin
  // hitos quedan al final.
  .sort((a, b) => {
    const fa = a.ultimo_hito?.fecha ?? '';
    const fb = b.ultimo_hito?.fecha ?? '';
    return fb.localeCompare(fa);
  });

// Texto plano para la búsqueda client-side. Agrupamos en un único campo
// data-search lower-case con todo lo indexable, evitando JS pesado en el
// cliente.
function buildSearchBlob(c: (typeof casos)[number]): string {
  return [
    c.mediatico,
    c.oficial,
    c.descripcion,
    c.organo,
    c.organoFull,
    c.numero,
  ]
    .filter(Boolean)
    .join(' ')
    .toLowerCase();
}

// Conjunto único de orgIds que aparecen como afectadas (directa O indirecta)
// en algún caso del listado. Sólo estas alimentan el multi-select del filtro
// — la decisión editorial es no engordar el desplegable con organizaciones
// del repo que nunca aparecen como afectadas en ningún caso visible.
const orgIdsPresentes = new Set<string>();
for (const c of casos) for (const id of c.orgIdsAfectadas) orgIdsPresentes.add(id);

const opcionesOrgsAfectadas = Array.from(orgIdsPresentes)
  .map((id) => {
    const o = orgIndex.get(id);
    if (!o) return null;
    return {
      value: id,
      label: o.nombre,
      sublabel: o.siglas && o.siglas !== o.nombre ? o.siglas : undefined,
    };
  })
  .filter((x): x is { value: string; label: string; sublabel?: string } => x !== null)
  .sort((a, b) => a.label.localeCompare(b.label, 'es'));

// Lista única de estados de elaboración de ficha que aparecen en el listado
// (los 7 valores legales no aparecen todos en producción). Mantener el orden
// canónico de LEYENDA_ESTADOS para que el dropdown siga una progresión
// editorial (pendiente → publicado → retirado), no alfabética.
const estadosPresentes = new Set(casos.map((c) => c.estado_publicacion));
const opcionesEstadoFicha = LEYENDA_ESTADOS
  .filter(({ estado }) => estadosPresentes.has(estado))
  .map(({ estado }) => ({
    value: estado,
    label: estadoLabel(estado),
  }));

function estadoLabel(e: EstadoPublicacion): string {
  switch (e) {
    case 'pendiente': return 'Pendiente';
    case 'borrador': return 'Borrador';
    case 'beta_publica': return 'Beta pública';
    case 'en_revision': return 'En revisión';
    case 'publicado': return 'Publicado';
    case 'retirado_temporalmente': return 'Retirada temporalmente';
    case 'retirado_definitivamente': return 'Retirada definitivamente';
    default: return e;
  }
}

// Mini-descripción: primer párrafo de descripcion_corta, recortado para
// caber a una/dos líneas en la celda. No corta a media palabra.
function miniDescripcion(raw: string, max = 140): string {
  const flat = raw.replace(/\s+/g, ' ').trim();
  if (!flat) return '';
  if (flat.length <= max) return flat;
  const slice = flat.slice(0, max);
  const lastSpace = slice.lastIndexOf(' ');
  return (lastSpace > 60 ? slice.slice(0, lastSpace) : slice).trim() + '…';
}
---

<BaseLayout
  title={strings.title}
  lang={lang}
  description={strings.description}
  activeNav="casos"
  breadcrumb={[
    { label: 'Inicio', href: lang === 'ca' ? '/cat' : '/' },
    { label: 'Casos' },
  ]}
>
  <section class="page-id">
    <div>
      <p class="page-id__eyebrow">{strings.eyebrow}</p>
      <h1 class="page-id__title">{strings.title}</h1>
      <p class="page-id__sub">{strings.sub}</p>
    </div>
    <div class="page-id__meta">
      <span>Total: <span data-total>{casos.length}</span></span>
      <span>·</span>
      <span>Mostrando: <span data-shown>{casos.length}</span></span>
    </div>
  </section>

  <CatalogoLeyenda
    titulo="Cómo leer este catálogo"
    resumen="Estado de elaboración de la ficha, columnas y filtros disponibles."
    ariaLabel="Leyenda del catálogo de casos"
  >
    <section class="cat-legend__section">
      <h3 class="cat-legend__section-title">{strings.leyendaEstadosTitulo}</h3>
      <p class="cat-legend__intro">{strings.leyendaEstadosIntro}</p>
      <ul class="cat-legend__list">
        {LEYENDA_ESTADOS.map(({ estado, nota }) => (
          <li class="cat-legend__item">
            <EstadoPublicacionBadge estado={estado} compact />
            <span class="cat-legend__desc">{nota}</span>
          </li>
        ))}
      </ul>
    </section>
    <section class="cat-legend__section">
      <h3 class="cat-legend__section-title">Filtros y ordenación</h3>
      <p class="cat-legend__inline">
        Puedes <strong>buscar</strong> por nombre del caso, organización o número de procedimiento;
        filtrar por <strong>fase procesal</strong> (instrucción → archivado), por
        <strong>estado de elaboración de la ficha</strong> y por
        <strong>organizaciones afectadas</strong> (directa o indirecta — sólo aparecen las que
        realmente figuran en algún caso del listado). El selector de orden cubre
        <strong>último hito</strong>, <strong>última actualización de la ficha</strong>,
        <strong>fase procesal</strong> (ascendente o descendente) e <strong>implicados</strong>.
      </p>
    </section>
    <section class="cat-legend__section">
      <h3 class="cat-legend__section-title">Más detalle metodológico</h3>
      <p class="cat-legend__inline">
        Los criterios editoriales aplicados a este catálogo están en
        <a href="/sobre#principios">/sobre — Principios editoriales</a>; cómo se respaldan los
        hechos de cada caso, en <a href="/sobre#niveles">/sobre — Niveles de fuente (N1–N4)</a>.
      </p>
    </section>
  </CatalogoLeyenda>

  <SectionH num="1.1" title="Filtros">
    <button
      type="reset"
      form="filters-casos"
      class="sec-h__action"
      aria-label="Limpiar filtros del catálogo"
    >
      Limpiar filtros
    </button>
  </SectionH>

  <form
    id="filters-casos"
    class="filter-bar filter-bar--wide"
    method="get"
    role="search"
    aria-label="Filtrar catálogo"
    data-catalog-filters
  >
    <div class="field">
      <label for="q">Buscar</label>
      <input id="q" name="q" type="search" placeholder="Caso, organización, número de procedimiento…" autocomplete="off" />
    </div>
    <div class="field">
      <label for="phase">Fase procesal</label>
      <CustomSelect
        id="phase"
        name="phase"
        value="all"
        ariaLabel="Filtrar por fase procesal"
        options={[
          { value: 'all',        label: 'Todas' },
          { value: 'instr',      label: 'Instrucción' },
          { value: 'intermedia', label: 'Fase intermedia' },
          { value: 'juicio',     label: 'Juicio oral' },
          { value: 'firme',      label: 'Sentencia firme' },
          { value: 'archivo',    label: 'Archivado' },
        ]}
      />
    </div>
    <div class="field">
      <label for="estado">Estado de la ficha</label>
      <CustomSelect
        id="estado"
        name="estado"
        value="all"
        ariaLabel="Filtrar por estado de elaboración de la ficha"
        options={[
          { value: 'all', label: 'Todos' },
          ...opcionesEstadoFicha,
        ]}
      />
    </div>
    <div class="field field--wide">
      <label for="orgs">Organizaciones afectadas</label>
      <MultiSelectFilter
        id="orgs"
        name="orgs"
        options={opcionesOrgsAfectadas}
        placeholder="Todas"
        ariaLabel="Filtrar por organización afectada (directa o indirecta)"
        searchPlaceholder="Buscar organización…"
      />
    </div>
    <div class="field">
      <label for="order">Ordenar por</label>
      <CustomSelect
        id="order"
        name="order"
        value="hito"
        ariaLabel="Ordenar listado"
        options={[
          { value: 'hito',           label: 'Último hito ↓' },
          { value: 'actualizado',    label: 'Última actualización ↓' },
          { value: 'fase_asc',       label: 'Fase ↑ (instrucción → archivo)' },
          { value: 'fase_desc',      label: 'Fase ↓ (archivo → instrucción)' },
          { value: 'implicados',     label: 'Implicados ↓' },
        ]}
      />
    </div>
  </form>

  <header class="sec-h">
    <span class="num">1.2</span>
    <h2>Listado</h2>
    <span class="right" data-listado-meta>
      {casos.length} caso{casos.length === 1 ? '' : 's'} · orden: último hito
    </span>
  </header>

  <div class="tbl-caption">
    <span>Tabla 1 · Catálogo de casos</span>
    <span>Última actualización del listado: 2026-05-21</span>
  </div>

  <div class="tbl-scroll">
  <table class="tbl" data-catalog>
    <thead>
      <tr>
        <th style="width: 28%;">Caso</th>
        <th style="width: 10%;">Fase</th>
        <th style="width: 14%;">Órgano</th>
        <th style="width: 28%;">Organizaciones afectadas</th>
        <th style="width: 20%;">Último hito</th>
      </tr>
    </thead>
    <tbody>
      {casos.map((c) => (
        <tr
          class:list={['is-link', c.bloqueadoEnProd && 'is-blocked']}
          data-row
          data-phase={c.phaseKind}
          data-phase-order={c.phaseOrder}
          data-implicados={c.implicados}
          data-fecha={c.ultimo_hito?.fecha ?? ''}
          data-actualizado={c.actualizado ?? ''}
          data-orgs={c.orgIdsAfectadas.join(',')}
          data-search={buildSearchBlob(c)}
          data-estado={c.estado_publicacion}
        >
          <td>
            {c.bloqueadoEnProd ? (
              <span aria-disabled="true" class="c-blocked">
                <span class="c-name-row">
                  <span class="c-name">{c.mediatico}</span>
                  <EstadoPublicacionBadge estado={c.estado_publicacion} compact />
                </span>
                {c.descripcion && (
                  <span class="c-desc">{miniDescripcion(c.descripcion)}</span>
                )}
              </span>
            ) : (
              <a href={`/casos/${c.slug}`}>
                <span class="c-name-row">
                  <span class="c-name">{c.mediatico}</span>
                  <EstadoPublicacionBadge estado={c.estado_publicacion} compact />
                </span>
                {c.descripcion && (
                  <span class="c-desc">{miniDescripcion(c.descripcion)}</span>
                )}
              </a>
            )}
          </td>
          <td>
            <PhaseBadge fase={c.fase_actual} />
          </td>
          <td>
            <div class="c-organo">
              <a class="c-organo__short c-mono" title={c.organoFull} href={`/organizaciones/${c.organoId}`}>{c.organo}</a>
              <span class="c-organo__full">{c.oficial}</span>
            </div>
          </td>
          <td>
            {(c.afectadasDirectas.length + c.afectadasIndirectas.length) === 0 ? (
              <span class="muted">—</span>
            ) : (
              <div class="c-afectadas">
                {c.afectadasDirectas.length > 0 && (
                  <div class="c-afectadas__grupo">
                    <span class="c-afectadas__nivel">Directa</span>
                    <ul class="c-afectadas__lista">
                      {c.afectadasDirectas.map((o) => (
                        <li class="c-afectadas__item">
                          <a href={`/organizaciones/${o.id}`}>{o.nombre}</a>
                          {o.rol && <RolBadge rol={o.rol} label={rolLabel(o.rol)} />}
                          {o.tag && <span class="c-afectadas__tag">{o.tag}</span>}
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
                {c.afectadasIndirectas.length > 0 && (
                  <div class="c-afectadas__grupo">
                    <span class="c-afectadas__nivel">Indirecta</span>
                    <ul class="c-afectadas__lista">
                      {c.afectadasIndirectas.map((o) => (
                        <li class="c-afectadas__item">
                          {o.esPartido ? (
                            <PartidoBadge id={o.id} label={o.labelCorto} href={`/organizaciones/${o.id}`} size="sm" />
                          ) : (
                            <a href={`/organizaciones/${o.id}`}>{o.nombre}</a>
                          )}
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            )}
          </td>
          <td>
            {c.ultimo_hito ? (
              <>
                <div class="c-date">{c.ultimo_hito.fecha}</div>
                <div class="c-hito-title" title={c.ultimo_hito.titulo}>{truncarHito(c.ultimo_hito.titulo)}</div>
              </>
            ) : (
              <span class="muted">Sin hitos registrados</span>
            )}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
  </div>

  <p class="empty-state" data-empty hidden>
    Sin resultados para los filtros actuales.
  </p>
</BaseLayout>

<script is:inline>
  (() => {
    const form = document.querySelector('[data-catalog-filters]');
    const table = document.querySelector('[data-catalog]');
    if (!form || !table) return;

    const rows = Array.from(table.querySelectorAll('[data-row]'));
    const tbody = table.querySelector('tbody');
    const shown = document.querySelector('[data-shown]');
    const empty = document.querySelector('[data-empty]');
    const meta = document.querySelector('[data-listado-meta]');

    const qInput = form.querySelector('#q');
    // Los selects ahora son <CustomSelect> y <MultiSelectFilter> que guardan
    // su valor en un <input type="hidden"> propio; los leemos por name del
    // formulario. El multi-select serializa CSV de orgIds.
    const phaseSel = form.querySelector('input[name="phase"]');
    const estadoSel = form.querySelector('input[name="estado"]');
    const orgsSel = form.querySelector('input[name="orgs"]');
    const orderSel = form.querySelector('input[name="order"]');

    const ORDER_LABEL = {
      hito: 'último hito',
      actualizado: 'última actualización',
      fase_asc: 'fase ascendente',
      fase_desc: 'fase descendente',
      implicados: 'implicados',
    };

    function selectedOrgIds() {
      return (orgsSel?.value || '').split(',').filter(Boolean);
    }

    function rowOrgs(row) {
      const raw = row.dataset.orgs || '';
      return raw ? raw.split(',') : [];
    }

    function apply() {
      const q = (qInput.value || '').trim().toLowerCase();
      const phase = phaseSel.value;
      const estado = estadoSel ? estadoSel.value : 'all';
      const order = orderSel.value;
      const orgs = selectedOrgIds();

      const visible = [];
      for (const row of rows) {
        const blob = row.dataset.search || '';
        const rowPhase = row.dataset.phase || '';
        const rowEstado = row.dataset.estado || '';
        const matchQ = !q || blob.includes(q);
        const matchPhase = phase === 'all' || rowPhase === phase;
        const matchEstado = estado === 'all' || rowEstado === estado;
        // Multi-select de orgs: si no hay selección, no filtra. Si hay,
        // semántica OR: el caso pasa si toca al menos una org seleccionada.
        let matchOrgs = true;
        if (orgs.length > 0) {
          const rowSet = rowOrgs(row);
          matchOrgs = orgs.some((id) => rowSet.includes(id));
        }
        const show = matchQ && matchPhase && matchEstado && matchOrgs;
        row.hidden = !show;
        if (show) visible.push(row);
      }

      visible.sort((a, b) => {
        if (order === 'implicados') {
          const ia = parseInt(a.dataset.implicados || '0', 10);
          const ib = parseInt(b.dataset.implicados || '0', 10);
          if (ib !== ia) return ib - ia;
          // tie-break por último hito ↓
          return (b.dataset.fecha || '').localeCompare(a.dataset.fecha || '');
        }
        if (order === 'actualizado') {
          const aa = a.dataset.actualizado || '';
          const ab = b.dataset.actualizado || '';
          // Casos sin fecha de actualización al final
          if (!aa && !ab) return 0;
          if (!aa) return 1;
          if (!ab) return -1;
          return ab.localeCompare(aa);
        }
        if (order === 'fase_asc' || order === 'fase_desc') {
          const pa = parseInt(a.dataset.phaseOrder || '9', 10);
          const pb = parseInt(b.dataset.phaseOrder || '9', 10);
          if (pa !== pb) return order === 'fase_asc' ? pa - pb : pb - pa;
          return (b.dataset.fecha || '').localeCompare(a.dataset.fecha || '');
        }
        // hito (default)
        return (b.dataset.fecha || '').localeCompare(a.dataset.fecha || '');
      });
      for (const row of visible) tbody.appendChild(row);

      if (shown) shown.textContent = String(visible.length);
      if (empty) empty.hidden = visible.length !== 0;
      if (meta) {
        const word = visible.length === 1 ? 'caso' : 'casos';
        meta.textContent = `${visible.length} ${word} · orden: ${ORDER_LABEL[order] || 'último hito'}`;
      }
    }

    function resyncCustomSelects() {
      // Tras un form.reset() los <input type="hidden"> recuperan su
      // value="..." inicial, pero el label visible del trigger del
      // CustomSelect no se entera. Recorremos cada CSel del form y
      // resincronizamos su label al option cuyo data-value coincida con
      // el hidden actual.
      form.querySelectorAll('[data-csel]').forEach((csel) => {
        const hidden = csel.querySelector('[data-csel-value]');
        const label = csel.querySelector('[data-csel-label]');
        if (!hidden || !label) return;
        const opt = csel.querySelector(`[data-csel-opt][data-value="${hidden.value}"]`);
        if (opt) {
          label.textContent = opt.textContent.trim();
          csel.querySelectorAll('[data-csel-opt]').forEach((o) => {
            o.setAttribute('aria-selected', o === opt ? 'true' : 'false');
          });
        }
      });
    }

    form.addEventListener('input', apply);
    form.addEventListener('change', apply);
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      apply();
    });
    form.addEventListener('reset', () => {
      setTimeout(() => { resyncCustomSelects(); apply(); }, 0);
    });
  })();
</script>

