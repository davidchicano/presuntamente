---
// PgPersonas — listado tabular de Personas con rol en algún caso.
// Filtros client-side: búsqueda + figura pública. Misma estética
// administrativa que PgCasos.

import BaseLayout from '@/layouts/BaseLayout.astro';
import CustomSelect from '@/components/CustomSelect.astro';
import MultiSelectFilter from '@/components/MultiSelectFilter.astro';
import CatalogoLeyenda from '@/components/CatalogoLeyenda.astro';
import SectionH from '@/components/SectionH.astro';
import OrgChip from '@/components/OrgChip.astro';
import RolBadge from '@/components/RolBadge.astro';
import HoverCard from '@/components/HoverCard.astro';
import { getCollection } from 'astro:content';
import { rolLabel, rolGrupo, type Lang } from '@/lib/labels';
import {
  toImporteEntries,
  analizarSujeto,
  importeAtribuidoSujeto,
  type HechoImporteInput,
} from '@/lib/importe';
import { formatEurosCompact, formatEurosFull } from '@/lib/money';

interface Props { lang?: Lang; }
const { lang = 'es' } = Astro.props;

const [personasCol, rolesCol, vinculosCol, organizacionesCol, casosCol, delitosCol, hechosCol] = await Promise.all([
  getCollection('personas'),
  getCollection('roles'),
  getCollection('vinculos'),
  getCollection('organizaciones'),
  getCollection('casos'),
  getCollection('delitos'),
  getCollection('hechos'),
]);

// Importe presuntamente atribuido por persona (cubetas beneficiario + activo,
// clase objeto), misma semántica que el "Importe atribuido" de /casos. No
// incluye el perjuicio sufrido (víctimas) ni las consecuencias económicas.
const importeEntries = toImporteEntries(
  hechosCol.map((h) => h.data as unknown as HechoImporteInput),
);
function importeAtribuidoDe(sujeto: string): number {
  return importeAtribuidoSujeto(analizarSujeto(importeEntries, sujeto));
}

const orgIdx = new Map(organizacionesCol.map((o) => [o.data.id, o.data]));
const casoIdx = new Map(casosCol.map((c) => [c.data.id, c.data]));
const delitoIdx = new Map(delitosCol.map((d) => [d.data.id, d.data]));

// Naturalezas de vínculo que implican "cargo / vinculación a una organización"
// y se pueden usar como derivación de "Relación principal con organización".
const NATURALEZAS_CARGO = new Set([
  'cargo_publico_electo',
  'cargo_publico_designado',
  'cargo_judicial',
  'cargo_organico_partido',
  'cargo_directivo_empresa_publica',
  'cargo_directivo_organizacion_privada',
  'cargo_academico_publico',
  'cargo_organizacion_civica',
]);

// Mini-descripción: aplana, recorta a ~110 caracteres sin cortar palabra.
function miniDescPersona(raw: string | undefined, max = 110): string {
  if (!raw) return '';
  const flat = raw.replace(/\s+/g, ' ').trim();
  if (flat.length <= max) return flat;
  const slice = flat.slice(0, max);
  const lastSpace = slice.lastIndexOf(' ');
  return (lastSpace > 50 ? slice.slice(0, lastSpace) : slice).trim() + '…';
}

const personas = personasCol
  .map((p) => {
    const rolesPersona = rolesCol.filter(
      (r) => r.data.sujeto_tipo === 'persona' && r.data.sujeto_persona_id === p.data.id,
    );
    const roles = rolesPersona.map((r) => r.data);
    const activos = roles.filter((r) => !r.fecha_fin);
    const referencia = activos.length > 0
      ? (activos.find((r) => rolGrupo(r.rol) === 'condenado')
        ?? activos.find((r) => rolGrupo(r.rol) === 'imputacion_activa')
        ?? activos.find((r) => rolGrupo(r.rol) === 'funcional')
        ?? activos[0])
      : roles[roles.length - 1];
    const casosUnicos = new Set(roles.map((r) => r.caso_id));
    const delitosUnicos = new Set(roles.flatMap((r) => r.delitos_atribuidos ?? []));
    const casosPersona = Array.from(casosUnicos)
      .flatMap((casoId) => {
        const caso = casoIdx.get(casoId);
        if (!caso) return [];
        const rolesCaso = roles
          .filter((r) => r.caso_id === casoId)
          .sort((a, b) => {
            const aActivo = a.fecha_fin ? 0 : 1;
            const bActivo = b.fecha_fin ? 0 : 1;
            if (aActivo !== bActivo) return bActivo - aActivo;
            return (b.fecha_inicio ?? '').localeCompare(a.fecha_inicio ?? '');
          });
        return [{
          id: casoId,
          nombre: caso.nombre_mediatico,
          roles: rolesCaso.map((r) => ({ rol: r.rol, label: rolLabel(r.rol) })),
        }];
      })
      .sort((a, b) => a.nombre.localeCompare(b.nombre, 'es'));

    // Vínculo de cargo más reciente que apunte a una organización.
    // Si está vigente y tiene `desde` posterior, se elige por encima de
    // vínculos cerrados. Permite mostrar la org de la persona en la tabla.
    const vinculosCargo = vinculosCol
      .filter((v) =>
        v.data.sujeto_persona_id === p.data.id &&
        v.data.objeto_organizacion_id &&
        NATURALEZAS_CARGO.has(v.data.naturaleza) &&
        v.data.estado_publicacion !== 'retirado_definitivamente',
      )
      .sort((a, b) => {
        // Vigentes primero, luego por desde descendiente.
        const aV = a.data.vigente ? 1 : 0;
        const bV = b.data.vigente ? 1 : 0;
        if (aV !== bV) return bV - aV;
        return (b.data.desde ?? '').localeCompare(a.data.desde ?? '');
      });
    const vincRef = vinculosCargo[0]?.data;
    const orgRefId = vincRef?.objeto_organizacion_id;
    const orgRef = orgRefId ? orgIdx.get(orgRefId) : undefined;

    return {
      slug: p.data.id,
      nombre: p.data.nombre_completo,
      cargo: p.data.cargo_publico_actual,
      biografia: miniDescPersona(p.data.biografia_corta),
      esFigura: p.data.es_figura_publica,
      rolPrincipal: referencia ? { rol: referencia.rol, label: rolLabel(referencia.rol) } : null,
      casosCount: casosUnicos.size,
      casoIds: Array.from(casosUnicos),
      delitoIds: Array.from(delitosUnicos),
      casosPersona,
      orgRefId,
      orgRefNombre: orgRef?.nombre,
      orgRefEsPartido: orgRef?.tipo === 'partido_politico',
      importeAtribuido: importeAtribuidoDe(p.data.id),
    };
  })
  .sort((a, b) => a.nombre.localeCompare(b.nombre, 'es'));

const casoIdsPresentes = new Set(personas.flatMap((p) => p.casoIds));
const opcionesCasos = Array.from(casoIdsPresentes)
  .flatMap((id) => {
    const c = casoIdx.get(id);
    return c ? [{ value: id, label: c.nombre_mediatico }] : [];
  })
  .sort((a, b) => a.label.localeCompare(b.label, 'es'));

const delitoIdsPresentes = new Set(personas.flatMap((p) => p.delitoIds));
const opcionesDelitos = Array.from(delitoIdsPresentes)
  .flatMap((id) => {
    const d = delitoIdx.get(id);
    return d ? [{ value: id, label: d.nombre_tipico }] : [];
  })
  .sort((a, b) => a.label.localeCompare(b.label, 'es'));

const strings = {
  title: 'Personas implicadas',
  description:
    'Listado de personas con rol formal en algún procedimiento registrado en el sistema.',
  eyebrow: 'Sección 2 · Personas',
  sub:
    'Personas físicas que aparecen con rol procesal (investigado, procesado, condenado, ' +
    'absuelto, desimputado, testigo, denunciante, juez, fiscal…) en alguno de los casos del ' +
    'inventario. No se incluyen personas privadas sin rol formal.',
};

function searchBlob(p: (typeof personas)[number]): string {
  return [
    p.nombre,
    p.cargo,
    p.rolPrincipal?.label,
    p.biografia,
    p.orgRefNombre,
    ...p.casosPersona.map((c) => c.nombre),
    ...p.delitoIds.map((id) => delitoIdx.get(id)?.nombre_tipico),
  ]
    .filter(Boolean)
    .join(' ')
    .toLowerCase();
}
---

<BaseLayout
  title={strings.title}
  lang={lang}
  description={strings.description}
  activeNav="personas"
  breadcrumb={[
    { label: 'Inicio', href: lang === 'ca' ? '/cat' : '/' },
    { label: 'Personas' },
  ]}
>
  <section class="page-id">
    <div>
      <p class="page-id__eyebrow">{strings.eyebrow}</p>
      <h1 class="page-id__title">{strings.title}</h1>
      <p class="page-id__sub">{strings.sub}</p>
    </div>
    <div class="page-id__meta">
      <span>Total: <span data-total>{personas.length}</span></span>
      <span>·</span>
      <span>Mostrando: <span data-shown>{personas.length}</span></span>
    </div>
  </section>

  <CatalogoLeyenda
    titulo="Cómo leer este catálogo"
    resumen="Rol procesal principal, figura pública y filtros disponibles."
    ariaLabel="Leyenda del catálogo de personas"
  >
    <section class="cat-legend__section">
      <h3 class="cat-legend__section-title">Rol procesal principal</h3>
      <p class="cat-legend__intro">
        Rol procesal vigente más relevante para esta persona en cualquiera de los procedimientos
        del inventario. Si tiene varios roles activos, se prioriza condenado &gt; imputación
        activa (investigado, procesado, acusado) &gt; rol funcional (juez, fiscal, testigo).
        Cuando todos los roles han cerrado, se muestra el último histórico.
      </p>
      <ul class="cat-legend__list">
        <li class="cat-legend__item">
          <RolBadge rol="investigado" label="Investigado" />
          <span class="cat-legend__desc">Procedimiento abierto en fase de instrucción.</span>
        </li>
        <li class="cat-legend__item">
          <RolBadge rol="procesado" label="Procesado" />
          <span class="cat-legend__desc">Auto de procesamiento dictado.</span>
        </li>
        <li class="cat-legend__item">
          <RolBadge rol="acusado" label="Acusado" />
          <span class="cat-legend__desc">Escrito de acusación formulado.</span>
        </li>
        <li class="cat-legend__item">
          <RolBadge rol="condenado_firme" label="Condenado" />
          <span class="cat-legend__desc">Sentencia condenatoria (firme o no).</span>
        </li>
        <li class="cat-legend__item">
          <RolBadge rol="absuelto" label="Absuelto" />
          <span class="cat-legend__desc">Sentencia absolutoria.</span>
        </li>
        <li class="cat-legend__item">
          <RolBadge rol="desimputado" label="Desimputado" />
          <span class="cat-legend__desc">Apartado de la causa antes de juicio.</span>
        </li>
      </ul>
    </section>
    <section class="cat-legend__section">
      <h3 class="cat-legend__section-title">Filtros y ordenación</h3>
      <p class="cat-legend__inline">
        Puedes <strong>buscar</strong> por nombre, cargo, caso o rol; filtrar por
        <strong>causa</strong>, por <strong>delito atribuido</strong> y por
        <strong>figura pública</strong> (cargo público, mediático o relevancia institucional).
        El selector de orden cubre
        <strong>alfabético</strong> y <strong>número de casos</strong> en los que la persona aparece.
      </p>
    </section>
    <section class="cat-legend__section">
      <h3 class="cat-legend__section-title">Presunción de inocencia</h3>
      <p class="cat-legend__inline">
        Que una persona figure aquí no implica culpabilidad. El rol procesal es un estado
        formal del procedimiento, no una valoración. La presunción de inocencia se mantiene
        mientras no exista sentencia firme.
      </p>
    </section>
    <section class="cat-legend__section">
      <h3 class="cat-legend__section-title">Más detalle metodológico</h3>
      <p class="cat-legend__inline">
        La taxonomía completa de roles (acusado, instructor, parte civil, función judicial…)
        está en <a href="/sobre#roles">/sobre — Roles procesales</a>; los criterios editoriales
        generales, en <a href="/sobre#principios">/sobre — Principios editoriales</a>.
      </p>
    </section>
  </CatalogoLeyenda>

  <SectionH num="2.1" title="Filtros">
    <button
      type="reset"
      form="filters-personas"
      class="sec-h__action"
      aria-label="Limpiar filtros de personas"
    >
      Limpiar filtros
    </button>
  </SectionH>

  <form id="filters-personas" class="filter-bar" method="get" role="search" aria-label="Filtrar personas" data-personas-filters>
    <div class="field">
      <label for="q">Buscar</label>
      <input id="q" name="q" type="search" placeholder="Nombre, cargo, rol…" autocomplete="off" />
    </div>
    <div class="field field--wide">
      <label for="caso">Causa</label>
      <MultiSelectFilter
        id="caso"
        name="caso"
        options={opcionesCasos}
        placeholder="Todas"
        ariaLabel="Filtrar por causa o caso"
        searchPlaceholder="Buscar caso…"
      />
    </div>
    <div class="field field--wide">
      <label for="delito">Delito atribuido</label>
      <MultiSelectFilter
        id="delito"
        name="delito"
        options={opcionesDelitos}
        placeholder="Todos"
        ariaLabel="Filtrar por delito atribuido en la causa"
        searchPlaceholder="Buscar delito…"
      />
    </div>
    <div class="field">
      <label for="figura">Figura pública</label>
      <CustomSelect
        id="figura"
        name="figura"
        value="all"
        ariaLabel="Filtrar por condición de figura pública"
        options={[
          { value: 'all',     label: 'Todas' },
          { value: 'publica', label: 'Sí, figura pública' },
          { value: 'privada', label: 'No, persona privada' },
        ]}
      />
    </div>
    <div class="field">
      <label for="importe">Importe atribuido</label>
      <CustomSelect
        id="importe"
        name="importe"
        value="all"
        ariaLabel="Filtrar por importe presuntamente atribuido"
        options={[
          { value: 'all', label: 'Cualquiera' },
          { value: 'con', label: 'Con importe atribuido' },
          { value: 'm1',  label: '≥ 1 M€' },
          { value: 'm10', label: '≥ 10 M€' },
        ]}
      />
    </div>
    <div class="field">
      <label for="order">Ordenar por</label>
      <CustomSelect
        id="order"
        name="order"
        value="alfabetico"
        ariaLabel="Ordenar listado"
        options={[
          { value: 'alfabetico', label: 'Alfabético' },
          { value: 'casos',      label: 'Nº de casos ↓' },
          { value: 'importe',    label: 'Importe atribuido ↓' },
        ]}
      />
    </div>
  </form>

  <header class="sec-h">
    <span class="num">2.2</span>
    <h2>Listado</h2>
    <span class="right" data-listado-meta>orden: alfabético</span>
  </header>

  <div class="tbl-scroll">
  <table class="tbl" data-personas>
    <thead>
      <tr>
        <th style="width: 28%;">Persona</th>
        <th style="width: 18%;">Organización principal</th>
        <th style="width: 18%;">Cargo actual</th>
        <th style="width: 36%;">Casos y rol procesal</th>
      </tr>
    </thead>
    <tbody>
      {personas.map((p) => (
        <tr
          class="is-link"
          data-row
          data-figura={p.esFigura ? 'publica' : 'privada'}
          data-casos={p.casosCount}
          data-caso-ids={p.casoIds.join(',')}
          data-delito-ids={p.delitoIds.join(',')}
          data-importe={p.importeAtribuido}
          data-search={searchBlob(p)}
        >
          <td>
            <a href={`/personas/${p.slug}`}>
              <span class="c-name-row">
                <span class="c-name">{p.nombre}</span>
                <span class="c-figura">
                  {p.esFigura ? 'figura pública' : 'persona privada'}
                </span>
              </span>
              {p.biografia && (
                <span class="c-desc">{p.biografia}</span>
              )}
            </a>
            {p.importeAtribuido > 0 && (
              <HoverCard side="top" align="start">
                <span slot="trigger" class="c-importe">
                  <span class="c-importe__label">Importe atribuido</span>
                  <span class="c-importe__value">{formatEurosCompact(p.importeAtribuido)}</span>
                </span>
                <div slot="content">
                  <strong>{formatEurosFull(p.importeAtribuido)}</strong> — dinero presuntamente
                  atribuido a su conducta (presunto beneficiario o conducta investigada) en los
                  hechos donde aparece. No incluye el perjuicio sufrido por terceros ni las multas;
                  el detalle por papel está en su ficha.
                </div>
              </HoverCard>
            )}
          </td>
          <td>
            {p.orgRefId && p.orgRefNombre ? (
              <OrgChip
                id={p.orgRefId}
                label={p.orgRefNombre}
                href={`/organizaciones/${p.orgRefId}`}
                esPartido={p.orgRefEsPartido}
              />
            ) : (
              <span class="muted">—</span>
            )}
          </td>
          <td class="c-mono">{p.cargo ?? '—'}</td>
          <td>
            {p.casosPersona.length > 0 ? (
              <ul class="c-cases-list">
                {p.casosPersona.map((caso) => (
                  <li class="c-case-ref">
                    <a href={`/casos/${caso.id}`} class="c-case-ref__name">{caso.nombre}</a>
                    <span class="c-case-ref__roles">
                      {caso.roles.map((r) => (
                        <RolBadge rol={r.rol} label={r.label} />
                      ))}
                    </span>
                  </li>
                ))}
              </ul>
            ) : (
              <span class="muted">—</span>
            )}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
  </div>

  <p class="empty-state" data-empty hidden>Sin resultados para los filtros actuales.</p>
</BaseLayout>

<script is:inline>
  (() => {
    const form = document.querySelector('[data-personas-filters]');
    const table = document.querySelector('[data-personas]');
    if (!form || !table) return;
    const rows = Array.from(table.querySelectorAll('[data-row]'));
    const tbody = table.querySelector('tbody');
    const shown = document.querySelector('[data-shown]');
    const empty = document.querySelector('[data-empty]');
    const meta = document.querySelector('[data-listado-meta]');
    const qInput = form.querySelector('#q');
    const figura = form.querySelector('input[name="figura"]');
    const casoSel = form.querySelector('input[name="caso"]');
    const delitoSel = form.querySelector('input[name="delito"]');
    const importeSel = form.querySelector('input[name="importe"]');
    const orderSel = form.querySelector('input[name="order"]');

    const ORDER_LABEL = {
      alfabetico: 'alfabético',
      casos: 'nº de casos',
      importe: 'importe atribuido',
    };
    const IMPORTE_MIN = { con: 1, m1: 1_000_000, m10: 10_000_000 };

    function resyncCustomSelects() {
      form.querySelectorAll('[data-csel]').forEach((csel) => {
        const hidden = csel.querySelector('[data-csel-value]');
        const label = csel.querySelector('[data-csel-label]');
        if (!hidden || !label) return;
        const opt = csel.querySelector(`[data-csel-opt][data-value="${hidden.value}"]`);
        if (opt) {
          label.textContent = opt.textContent.trim();
          csel.querySelectorAll('[data-csel-opt]').forEach((o) => o.setAttribute('aria-selected', o === opt ? 'true' : 'false'));
        }
      });
    }

    function apply() {
      const q = (qInput.value || '').trim().toLowerCase();
      const fig = figura.value;
      const casos = (casoSel?.value || '').split(',').filter(Boolean);
      const delitos = (delitoSel?.value || '').split(',').filter(Boolean);
      const importe = importeSel ? importeSel.value : 'all';
      const importeMin = IMPORTE_MIN[importe] ?? 0;
      const order = orderSel ? orderSel.value : 'alfabetico';

      const visible = [];
      for (const row of rows) {
        const matchQ = !q || (row.dataset.search || '').includes(q);
        const matchF = fig === 'all' || row.dataset.figura === fig;
        const rowCasos = (row.dataset.casoIds || '').split(',').filter(Boolean);
        const rowDelitos = (row.dataset.delitoIds || '').split(',').filter(Boolean);
        const matchCaso = casos.length === 0 || casos.some((id) => rowCasos.includes(id));
        const matchDelito = delitos.length === 0 || delitos.some((id) => rowDelitos.includes(id));
        const matchImporte = importeMin === 0 || parseFloat(row.dataset.importe || '0') >= importeMin;
        const show = matchQ && matchF && matchCaso && matchDelito && matchImporte;
        row.hidden = !show;
        if (show) visible.push(row);
      }

      if (tbody) {
        visible.sort((a, b) => {
          if (order === 'casos') {
            const ca = parseInt(a.dataset.casos || '0', 10);
            const cb = parseInt(b.dataset.casos || '0', 10);
            if (cb !== ca) return cb - ca;
          }
          if (order === 'importe') {
            const va = parseFloat(a.dataset.importe || '0');
            const vb = parseFloat(b.dataset.importe || '0');
            if (vb !== va) return vb - va;
          }
          // Tie-break y default: alfabético por la primera celda (nombre).
          const na = (a.querySelector('.c-name')?.textContent || '').trim();
          const nb = (b.querySelector('.c-name')?.textContent || '').trim();
          return na.localeCompare(nb, 'es');
        });
        for (const row of visible) tbody.appendChild(row);
      }

      if (shown) shown.textContent = String(visible.length);
      if (empty) empty.hidden = visible.length !== 0;
      if (meta) meta.textContent = `orden: ${ORDER_LABEL[order] || 'alfabético'}`;
    }
    form.addEventListener('input', apply);
    form.addEventListener('change', apply);
    form.addEventListener('submit', (e) => { e.preventDefault(); apply(); });
    form.addEventListener('reset', () => setTimeout(() => { resyncCustomSelects(); apply(); }, 0));
  })();
</script>

<style>
  .empty-state {
    border: 1px dashed var(--color-border-strong);
    background: var(--color-surface-muted);
    padding: var(--space-4);
    text-align: center;
    font: 400 var(--font-size-1)/1.5 var(--font-sans);
    color: var(--color-fg-muted);
  }
  .filter-bar {
    grid-template-columns: minmax(220px, 1.3fr) minmax(180px, 1fr) minmax(180px, 1fr) minmax(150px, 0.8fr) minmax(150px, 0.8fr) minmax(150px, 0.8fr);
  }
  .filter-bar .field--wide {
    min-width: 0;
  }
  /* Chip de importe atribuido bajo el nombre (HoverCard común). */
  .c-importe {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    margin-top: 6px;
    padding: 3px 8px;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    background: var(--color-surface-muted);
    width: max-content;
    max-width: 100%;
  }
  .c-importe__label {
    font: 500 0.66rem/1 var(--font-sans);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
  }
  .c-importe__value {
    font: 600 0.82rem/1 var(--font-mono);
    font-variant-numeric: tabular-nums;
    color: var(--color-fg);
  }
