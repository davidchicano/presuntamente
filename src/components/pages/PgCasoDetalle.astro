  /* Wrapper passthrough para filas filtrables de la ficha (hitos y hechos).
     `display: contents` hace que el wrapper no genere caja propia, así que
     el <Hito>/<Hecho> hereda el contexto de su padre (`.timeline` flex,
     `.grupo__cards` grid). Cuando el JS de filtrado pone `hidden`, la
     regla más específica `[hidden].row-pass` lo oculta de verdad — sin la
     segunda regla, `display: contents` ganaría a `[hidden]` por
     especificidad del style declarado en la clase. */
  .row-pass { display: contents; }
  [hidden].row-pass { display: none; }
</style>

<script is:inline>
  (() => {
    // Filtrado de §3 Personas (por rol procesal), §5 Cronología (por
    // familia de hito) y §6 Hechos (por estado epistémico). Cada
    // ChipFilterGroup expone un <input type="hidden" name="..."> que
    // emite 'change' al cambiar. Aquí leemos esos hidden y aplicamos
    // visibilidad a las filas correspondientes con semántica OR. Si no
    // hay nada seleccionado, todo visible (estado "todo activo").
    //
    // El atributo de cada fila se trata SIEMPRE como CSV: para hitos y
    // hechos lleva un único valor ("jurisdiccional", "acreditado"…) y
    // funciona como matching simple; para personas lleva varios
    // ("investigado,procesado") y funciona como matching por contención.
    function attach(name, rowSelector, dataAttr, groupSelector) {
      const input = document.querySelector(`input[name="${name}"]`);
      if (!input) return;
      const rows = document.querySelectorAll(rowSelector);
      const groups = groupSelector ? document.querySelectorAll(groupSelector) : null;
      if (rows.length === 0) return;

      function apply() {
        const sel = (input.value || '').split(',').filter(Boolean);
        rows.forEach((row) => {
          const itemKeys = (row.dataset[dataAttr] || '').split(',').filter(Boolean);
          row.hidden = sel.length > 0 && !sel.some((s) => itemKeys.includes(s));
        });
        // Si hay grupos, ocultar los que se queden sin hijos visibles.
        if (groups) {
          groups.forEach((g) => {
            const anyVisible = Array.from(g.querySelectorAll(rowSelector))
              .some((r) => !r.hidden);
            g.hidden = !anyVisible;
          });
        }
      }
      input.addEventListener('change', apply);
      apply();
    }

    function init() {
      attach('personas-rol',  '[data-persona-row]', 'roles',       '[data-personas-grupo]');
      attach('hitos-familia', '[data-hito-row]',    'tipoFamilia', null);
      attach('hechos-epi',    '[data-hecho-row]',   'tipoEpi',     '[data-hechos-grupo]');
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
      init();
    }
  })();
</script>
