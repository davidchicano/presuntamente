  /* === 2.1 Flip 3D de la masthead — la cabecera se voltea con un botón
     textual explícito, revelando el reverso editorial (estado global +
     10 chequeos + cómo se ha redactado). Perspective 3D real, no
     crossfade. La altura del wrapper se mide con JS porque las dos
     caras tienen contenido distinto. === */
  .ficha-flip {
    position: relative;
    margin-bottom: 24px;
    perspective: 2200px;
    perspective-origin: 50% 30%;
  }
  .ficha-flip[data-flipped='true'] + .ficha-sintesis {
    /* The summary uses a negative margin to sit close to the front face.
       The taller back face needs normal spacing so it does not look clipped. */
    margin-top: 0;
  }
  .ficha-flip__inner {
    position: relative;
    transform-style: preserve-3d;
    transition:
      transform 0.75s cubic-bezier(0.32, 0.04, 0.18, 1),
      min-height 0.45s cubic-bezier(0.2, 0.7, 0.2, 1);
    /* min-height la setea el JS al alto de la cara visible (no al máximo
       de ambas), para que no quede hueco bajo la cara A cuando es más
       corta que la B. La transición es algo más rápida que el flip
       para que la altura cuadre antes de terminar la rotación. */
  }
  .ficha-flip[data-flipped='true'] .ficha-flip__inner {
    transform: rotateY(180deg);
  }
  @media (prefers-reduced-motion: reduce) {
    .ficha-flip__inner { transition: none; }
  }

  .ficha-flip__face {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    /* La clase `.ficha-mast` hereda una animación global `fade-up` que
       define un `transform` en sus keyframes — con `animation-fill-mode:
       both` mantiene el valor final y machaca nuestro `rotateY(180deg)`
       del reverso. Desactivamos la animación dentro del flip. */
    animation: none;
    margin-bottom: 0;
  }
  .ficha-flip__face--front > .ficha-mast__top > :not(.ficha-mast__grid) {
    max-width: calc(100% - 168px);
  }
  .ficha-flip__face--front {
    position: relative;
    /* La cara A ocupa el flujo normal y define el tamaño del wrapper en
       SSR/primer paint, antes de que el JS mida y unifique alturas. */
  }
  .ficha-flip__face--back {
    position: absolute;
    top: 0;
    right: 0;
    bottom: auto;
    left: 0;
    transform: rotateY(180deg);
  }

  /* --- Estado editorial + botón discreto de detalles ------------------- */
  .ficha-flip__actions {
    position: absolute;
    top: 14px;
