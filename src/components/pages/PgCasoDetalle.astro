---
// PgCasoDetalle — ficha individual de un Caso.
// Sigue la arquitectura de doc 02, secciones "Arquitectura de la página" y
// "Detalle por sección" (encabezado, resumen, estado, personas, organizaciones,
// cronología, hechos por estado epistémico, biblioteca, cómo se redacta, pie).
// Toda la lectura se hace contra Content Collections; la página es estática.

import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import FichaTocSection from '@/components/FichaTocSection.astro';
import PhaseBadge from '@/components/PhaseBadge.astro';
import PersonaCard from '@/components/PersonaCard.astro';
import OrgCard from '@/components/OrgCard.astro';
import Hito from '@/components/Hito.astro';
import Hecho from '@/components/Hecho.astro';
import DocumentoCard from '@/components/DocumentoCard.astro';
import CoberturaMediaticaTable from '@/components/CoberturaMediaticaTable.astro';
import ClasificacionEditorialBarra from '@/components/ClasificacionEditorialBarra.astro';
import RichProse from '@/components/RichProse.astro';
import EstadoFichaBadge from '@/components/EstadoFichaBadge.astro';
import EstadoPublicacionBadge from '@/components/EstadoPublicacionBadge.astro';
import GraphConexionesLink from '@/components/GraphConexionesLink.astro';
import ChipFilterGroup from '@/components/ChipFilterGroup.astro';
import Chip from '@/components/Chip.astro';
import RolBadge from '@/components/RolBadge.astro';
import EpistemicBadge from '@/components/EpistemicBadge.astro';
import CategoryBadge from '@/components/CategoryBadge.astro';
import Aclaracion from '@/components/Aclaracion.astro';
import CifrasCasoBloque from '@/components/CifrasCasoBloque.astro';

// Mismo enum que en EstadoPublicacionBadge — Astro no exporta tipos entre
// componentes .astro de forma estable, así que re-declaro aquí.
type EstadoPublicacion =
  | 'pendiente'
  | 'borrador'
  | 'beta_publica'
  | 'en_revision'
  | 'publicado'
  | 'retirado_temporalmente'
  | 'retirado_definitivamente';
import {
  rolLabel,
  rolGrupo,
  tipoOrgLabel,
  tipoHitoLabel,
  tipoHitoFamilia,
  tipoDocLabel,
  naturalezaVinculoLabel,
  tipoPiezaMediaticaLabel,
  relevanciaEditorialLabel,
  faseLabel,
  origenLabel,
  iniciales,
  importeNaturalezaLabel,
  type Lang,
} from '@/lib/labels';
import { documentoRespaldoHref } from '@/lib/documentos';
import { formatFechaEs } from '@/lib/og';
import { toImporteEntries, analizarCaso, type HechoImporteInput } from '@/lib/importe';
import { formatEurosCompact } from '@/lib/money';

interface Props {
  lang?: Lang;
  caso: CollectionEntry<'casos'>;
}

const { lang = 'es', caso } = Astro.props;
const data = caso.data;
interface SintesisCaso {
  que_se_investiga: string;
  hechos_clave: string[];
  estado_actual: string;
  cifras_clave?: string[];
}
const sintesisCaso = (data as { sintesis_caso?: SintesisCaso }).sintesis_caso;

// --- Estado de la ficha (10 checks editoriales/técnicos sobre el trabajo de
// presuntamente.org en este caso; ver docs/web/features/estado-ficha-caso.md).
type ChequeoFicha = 'completo' | 'parcial' | 'pendiente' | 'no_aplica';
interface EstadoFicha {
  cronologia: ChequeoFicha;
  roles_procesales: ChequeoFicha;
  documentos_primarios: ChequeoFicha;
  hechos_modelados: ChequeoFicha;
  fuentes_cruzadas: ChequeoFicha;
  composicion_fuentes_citadas: ChequeoFicha;
  vinculos_institucionales: ChequeoFicha;
  conexiones: ChequeoFicha;
  cobertura_mediatica_general: ChequeoFicha;
  revision_editorial: ChequeoFicha;
  notas?: string;
  fecha_actualizacion?: string;
}
const estadoFicha = (data as { estado_ficha?: EstadoFicha }).estado_ficha;

// Orden estable de los 10 checks para render predecible. El orden refleja la
// prioridad editorial: primero lo que la ficha debería tener siempre
// (cronología, roles, primarios, hechos, fuentes), luego las cuatro features
// transversales del Bloque D que pueden faltar legítimamente, y por último
// la revisión editorial cualitativa de `/revisar-caso`.
const CHEQUEOS_FICHA: ReadonlyArray<readonly [keyof EstadoFicha, string]> = [
  ['cronologia', 'Cronología'],
  ['roles_procesales', 'Roles procesales'],
  ['documentos_primarios', 'Documentos primarios'],
  ['hechos_modelados', 'Hechos modelados'],
  ['fuentes_cruzadas', 'Fuentes periodísticas cruzadas'],
  ['composicion_fuentes_citadas', 'Composición de fuentes citadas'],
  ['vinculos_institucionales', 'Vínculos institucionales documentados'],
  ['conexiones', 'Conexiones y relaciones'],
  ['cobertura_mediatica_general', 'Cobertura mediática general'],
  ['revision_editorial', 'Revisión editorial cualitativa'],
] as const;

// --- Collections relacionadas ------------------------------------------------

const [
  hitosCol,
  hechosCol,
  rolesCol,
  personasCol,
  organizacionesCol,
  documentosCol,
  delitosCol,
  vinculosCol,
  coberturaMediaticaCol,
] =
  await Promise.all([
    getCollection('hitos'),
    getCollection('hechos'),
    getCollection('roles'),
    getCollection('personas'),
    getCollection('organizaciones'),
    getCollection('documentos'),
    getCollection('delitos'),
    getCollection('vinculos'),
    getCollection('coberturaMediatica'),
  ]);

const hitos = hitosCol
  .filter((h) => h.data.caso_id === data.id)
  .sort((a, b) => b.data.fecha.localeCompare(a.data.fecha));
// Mismo criterio que la API de datos abiertos (src/lib/api.ts; ver
// docs/api/decisiones.md D12): un Hecho retractado no se propaga. Excluye
// `estado_publicacion` retirado_* y `vigencia: retirado`. Los `vigencia:
// superado` SÍ se conservan (histórico corregido por un Hecho posterior vía
// `corregido_por`; principio "conserva el histórico" de AGENTS.md).
const hechos = hechosCol.filter((h) => {
  if (h.data.caso_id !== data.id) return false;
  const ep = (h.data as { estado_publicacion?: string }).estado_publicacion;
  if (ep === 'retirado_temporalmente' || ep === 'retirado_definitivamente') return false;
  if ((h.data as { vigencia?: string }).vigencia === 'retirado') return false;
  return true;
});
const roles = rolesCol.filter((r) => r.data.caso_id === data.id);

// «Contenido considerado y no modelado» (doc 02, sección 2.13, regla P-11).
// Condición 4 de la regla: en esta sección sólo se auto-enlazan personas con
// rol formal en ESTE caso; cualquier otra persona del inventario (p. ej. un
// cargo público nombrado en la prosa sin rol procesal) queda como texto plano,
// sin link y sin nodo. El cálculo es mecánico: exclusión = todas menos las
// que tienen RolEnCaso aquí.
const contenidoNoModelado = data.contenido_no_modelado ?? [];
const personasConRolEnCaso = new Set(
  roles.map((r) => r.data.sujeto_persona_id).filter(Boolean),
);
const personasSinRolEnCaso = personasCol
  .map((p) => p.data.id)
  .filter((id) => !personasConRolEnCaso.has(id));

// Índices auxiliares
const personaIndex = new Map(personasCol.map((p) => [p.data.id, p.data]));
const orgIndex = new Map(organizacionesCol.map((o) => [o.data.id, o.data]));
const docIndex = new Map(documentosCol.map((d) => [d.data.id, d.data]));
const delitoIndex = new Map(delitosCol.map((d) => [d.data.id, d.data]));

function docHrefForCaso(docId: string): string | undefined {
  const doc = docIndex.get(docId);
  return documentoRespaldoHref(docId, doc);
}

function personaLabel(id: string): string {
  return personaIndex.get(id)?.nombre_completo ?? id;
}

function orgLabel(id: string): string {
  return orgIndex.get(id)?.nombre ?? id;
}

function personaHref(id: string): string {
  return lang === 'ca' ? `/cat/personas/${id}` : `/personas/${id}`;
}

function orgHref(id: string): string {
  return lang === 'ca' ? `/cat/organizaciones/${id}` : `/organizaciones/${id}`;
}

function formatVinculoDate(value: string, precision?: string): string {
  if (precision === 'anio') return value.slice(0, 4);
  if (precision === 'mes') return value.slice(0, 7);
  return value;
}

function formatVinculoPeriodo(v: {
  desde: string;
  hasta?: string;
  precision_desde?: string;
  precision_hasta?: string;
  vigente?: boolean;
}): string {
  const desde = formatVinculoDate(v.desde, v.precision_desde);
  const hasta = v.hasta
    ? formatVinculoDate(v.hasta, v.precision_hasta)
    : v.vigente
      ? 'vigente'
      : 'sin fecha de cierre';
  return `${desde} → ${hasta}`;
}

// --- 2.1 Encabezado / 2.3 Estado procesal ---------------------------------

const organo = orgIndex.get(data.organo_judicial_id);
const ultimoHito = hitos[0]?.data;
const juezInstructor = roles.find((r) => r.data.rol === 'juez_instructor');
const juezInstructorPersona = juezInstructor?.data.sujeto_persona_id
  ? personaIndex.get(juezInstructor.data.sujeto_persona_id)
  : undefined;

// --- 2.4 Personas implicadas -----------------------------------------------
// Agrupadas por rol procesal (imputación activa / condenado / exculpado /
// otros / funcional), siguiendo doc 02, sección "Personas implicadas".

interface PersonaView {
  persona: ReturnType<typeof personaIndex.get>;
  roles: { rol: string; rolLabel: string; fecha_inicio: string; fecha_fin?: string; delitos: string[]; notas?: string }[];
  // Rol que rige el lado visual de la card: el rol activo de mayor peso
  // procesal, o si todos están cerrados, el último cronológico. Se usa
  // como clave para el filtro por rol individual de la sección §3.
  rolPrincipal?: string;
}

const personasMap = new Map<string, PersonaView>();
for (const r of roles) {
  if (r.data.sujeto_tipo !== 'persona' || !r.data.sujeto_persona_id) continue;
  const persona = personaIndex.get(r.data.sujeto_persona_id);
  if (!persona) continue;
  if (!personasMap.has(persona.id)) {
    personasMap.set(persona.id, { persona, roles: [] });
  }
  personasMap.get(persona.id)!.roles.push({
    rol: r.data.rol,
    rolLabel: rolLabel(r.data.rol, lang),
    fecha_inicio: r.data.fecha_inicio,
    fecha_fin: r.data.fecha_fin,
    delitos: (r.data.delitos_atribuidos ?? []).map((d) => delitoIndex.get(d)?.nombre_tipico ?? d),
    notas: r.data.notas,
  });
}

const personasPorGrupo: Record<string, PersonaView[]> = {
  imputacion_activa: [],
  condenado: [],
  exculpado: [],
  otros: [],
  funcional: [],
};
for (const pv of personasMap.values()) {
  // Grupo = el "peor" estado vigente entre sus roles activos. Si todos
  // están cerrados, vamos al grupo del rol más reciente.
  const activos = pv.roles.filter((r) => !r.fecha_fin);
  const referencia = activos.length > 0 ? activos[0] : pv.roles[pv.roles.length - 1];
  pv.rolPrincipal = referencia.rol;
  const grupo = rolGrupo(referencia.rol);
  personasPorGrupo[grupo].push(pv);
}

// Cada subheading se compone de partes, donde las que corresponden a un rol
// concreto reciben el color de F-estado del badge (DESIGN.md — "Sistema de badges").
// Refuerza la lectura: "investigados" en navy, "procesados / acusados" en mostaza,
// "condenados" en granate, "absueltos" en verde, "desimputados" en azul-gris.
interface SubheadParte {
  text: string;
  rolKey?: string;
}
const grupoOrden: {
  key: keyof typeof personasPorGrupo;
  partes: SubheadParte[];
  intro?: string;
}[] = [
  {
    key: 'imputacion_activa',
    partes: [
      { text: 'Investigados', rolKey: 'investigado' },
      { text: ' / ' },
      { text: 'procesados', rolKey: 'procesado' },
      { text: ' / ' },
      { text: 'acusados', rolKey: 'acusado' },
    ],
    intro:
      'Las personas en esta sección tienen un rol procesal activo de imputación. Conforme al principio de presunción de inocencia, su condición no implica valoración de culpabilidad mientras no recaiga resolución firme.',
  },
  {
    key: 'condenado',
    partes: [{ text: 'Condenados', rolKey: 'condenado_no_firme' }],
  },
  {
    key: 'exculpado',
    partes: [
      { text: 'Absueltos', rolKey: 'absuelto' },
      { text: ' / ' },
      { text: 'desimputados', rolKey: 'desimputado' },
    ],
  },
  {
    key: 'otros',
    partes: [{ text: 'Otros: denunciantes, testigos, acusación popular' }],
  },
  {
    key: 'funcional',
    partes: [{ text: 'Funcionales: jueces, fiscales, abogados' }],
  },
];

// --- 2.5 Organizaciones implicadas -----------------------------------------

interface OrgView {
  org: ReturnType<typeof orgIndex.get>;
  roles: { rol: string; rolLabel: string; fecha_inicio: string; fecha_fin?: string; notas?: string }[];
}
const orgsMap = new Map<string, OrgView>();
for (const r of roles) {
  if (r.data.sujeto_tipo !== 'organizacion' || !r.data.sujeto_organizacion_id) continue;
  const org = orgIndex.get(r.data.sujeto_organizacion_id);
  if (!org) continue;
  if (!orgsMap.has(org.id)) orgsMap.set(org.id, { org, roles: [] });
  orgsMap.get(org.id)!.roles.push({
    rol: r.data.rol,
    rolLabel: rolLabel(r.data.rol, lang),
    fecha_inicio: r.data.fecha_inicio,
    fecha_fin: r.data.fecha_fin,
    notas: r.data.notas,
  });
}
const orgsImplicadas = Array.from(orgsMap.values());

// --- Contexto institucional -------------------------------------------------

const vinculosCasoEntries = vinculosCol
  .filter((v) => v.data.relevancia_para_caso_ids?.includes(data.id))
  .filter((v) => v.data.estado_publicacion !== 'retirado_definitivamente')
  .sort((a, b) => {
    const byNature = naturalezaVinculoLabel(a.data.naturaleza).localeCompare(
      naturalezaVinculoLabel(b.data.naturaleza),
      'es',
    );
    if (byNature !== 0) return byNature;
    return b.data.desde.localeCompare(a.data.desde);
  });

function vinculoEntity(v: CollectionEntry<'vinculos'>['data'], side: 'sujeto' | 'objeto') {
  if (side === 'sujeto') {
    if (v.sujeto_persona_id) {
      return {
        label: personaLabel(v.sujeto_persona_id),
        href: personaHref(v.sujeto_persona_id),
      };
    }
    if (v.sujeto_organizacion_id) {
      return {
        label: orgLabel(v.sujeto_organizacion_id),
        href: orgHref(v.sujeto_organizacion_id),
      };
    }
  }
  if (v.objeto_persona_id) {
    return {
      label: personaLabel(v.objeto_persona_id),
      href: personaHref(v.objeto_persona_id),
    };
  }
  if (v.objeto_organizacion_id) {
    return {
      label: orgLabel(v.objeto_organizacion_id),
      href: orgHref(v.objeto_organizacion_id),
    };
  }
  return { label: 'Entidad no resuelta' };
}

interface CardRelacion {
  naturalezaLabel: string;
  entidadLabel: string;
  entidadHref?: string;
  descripcion: string;
  periodo: string;
  documentoHref?: string;
}

function firstDocHref(v: CollectionEntry<'vinculos'>): string | undefined {
  const docId = v.data.documentos_respaldo[0]?.documento_id;
  return docId && docIndex.has(docId) ? docHrefForCaso(docId) : undefined;
}

function relacionParaCard(v: CollectionEntry<'vinculos'>, entityId: string, entityType: 'persona' | 'organizacion'): CardRelacion {
  const subjectMatches =
    entityType === 'persona'
      ? v.data.sujeto_persona_id === entityId
      : v.data.sujeto_organizacion_id === entityId;
  const counterpart = subjectMatches ? vinculoEntity(v.data, 'objeto') : vinculoEntity(v.data, 'sujeto');
  return {
    naturalezaLabel: naturalezaVinculoLabel(v.data.naturaleza),
    entidadLabel: counterpart.label,
    entidadHref: counterpart.href,
    descripcion: v.data.descripcion,
    periodo: formatVinculoPeriodo(v.data),
    documentoHref: firstDocHref(v),
  };
}

const relacionesPorPersona = new Map<string, CardRelacion[]>();
const relacionesPorOrg = new Map<string, CardRelacion[]>();

function addRelacion(map: Map<string, CardRelacion[]>, id: string, rel: CardRelacion) {
  const current = map.get(id) ?? [];
  current.push(rel);
  map.set(id, current);
}

// --- Organizaciones afectadas (refactor 2026-05-27) -----------------------
// Bloque unificado que sustituye al anterior "Instituciones alcanzadas" +
// al campo retirado `Caso.partidos_afectados[]`. Una sola dimensión con dos
// niveles (directa / indirecta), exhaustiva y mutuamente excluyente. El
// papel procesal (acusación popular) NO es afectación y aparece en
// "Participación procesal" más abajo. Canon: docs/diseno/08-afectacion-directa-indirecta.md.
const ETIQUETA_NATURALEZA_AFECTACION: Record<string, string> = {
  entidad_investigada_en_caso: 'Persona jurídica investigada',
  perjudicado_institucional_en_caso: 'Perjudicado institucional',
  ambito_administrativo_directo_del_acto_en_caso: 'Ámbito administrativo del acto',
  caja_partido_objeto_investigacion_en_caso: 'Caja del partido, objeto del caso',
  afectacion_indirecta_en_caso: 'Afectación indirecta',
};
type OrgAfectadaView = {
  id: string;
  nombre: string;
  siglas?: string;
  esPartido: boolean;
  href: string;
  naturalezaLabel: string;
  justificacion?: string;
};
const orgAfectadasDirectas: OrgAfectadaView[] = [];
const orgAfectadasIndirectas: OrgAfectadaView[] = [];
{
  const seen = new Map<string, OrgAfectadaView>();
  const NATURALEZAS_DIRECTA = new Set([
    'entidad_investigada_en_caso',
    'perjudicado_institucional_en_caso',
    'ambito_administrativo_directo_del_acto_en_caso',
    'caja_partido_objeto_investigacion_en_caso',
  ]);
  const orderForDedup: Array<{ v: OrgAfectadaView; nivel: 'directa' | 'indirecta' }> = [];
  for (const v of vinculosCasoEntries) {
    const nat = v.data.naturaleza;
    const orgId = v.data.sujeto_organizacion_id;
    if (!orgId) continue;
    const esDirecta = NATURALEZAS_DIRECTA.has(nat);
    const esIndirecta = nat === 'afectacion_indirecta_en_caso';
    if (!esDirecta && !esIndirecta) continue;
    const org = orgIndex.get(orgId);
    const view: OrgAfectadaView = {
      id: orgId,
      nombre: org?.nombre ?? orgId,
      siglas: (org as { siglas?: string } | undefined)?.siglas,
      esPartido: org?.tipo === 'partido_politico',
      href: orgHref(orgId),
      naturalezaLabel: ETIQUETA_NATURALEZA_AFECTACION[nat] ?? nat,
      justificacion: v.data.justificacion_afectacion as string | undefined,
    };
    const ya = seen.get(orgId);
    if (!ya) {
      seen.set(orgId, view);
      orderForDedup.push({ v: view, nivel: esDirecta ? 'directa' : 'indirecta' });
    } else if (esDirecta) {
      // Dedupe: directa gana sobre indirecta.
      Object.assign(ya, view);
    }
  }
  for (const { v, nivel } of orderForDedup) {
    const actual = seen.get(v.id);
    if (!actual) continue;
    if (nivel === 'directa') orgAfectadasDirectas.push(actual);
    else orgAfectadasIndirectas.push(actual);
  }
  // Dedupe local de la lista (puede haber duplicados si una misma org
  // aparece en dos vínculos con la misma naturaleza).
  const dedup = (arr: OrgAfectadaView[]) => {
    const out: OrgAfectadaView[] = [];
    const ids = new Set<string>();
    for (const o of arr) {
      if (ids.has(o.id)) continue;
      ids.add(o.id);
      out.push(o);
    }
    return out.sort((a, b) => a.nombre.localeCompare(b.nombre, 'es'));
  };
  orgAfectadasDirectas.splice(0, orgAfectadasDirectas.length, ...dedup(orgAfectadasDirectas));
  orgAfectadasIndirectas.splice(0, orgAfectadasIndirectas.length, ...dedup(orgAfectadasIndirectas));
}
const hayOrgAfectadas =
  orgAfectadasDirectas.length + orgAfectadasIndirectas.length > 0;

// --- Participación procesal: acusación popular constituida -----------------
// Las organizaciones que se personan como acusación popular no son
// afectadas (regla 5 del doc 08). Aparecen aquí, separadas, deduplicadas
// por organizacion_id.
type OrgProcesalView = { id: string; nombre: string; href: string };
const acusacionPopularOrgs: OrgProcesalView[] = (() => {
  const seen = new Set<string>();
  const out: OrgProcesalView[] = [];
  for (const v of vinculosCasoEntries) {
    if (v.data.naturaleza !== 'acusacion_institucional_en_caso') continue;
    const orgId = v.data.sujeto_organizacion_id;
    if (!orgId || seen.has(orgId)) continue;
    seen.add(orgId);
    out.push({ id: orgId, nombre: orgLabel(orgId), href: orgHref(orgId) });
  }
  return out.sort((a, b) => a.nombre.localeCompare(b.nombre, 'es'));
})();
const hayAcusacionPopular = acusacionPopularOrgs.length > 0;

for (const v of vinculosCasoEntries) {
  if (v.data.sujeto_persona_id) {
    addRelacion(relacionesPorPersona, v.data.sujeto_persona_id, relacionParaCard(v, v.data.sujeto_persona_id, 'persona'));
  }
  if (v.data.objeto_persona_id) {
    addRelacion(relacionesPorPersona, v.data.objeto_persona_id, relacionParaCard(v, v.data.objeto_persona_id, 'persona'));
  }
  if (v.data.sujeto_organizacion_id) {
    addRelacion(relacionesPorOrg, v.data.sujeto_organizacion_id, relacionParaCard(v, v.data.sujeto_organizacion_id, 'organizacion'));
  }
  if (v.data.objeto_organizacion_id) {
    addRelacion(relacionesPorOrg, v.data.objeto_organizacion_id, relacionParaCard(v, v.data.objeto_organizacion_id, 'organizacion'));
  }
}

// --- 2.6 Cronología ---------------------------------------------------------

const cronologia = hitos.map((h) => {
  const doc = h.data.documento_principal_id ? docIndex.get(h.data.documento_principal_id) : undefined;
  return {
    id: h.data.id,
    fecha: h.data.fecha,
    precision: h.data.fecha_precision,
    tipo: h.data.tipo,
    tipoLabel: tipoHitoLabel(h.data.tipo),
    tipoFamilia: tipoHitoFamilia(h.data.tipo),
    titulo: h.data.titulo,
    descripcion: h.data.descripcion,
    doc,
  };
});

// --- 2.7 Hechos clasificados por estado epistémico -------------------------

interface HechoView {
  id: string;
  tipo: 'acreditado' | 'investigado' | 'atribuido' | 'exculpatorio' | 'desmentido' | 'no_concluyente';
  enunciado: string;
  fechaTexto: string;
  fuentes: { nivel: 1 | 2 | 3 | 4; titulo: string; href?: string; pasaje?: string }[];
}

function formatPeriodo(fop: { desde: string; hasta?: string; precision: string }): string {
  if (fop.precision === 'rango' && fop.hasta) return `${fop.desde} → ${fop.hasta}`;
  if (fop.precision === 'anio') return fop.desde.slice(0, 4);
  if (fop.precision === 'mes') return fop.desde.slice(0, 7);
  return fop.desde;
}

const hechosViews: HechoView[] = hechos.map((h) => ({
  id: h.data.id,
  tipo: h.data.tipo,
  enunciado: h.data.enunciado,
  fechaTexto: formatPeriodo(h.data.fecha_o_periodo as { desde: string; hasta?: string; precision: string }),
  fuentes: ((h.data as { documentos_respaldo?: { documento_id: string; pasaje?: string }[] }).documentos_respaldo ?? []).map((d) => {
    const doc = docIndex.get(d.documento_id);
    return {
      nivel: (doc?.nivel_fuente ?? 4) as 1 | 2 | 3 | 4,
      titulo: doc?.titulo ?? d.documento_id,
      href: doc ? docHrefForCaso(doc.id) : undefined,
      pasaje: d.pasaje,
    };
  }),
}));

const HECHOS_ORDEN: { tipos: HechoView['tipo'][]; titulo: string; aviso?: string; num: string }[] = [
  { tipos: ['acreditado'],                  titulo: 'Hechos acreditados',     num: '6.1' },
  {
    tipos: ['investigado', 'atribuido'],
    titulo: 'Hechos bajo investigación o atribuidos',
    num: '6.2',
    aviso:
      'Los hechos en esta sección están bajo investigación judicial o atribuidos por una fuente con autoridad institucional pero no han sido acreditados por sentencia firme. Pueden ser confirmados, descartados o archivados en el futuro.',
  },
  { tipos: ['exculpatorio'],                titulo: 'Hechos exculpatorios',   num: '6.3' },
  { tipos: ['desmentido', 'no_concluyente'], titulo: 'Hechos desmentidos o no concluyentes', num: '6.4' },
];

const hechosPorGrupo = HECHOS_ORDEN.map((g) => ({
  ...g,
  items: hechosViews.filter((h) => g.tipos.includes(h.tipo)),
}));

// --- Cifras del caso (importes) --------------------------------------------
// El dinero vive en los Hechos. Se separan SIEMPRE dos clases que nunca se
// mezclan ni se suman: `objeto` (dinero presuntamente atribuido / en juego) y
// `consecuencia` (multas y responsabilidad civil). Reglas anti-doble-conteo y
// por clase en src/lib/importe.ts.
function truncarEnunciado(s: string, n = 120): string {
  const flat = s.replace(/\s+/g, ' ').trim();
  return flat.length <= n ? flat : flat.slice(0, n - 1).trimEnd() + '…';
}
const importeEntriesCaso = toImporteEntries(
  hechos.map((h) => h.data as unknown as HechoImporteInput),
);
function cifraEntryView(e: (typeof importeEntriesCaso)[number]) {
  return {
    importe: e.importe,
    tipo: e.tipo,
    nivel: e.nivel,
    naturaleza: e.naturaleza,
    alcance: e.alcance,
    enunciado: truncarEnunciado(e.enunciado),
    nota: e.nota,
    hechoHref: `#hecho-${e.hechoId}`,
    docHref: e.docId ? docHrefForCaso(e.docId) : undefined,
    acumula: e.acumula,
  };
}
const cifrasObjeto = analizarCaso(importeEntriesCaso, 'objeto');
const cifrasConsecuencia = analizarCaso(importeEntriesCaso, 'consecuencia');
const cifrasObjetoViews = cifrasObjeto.entries.map(cifraEntryView);
const cifrasConsecuenciaViews = cifrasConsecuencia.entries.map(cifraEntryView);
const naturalezasObjetoLabels = cifrasObjeto.naturalezasEnTotal.map((n) => importeNaturalezaLabel(n));
const naturalezasConsecuenciaLabels = cifrasConsecuencia.naturalezasEnTotal.map((n) => importeNaturalezaLabel(n));
const hayCifras = cifrasObjetoViews.length > 0 || cifrasConsecuenciaViews.length > 0;
const cifrasTotalPreview = cifrasObjeto.total ?? cifrasConsecuencia.total;

// --- Pills de filtrado por sección -----------------------------------------
//
// Para cada sección filtrable de la ficha calculamos las opciones de pill
// realmente presentes en el caso (no engordar la fila con buckets/tipos
// que el caso no usa). El orden es canónico, no alfabético: en personas
// sigue la pirámide procesal (imputación activa → funcional); en hitos
// sigue el orden editorial (jurisdiccional → político → mediático); en
// hechos sigue la escala epistémica (acreditado → no concluyente).

// §3 Personas — un pill por rol individual realmente presente en el caso.
// Cada pill envuelve un RolBadge real del rol (mismo badge que aparece en
// las cards de las personas). Decisión 2026-05-27 (segunda iteración): los
// buckets agrupaban roles distintos en un solo badge representativo
// (p. ej. "Absuelto" / "Desimputado" bajo "Absuelto / desimputado"), lo
// cual ocultaba el badge real de cada rol. Mejor enseñar el badge tal
// cual y permitir filtrar por cada rol concreto presente.
//
// Orden canónico de roles, alineado con `grupoOrden` (pirámide procesal),
// aplanado: primero imputación activa, después condenados, después
// exculpados, partes civiles/popular/testigos y por último aparato
// judicial.
const ROL_ORDEN_CANONICO: string[] = [
  'investigado', 'procesado', 'acusado',
  'condenado_no_firme', 'condenado_firme',
  'absuelto', 'desimputado',
  'denunciante', 'querellante', 'acusacion_particular', 'acusacion_popular',
  'perjudicado', 'testigo',
  'juez_instructor', 'juez_ponente',
  'fiscal',
  'abogado_defensa', 'abogado_acusacion',
  'perito_judicial', 'perito_parte',
  'secretario_judicial',
];
// Unión de TODOS los roles que aparecen en cualquier persona del caso, no
// sólo el "rol principal" de referencia. Decisión 2026-05-27 (tercera
// iteración): el lector veía la card con los dos roles (p.ej. investigado
// + procesado) pero la fila de pills sólo mostraba el principal, lo que
// generaba mismatch. Ahora un pill aparece si CUALQUIER persona del caso
// tiene ese rol entre los suyos, y filtrar por él muestra a todas las
// personas que lo lleven. El `data-roles` de cada card es CSV con todos
// los roles de la persona; el script aplica match por contención.
const personasRolesPresentes = new Set<string>();
for (const pv of personasMap.values()) {
  for (const r of pv.roles) personasRolesPresentes.add(r.rol);
}
const personasPills = ROL_ORDEN_CANONICO.filter((r) => personasRolesPresentes.has(r));

// §5 Cronología — 3 familias (devueltas por tipoHitoFamilia).
const HITOS_PILL_DEF: { value: 'jurisdiccional' | 'politico' | 'mediatico'; label: string }[] = [
  { value: 'jurisdiccional', label: 'Jurisdiccional' },
  { value: 'politico',       label: 'Político' },
  { value: 'mediatico',      label: 'Mediático' },
];
const hitoFamiliasPresentes = new Set(cronologia.map((h) => h.tipoFamilia));
const hitosPills = HITOS_PILL_DEF.filter((p) => hitoFamiliasPresentes.has(p.value));

// §6 Hechos — 6 tipos epistémicos posibles.
const HECHOS_PILL_DEF: { value: HechoView['tipo']; label: string }[] = [
  { value: 'acreditado',     label: 'Acreditado' },
  { value: 'investigado',    label: 'Investigado' },
  { value: 'atribuido',      label: 'Atribuido' },
  { value: 'exculpatorio',   label: 'Exculpatorio' },
  { value: 'desmentido',     label: 'Desmentido' },
  { value: 'no_concluyente', label: 'No concluyente' },
];
const hechoTiposPresentes = new Set(hechosViews.map((h) => h.tipo));
const hechosPills = HECHOS_PILL_DEF.filter((p) => hechoTiposPresentes.has(p.value));

// --- 2.8 Biblioteca ---------------------------------------------------------

// Documentos del caso = los que tienen caso_principal_id === data.id +
// los referenciados desde hitos del caso + los referenciados en hechos del
// caso. Deduplicar por id. Ordenar por nivel ascendente (más oficiales
// primero) y fecha descendente.

const docIds = new Set<string>();
for (const d of documentosCol) {
  if (d.data.caso_principal_id === data.id) docIds.add(d.data.id);
}
for (const h of hitos) if (h.data.documento_principal_id) docIds.add(h.data.documento_principal_id);
for (const h of hechos) {
  const ds = (h.data as { documentos_respaldo?: { documento_id: string }[] }).documentos_respaldo;
  if (ds) for (const d of ds) docIds.add(d.documento_id);
}
for (const v of vinculosCasoEntries) {
  for (const d of v.data.documentos_respaldo) docIds.add(d.documento_id);
}

const biblioteca = Array.from(docIds)
  .map((id) => docIndex.get(id))
  .filter((d): d is NonNullable<typeof d> => Boolean(d))
  .map((d) => {
    // citado en N hechos
    let citado = 0;
    for (const h of hechos) {
      const ds = (h.data as { documentos_respaldo?: { documento_id: string }[] }).documentos_respaldo;
      if (ds && ds.some((x) => x.documento_id === d.id)) citado++;
    }
    const productorOrg = d.productor_organizacion_id ? orgIndex.get(d.productor_organizacion_id) : undefined;
    return {
      d,
      productor: productorOrg?.nombre,
      productorId: productorOrg?.id,
      citadoEn: citado,
    };
  })
  .sort((a, b) => {
    if (a.d.nivel_fuente !== b.d.nivel_fuente) return a.d.nivel_fuente - b.d.nivel_fuente;
    return b.d.fecha_documento.localeCompare(a.d.fecha_documento);
  });

// --- Cobertura mediática general --------------------------------------------

const coberturaCaso = coberturaMediaticaCol.find((c) => c.data.caso_id === data.id)?.data;
const noticiasCobertura = coberturaCaso?.noticias ?? [];

function countBy<T>(items: T[], keyFn: (item: T) => string): Map<string, number> {
  const counts = new Map<string, number>();
  for (const item of items) {
    const key = keyFn(item);
    counts.set(key, (counts.get(key) ?? 0) + 1);
  }
  return counts;
}

const coberturaPorTipo = Array.from(countBy(noticiasCobertura, (n) => n.tipo_pieza).entries())
  .map(([tipo, total]) => ({
    label: tipoPiezaMediaticaLabel(tipo),
    total,
  }))
  .sort((a, b) => b.total - a.total || a.label.localeCompare(b.label, 'es'));

const coberturaPorMedio = Array.from(countBy(noticiasCobertura, (n) => n.medio_id).entries())
  .map(([medioId, total]) => ({
    medioId,
    label: orgLabel(medioId),
    href: orgHref(medioId),
    total,
  }))
  .sort((a, b) => b.total - a.total || a.label.localeCompare(b.label, 'es'));

const coberturaMeses = Array.from(
  countBy(noticiasCobertura, (n) => n.fecha_publicacion.slice(0, 7)).entries(),
)
  .map(([mes, total]) => {
    const ejemplo = noticiasCobertura
      .filter((n) => n.fecha_publicacion.startsWith(mes))
      .sort((a, b) => a.fecha_publicacion.localeCompare(b.fecha_publicacion))[0];
    return {
      mes,
      total,
      ejemploTitulo: ejemplo?.titular,
      ejemploMedio: ejemplo ? orgLabel(ejemplo.medio_id) : undefined,
    };
  })
  .sort((a, b) => a.mes.localeCompare(b.mes));

const coberturaPicos = [...coberturaMeses]
  .sort((a, b) => b.total - a.total || a.mes.localeCompare(b.mes))
  .slice(0, 3);

const coberturaFechas = noticiasCobertura
  .map((n) => n.fecha_publicacion)
  .sort((a, b) => a.localeCompare(b));
const coberturaDesde = coberturaFechas[0];
const coberturaHasta = coberturaFechas[coberturaFechas.length - 1];
const coberturaMedioPrincipal = coberturaPorMedio[0];
const coberturaTipoPrincipal = coberturaPorTipo[0];
const coberturaEstadoLabel = coberturaCaso?.estado === 'parcial'
  ? 'Muestra inicial verificada; el rastreo de cobertura se completará en revisiones posteriores.'
  : coberturaCaso?.estado === 'completo'
    ? 'Rastreo completo según la metodología declarada.'
    : 'Rastreo pendiente de completar.';

const coberturaRows = [...noticiasCobertura]
  .sort((a, b) => b.fecha_publicacion.localeCompare(a.fecha_publicacion))
  .map((n) => ({
    id: n.id,
    fecha: n.fecha_publicacion,
    medioLabel: orgLabel(n.medio_id),
    medioHref: orgHref(n.medio_id),
    tipo: n.tipo_pieza,
    tipoLabel: tipoPiezaMediaticaLabel(n.tipo_pieza),
    titular: n.titular,
    resumen: n.resumen,
    relevanciaLabel: n.relevancia_editorial
      ? relevanciaEditorialLabel(n.relevancia_editorial)
      : undefined,
    url: n.url,
    urlArchivo: n.url_archivo,
  }));

