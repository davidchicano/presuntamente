---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CategoryBadge from '@/components/CategoryBadge.astro';
import CustomSelect from '@/components/CustomSelect.astro';
import CatalogoLeyenda from '@/components/CatalogoLeyenda.astro';
import SectionH from '@/components/SectionH.astro';
import { getCollection } from 'astro:content';
import { familiaDelitoLabel, type Lang } from '@/lib/labels';

interface Props { lang?: Lang; }
const { lang = 'es' } = Astro.props;

const [delitosCol, casosCol, rolesCol] = await Promise.all([
  getCollection('delitos'),
  getCollection('casos'),
  getCollection('roles'),
]);

// Para cada delito calculamos:
//   - casos: número de casos cuyos `delitos_atribuidos_en_la_causa` lo incluyen.
//   - atribuciones: número de roles (persona+org) que se lo atribuyen formalmente.
function countCasos(delitoId: string): number {
  const set = new Set<string>();
  for (const c of casosCol) {
    if (c.data.delitos_atribuidos_en_la_causa?.includes(delitoId)) set.add(c.data.id);
  }
  for (const r of rolesCol) {
    if (r.data.delitos_atribuidos?.includes(delitoId)) set.add(r.data.caso_id);
  }
  return set.size;
}
function countAtribuciones(delitoId: string): number {
  return rolesCol.filter((r) => r.data.delitos_atribuidos?.includes(delitoId)).length;
}

const delitos = delitosCol
  .map((d) => ({
    slug: d.data.id,
    nombre: d.data.nombre_tipico,
    familia: d.data.familia,
    familiaLabel: familiaDelitoLabel(d.data.familia),
    articulos: d.data.articulos_cp,
    casosCount: countCasos(d.data.id),
    atribCount: countAtribuciones(d.data.id),
  }))
  .sort((a, b) => a.nombre.localeCompare(b.nombre, 'es'));

const strings = {
  title: 'Delitos del catálogo',
  description:
    'Catálogo de tipos penales referenciados en los procedimientos de presuntamente.org. ' +
    'No es un listado de personas condenadas: cada ficha cuenta los casos y los roles donde el delito se ATRIBUYE.',
  eyebrow: 'Sección 4 · Delitos',
  sub:
    'Tipos penales del Código Penal español que aparecen en los procedimientos: ' +
    'cada ficha describe el tipo, lista los artículos aplicables y resume en qué casos y a qué sujetos se atribuye. ' +
    'Que un delito aparezca atribuido a una persona NO equivale a condena.',
};

function searchBlob(d: (typeof delitos)[number]): string {
  return [d.nombre, d.familiaLabel, ...d.articulos].join(' ').toLowerCase();
}

const familiasPresentes = Array.from(new Set(delitos.map((d) => d.familia)))
  .map((f) => ({ valor: f, label: familiaDelitoLabel(f) }))
  .sort((a, b) => a.label.localeCompare(b.label, 'es'));
---

<BaseLayout
  title={strings.title}
  lang={lang}
  description={strings.description}
  activeNav="delitos"
  breadcrumb={[
    { label: 'Inicio', href: lang === 'ca' ? '/cat' : '/' },
    { label: 'Delitos' },
  ]}
>
  <section class="page-id">
    <div>
      <p class="page-id__eyebrow">{strings.eyebrow}</p>
      <h1 class="page-id__title">{strings.title}</h1>
      <p class="page-id__sub">{strings.sub}</p>
    </div>
    <div class="page-id__meta">
      <span>Total: <span data-total>{delitos.length}</span></span>
      <span>·</span>
      <span>Mostrando: <span data-shown>{delitos.length}</span></span>
    </div>
  </section>

  <CatalogoLeyenda
    titulo="Cómo leer este catálogo"
    resumen="Tipo penal, familia, casos donde aparece y atribuciones formales."
    ariaLabel="Leyenda del catálogo de delitos"
  >
    <section class="cat-legend__section">
      <h3 class="cat-legend__section-title">Columnas del listado</h3>
      <p class="cat-legend__inline">
        <strong>Tipo penal:</strong> enunciado del delito según la doctrina y el Código Penal.
        <strong>Familia:</strong> agrupación temática que sirve para filtrar (contra la
        Administración Pública, contra el patrimonio, falsedad documental, etc.).
        <strong>Artículos CP:</strong> articulado aplicable.
        <strong>Casos:</strong> número de procedimientos del inventario donde el tipo penal
        aparece atribuido.
        <strong>Atribuciones:</strong> número de roles (persona u organización) que se lo
        atribuyen formalmente en algún momento del procedimiento.
      </p>
    </section>
    <section class="cat-legend__section">
      <h3 class="cat-legend__section-title">Filtros y ordenación</h3>
      <p class="cat-legend__inline">
        Puedes <strong>buscar</strong> por nombre típico, familia o número de artículo, y
        filtrar por <strong>familia de delito</strong>. El selector de orden cubre
        <strong>alfabético</strong>, <strong>número de casos</strong> y
        <strong>número de atribuciones</strong>.
      </p>
    </section>
    <section class="cat-legend__section">
      <h3 class="cat-legend__section-title">Atribución ≠ condena</h3>
      <p class="cat-legend__inline">
        Que un delito aparezca atribuido a una persona o a una organización <strong>no
        equivale a condena</strong>. La atribución es un dato del procedimiento (escrito de
        querella, auto de procesamiento, escrito de acusación). La presunción de inocencia
        se mantiene mientras no exista sentencia firme. Esta misma advertencia aparece como
        aviso editorial al pie del listado.
      </p>
    </section>
    <section class="cat-legend__section">
      <h3 class="cat-legend__section-title">Más detalle metodológico</h3>
      <p class="cat-legend__inline">
        Cómo se modelan los hechos a los que se asocia cada delito está en
        <a href="/sobre#tipos-hecho">/sobre — Tipos de hecho</a>; los criterios editoriales
        generales (presunción de inocencia y lenguaje), en
        <a href="/sobre#principios">/sobre — Principios editoriales</a> y
        <a href="/sobre#lenguaje">/sobre — Lenguaje editorial</a>.
      </p>
    </section>
  </CatalogoLeyenda>

  <SectionH num="4.1" title="Filtros">
    <button
      type="reset"
      form="filters-delitos"
      class="sec-h__action"
      aria-label="Limpiar filtros de delitos"
    >
      Limpiar filtros
    </button>
  </SectionH>

  <form id="filters-delitos" class="filter-bar" method="get" role="search" aria-label="Filtrar delitos" data-delitos-filters>
    <div class="field">
      <label for="q">Buscar</label>
      <input id="q" name="q" type="search" placeholder="Nombre típico, familia, artículo…" autocomplete="off" />
    </div>
    <div class="field">
      <label for="familia">Familia</label>
      <CustomSelect
        id="familia"
        name="familia"
        value="all"
        ariaLabel="Filtrar por familia de delito"
        options={[
          { value: 'all', label: 'Todas' },
          ...familiasPresentes.map((f) => ({ value: f.valor, label: f.label })),
        ]}
      />
    </div>
    <div class="field">
      <label for="order">Ordenar por</label>
      <CustomSelect
        id="order"
        name="order"
        value="alfabetico"
        ariaLabel="Ordenar listado"
        options={[
          { value: 'alfabetico',    label: 'Alfabético' },
          { value: 'casos',         label: 'Nº de casos ↓' },
          { value: 'atribuciones',  label: 'Nº de atribuciones ↓' },
        ]}
      />
    </div>
  </form>

  <header class="sec-h">
    <span class="num">4.2</span>
    <h2>Listado</h2>
    <span class="right" data-listado-meta>orden: alfabético</span>
  </header>

  <div class="tbl-scroll">
  <table class="tbl" data-delitos>
    <thead>
      <tr>
        <th style="width: 36%;">Tipo penal</th>
        <th style="width: 28%;">Familia</th>
        <th style="width: 20%;">Artículos CP</th>
        <th style="width: 8%;" class="c-num">Casos</th>
        <th
          style="width: 8%;"
          class="c-num"
          title="Roles procesales (investigado, procesado, acusado, condenado) a los que se ha atribuido formalmente este delito en algún momento del procedimiento. Una atribución NO equivale a condena."
        >Atribuciones</th>
      </tr>
    </thead>
    <tbody>
      {delitos.map((d) => (
        <tr
          class="is-link"
          data-row
          data-familia={d.familia}
          data-casos={d.casosCount}
          data-atribuciones={d.atribCount}
          data-search={searchBlob(d)}
        >
          <td>
            <a href={`/delitos/${d.slug}`}>
              <span class="c-name">{d.nombre}</span>
            </a>
          </td>
          <td>
            <CategoryBadge kind="delito" tipo={d.familia} label={d.familiaLabel} />
          </td>
          <td class="c-mono c-arts">{d.articulos.join(' · ')}</td>
          <td class="c-num">{d.casosCount}</td>
          <td class="c-num">{d.atribCount}</td>
        </tr>
      ))}
    </tbody>
  </table>
  </div>

  <p class="empty-state" data-empty hidden>Sin resultados para los filtros actuales.</p>

  <p class="legal-note">
    <strong>Aviso editorial.</strong> La columna «Atribuciones» cuenta los roles procesales (investigados, procesados,
    acusados, condenados) a los que el delito ha sido formalmente atribuido en algún momento del procedimiento.
    La presunción de inocencia se mantiene mientras no exista sentencia firme.
  </p>
</BaseLayout>

<script is:inline>
  (() => {
    const form = document.querySelector('[data-delitos-filters]');
    const table = document.querySelector('[data-delitos]');
    if (!form || !table) return;
    const rows = Array.from(table.querySelectorAll('[data-row]'));
    const tbody = table.querySelector('tbody');
    const shown = document.querySelector('[data-shown]');
    const empty = document.querySelector('[data-empty]');
    const meta = document.querySelector('[data-listado-meta]');
    const qInput = form.querySelector('#q');
    const famSel = form.querySelector('input[name="familia"]');
    const orderSel = form.querySelector('input[name="order"]');

    const ORDER_LABEL = {
      alfabetico: 'alfabético',
      casos: 'nº de casos',
      atribuciones: 'nº de atribuciones',
    };

    function resyncCustomSelects() {
      form.querySelectorAll('[data-csel]').forEach((csel) => {
        const hidden = csel.querySelector('[data-csel-value]');
        const label = csel.querySelector('[data-csel-label]');
        if (!hidden || !label) return;
        const opt = csel.querySelector(`[data-csel-opt][data-value="${hidden.value}"]`);
        if (opt) {
          label.textContent = opt.textContent.trim();
          csel.querySelectorAll('[data-csel-opt]').forEach((o) =>
            o.setAttribute('aria-selected', o === opt ? 'true' : 'false'),
          );
        }
      });
    }
    function apply() {
      const q = (qInput.value || '').trim().toLowerCase();
      const fam = famSel.value;
      const order = orderSel ? orderSel.value : 'alfabetico';

      const visible = [];
      for (const row of rows) {
        const matchQ = !q || (row.dataset.search || '').includes(q);
        const matchF = fam === 'all' || row.dataset.familia === fam;
        const show = matchQ && matchF;
        row.hidden = !show;
        if (show) visible.push(row);
      }

      if (tbody) {
        visible.sort((a, b) => {
          if (order === 'casos') {
            const ca = parseInt(a.dataset.casos || '0', 10);
            const cb = parseInt(b.dataset.casos || '0', 10);
            if (cb !== ca) return cb - ca;
          }
          if (order === 'atribuciones') {
            const aa = parseInt(a.dataset.atribuciones || '0', 10);
            const ab = parseInt(b.dataset.atribuciones || '0', 10);
            if (ab !== aa) return ab - aa;
          }
          const na = (a.querySelector('.c-name')?.textContent || '').trim();
          const nb = (b.querySelector('.c-name')?.textContent || '').trim();
          return na.localeCompare(nb, 'es');
        });
        for (const row of visible) tbody.appendChild(row);
      }

      if (shown) shown.textContent = String(visible.length);
      if (empty) empty.hidden = visible !== 0;
      if (meta) meta.textContent = `orden: ${ORDER_LABEL[order] || 'alfabético'}`;
    }
    form.addEventListener('input', apply);
    form.addEventListener('change', apply);
    form.addEventListener('submit', (e) => { e.preventDefault(); apply(); });
    form.addEventListener('reset', () => setTimeout(() => { resyncCustomSelects(); apply(); }, 0));
  })();
</script>

<style>
  .empty-state {
    border: 1px dashed var(--color-border-strong);
    background: var(--color-surface-muted);
    padding: var(--space-4);
    text-align: center;
    font: 400 var(--font-size-1)/1.5 var(--font-sans);
    color: var(--color-fg-muted);
  }
  .c-arts { font-size: 11px; color: var(--color-fg-muted); }
  .legal-note {
    margin: var(--space-4) 0 0;
    padding: 12px 14px;
    border-left: 3px solid var(--color-border-strong);
    background: var(--color-surface-muted);
    font: 400 12px/1.55 var(--font-sans);
    color: var(--color-fg-muted);
  }
  .legal-note strong { color: var(--color-fg); font-weight: 600; }
</style>
