---
// EstadoFichaBadge — badge para el campo `estado_ficha.<check>` del Caso.
// Cuatro estados discretos con color suave + label de texto, sin glyph
// decorativo (ver AGENTS.md → "Convención de referencias y citas",
// punto 4 sobre el sistema de badges).
//
// Estilos scoped en este mismo fichero para no inflar global.css y para
// respetar la coordinación multiagéntica de esta sesión (global.css está
// en manos del worktree bloque-e).
//
// Mapeo:
//   completo   — verde, alineado con --color-acreditado (epistémico)
//   parcial    — mostaza, alineado con --color-accent-secondary
//   pendiente  — gris navy suave, alineado con --color-rol-investigado
//   no_aplica  — gris desaturado, sin contraste fuerte

interface Props {
  estado: 'completo' | 'parcial' | 'pendiente' | 'no_aplica';
  /** Texto opcional debajo del badge (justificación corta de `parcial`/`pendiente`). */
  detalle?: string;
}

const { estado, detalle } = Astro.props;

const LABELS: Record<Props['estado'], string> = {
  completo: 'Completo',
  parcial: 'Parcial',
  pendiente: 'Pendiente',
  no_aplica: 'No aplica',
};
---

<span class:list={['estado-badge', `estado-badge--${estado.replace('_', '-')}`]}>
  <span class="estado-badge__dot" aria-hidden="true"></span>
  <span class="estado-badge__label">{LABELS[estado]}</span>
  {detalle && <span class="estado-badge__detalle"> — {detalle}</span>}
</span>

<style>
  .estado-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.02em;
    padding: 0.12em 0.38em;
    border-radius: 2px;
    white-space: nowrap;
  }

  .estado-badge__dot {
    flex-shrink: 0;
    inline-size: 0.5em;
    block-size: 0.5em;
    margin-top: 0.08em;
    border-radius: 50%;
    background: currentColor;
  }

  .estado-badge__label {
    text-transform: none;
    line-height: 1.2;
  }

  .estado-badge__detalle {
    font-weight: 400;
    color: var(--color-fg-muted, var(--color-fg));
    opacity: 0.85;
    white-space: normal;
    line-height: 1.2;
  }

  /* Estados ---------------------------------------------------------------- */

  .estado-badge--completo {
    color: var(--color-acreditado);
    background: var(--color-acreditado-bg, #eef4ef);
  }

  .estado-badge--parcial {
    color: var(--color-accent-secondary-text);
    background: var(--color-accent-secondary-soft, #f7ecc5);
  }

  .estado-badge--pendiente {
    color: var(--color-rol-investigado);
    background: var(--color-investigado-bg, #f7f0dd);
  }

  .estado-badge--no-aplica {
    color: var(--color-fg-muted, #6c6f73);
    background: var(--color-desmentido-bg, #f0f0f0);
  }
  /* El tema oscuro se resuelve por tokens dark-aware (--color-acreditado,
     --color-accent-secondary-text, --color-rol-investigado, --color-fg-muted):
     no hace falta un bloque dark específico aquí. */
</style>
