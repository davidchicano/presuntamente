---
// StackedBar — barra de composición 100% horizontal con leyenda. Generada en
// build (HTML + CSS). Pensada para "de qué se compone el total": niveles de
// fuente N1–N4, madurez del inventario, estado epistémico de los hechos.
//
// Accesible: la leyenda lista cada segmento con su valor y porcentaje en texto;
// la barra es decorativa (aria-hidden). El reveal lo coordina la isla de
// PgGraficas (data-reveal + html[data-charts-armed]).

export interface StackSegment {
  label: string;
  value: number;
  /** Color CSS del segmento (token var(--…) o hex). */
  color: string;
  /** Color del texto del swatch si el fondo es claro (opcional). */
  fg?: string;
  /** Si se pasa, segmento y leyenda abren el panel de referencia (drill-down). */
  refKey?: string;
}

interface Props {
  segments: StackSegment[];
  ariaLabel: string;
  /** Leyenda: 'full' (etiqueta + nº + %), 'min' (etiqueta + nº), 'none'. */
  legend?: 'full' | 'min' | 'none';
}

const { segments, ariaLabel, legend = 'full' } = Astro.props;
const total = Math.max(1, segments.reduce((a, s) => a + s.value, 0));
const pct = (v: number) => (v / total) * 100;
const fmtPct = (v: number) => {
  const p = pct(v);
  return p > 0 && p < 1 ? '<1%' : `${Math.round(p)}%`;
};
const visible = segments.filter((s) => s.value > 0);
---

<figure class="chart chart--stacked" data-reveal role="group" aria-label={ariaLabel}>
  <div class="stacked-track" aria-hidden="true">
    {visible.map((s, i) => (
      <div
        class:list={['stacked-seg', s.refKey && 'is-clickable']}
        style={`--seg-w:${pct(s.value)}%;--seg-c:${s.color};--i:${i};`}
        title={`${s.label}: ${s.value} (${fmtPct(s.value)})`}
        data-sheet={s.refKey}
      ></div>
    ))}
  </div>
  {legend !== 'none' && (
    <ul class="stacked-legend">
      {visible.map((s) => (
        <li
          class:list={['stacked-legend__item', s.refKey && 'is-clickable']}
          data-sheet={s.refKey}
          role={s.refKey ? 'button' : undefined}
          tabindex={s.refKey ? 0 : undefined}
        >
          <span class="stacked-legend__swatch" style={`background:${s.color};`} aria-hidden="true"></span>
          <span class="stacked-legend__label">{s.label}</span>
          <span class="stacked-legend__val">{legend === 'full' ? `${s.value} · ${fmtPct(s.value)}` : s.value}</span>
        </li>
      ))}
    </ul>
  )}
</figure>

<style>
  .chart--stacked { margin: 0; }
  .stacked-track {
    display: flex;
    height: 30px;
    border: 1px solid var(--color-border);
    overflow: hidden;
    background: var(--color-surface-muted);
  }
  .stacked-seg {
    width: var(--seg-w);
    background: var(--seg-c);
    border-right: 1px solid color-mix(in srgb, var(--color-fg) 14%, transparent);
  }
  .stacked-seg:last-child { border-right: 0; }

  .stacked-legend {
    list-style: none;
    margin: var(--space-3) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 18px;
  }
  .stacked-legend__item {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font: 400 12.5px/1.3 var(--font-sans);
    color: var(--color-fg);
  }
  .stacked-legend__swatch {
    width: 11px;
    height: 11px;
    border: 1px solid color-mix(in srgb, var(--color-fg) 18%, transparent);
    flex: none;
  }
  .stacked-legend__label { font-weight: 600; }
  .stacked-legend__val {
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--color-fg-muted);
    font-variant-numeric: tabular-nums;
  }

  /* Drill-down: segmento y leyenda clicables. */
  .stacked-seg.is-clickable { cursor: pointer; }
  .stacked-seg.is-clickable:hover { filter: brightness(0.92); }
  .stacked-legend__item.is-clickable { cursor: pointer; }
  .stacked-legend__item.is-clickable::after {
    content: '›';
    color: var(--color-fg-subtle);
    font-weight: 600;
  }
  .stacked-legend__item.is-clickable:hover .stacked-legend__label {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .stacked-legend__item.is-clickable:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* Reveal: la barra crece de izquierda a derecha (scaleX) una sola vez. */
  :global(html[data-charts-armed]) .chart--stacked[data-reveal]:not([data-revealed]) .stacked-track {
    transform: scaleX(0);
    transform-origin: left center;
  }
  .chart--stacked[data-reveal][data-revealed] .stacked-track {
    transform: scaleX(1);
    transform-origin: left center;
    transition: transform 0.6s var(--motion-ease);
  }
</style>
