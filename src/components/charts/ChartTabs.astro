---
// ChartTabs — contenedor de pestañas para alternar datasets de un mismo tipo de
// gráfica (p. ej. tiempo: hitos / casos / imputaciones por año). Mobile-first:
// la fila de pestañas hace scroll horizontal si no caben.
//
// El consumidor pasa los paneles como hijos directos, cada uno marcado con
// `data-ctab-panel="<id>"` y todos salvo el primero con `hidden`:
//
//   <ChartTabs tabs={[{id:'hitos',label:'Hitos'},{id:'casos',label:'Casos'}]} ariaLabel="…">
//     <div data-ctab-panel="hitos"><TimelineColumns … /></div>
//     <div data-ctab-panel="casos" hidden><TimelineColumns … /></div>
//   </ChartTabs>
//
// (Astro no admite <slot name> dinámico, de ahí el patrón con slot por defecto.)

export interface ChartTab {
  id: string;
  label: string;
}

interface Props {
  tabs: ChartTab[];
  ariaLabel: string;
}

const { tabs, ariaLabel } = Astro.props;
---

<div class="ctabs" data-ctabs>
  <div class="ctabs__list" role="tablist" aria-label={ariaLabel}>
    {tabs.map((t, i) => (
      <button
        type="button"
        class="ctabs__tab"
        role="tab"
        aria-selected={i === 0 ? 'true' : 'false'}
        tabindex={i === 0 ? '0' : '-1'}
        data-ctab={t.id}
      >{t.label}</button>
    ))}
  </div>
  <slot />
</div>

<script>
  // Singleton para todos los [data-ctabs]. Click o flechas cambian de pestaña;
  // al mostrar un panel, se revelan sus gráficas (estaban ocultas y no habían
  // disparado el IntersectionObserver).
  function __initChartTabs() {
    if ((window as any).__chartTabsInit) return;
    (window as any).__chartTabsInit = true;

    const armed = () => document.documentElement.hasAttribute('data-charts-armed');

    function activate(root: Element, id: string) {
      root.querySelectorAll<HTMLButtonElement>('[data-ctab]').forEach((t) => {
        const on = t.dataset.ctab === id;
        t.setAttribute('aria-selected', on ? 'true' : 'false');
        t.tabIndex = on ? 0 : -1;
      });
      root.querySelectorAll<HTMLElement>('[data-ctab-panel]').forEach((p) => {
        const on = p.dataset.ctabPanel === id;
        p.hidden = !on;
        if (on && armed()) {
          p.querySelectorAll('[data-reveal]:not([data-revealed])').forEach((el) =>
            el.setAttribute('data-revealed', ''),
          );
        }
      });
    }

    document.addEventListener('click', (e) => {
      const target = e.target;
      if (!(target instanceof Element)) return;
      const tab = target.closest<HTMLButtonElement>('[data-ctab]');
      if (!tab) return;
      const root = tab.closest('[data-ctabs]');
      if (!root) return;
      activate(root, tab.dataset.ctab ?? '');
      tab.focus();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
      const target = e.target;
      if (!(target instanceof Element)) return;
      const tab = target.closest<HTMLButtonElement>('[data-ctab]');
      if (!tab) return;
      const root = tab.closest('[data-ctabs]');
      if (!root) return;
      const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-ctab]'));
      const idx = tabs.indexOf(tab);
      const next = e.key === 'ArrowRight' ? (idx + 1) % tabs.length : (idx - 1 + tabs.length) % tabs.length;
      e.preventDefault();
      activate(root, tabs[next].dataset.ctab ?? '');
      tabs[next].focus();
    });
  }
  __initChartTabs();
  document.addEventListener('astro:page-load', __initChartTabs);
</script>

<style>
  .ctabs { margin: 0; }
  .ctabs__list {
    display: flex;
    gap: 4px;
    overflow-x: auto;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-4);
    scrollbar-width: thin;
  }
  .ctabs__tab {
    flex: 0 0 auto;
    appearance: none;
    background: transparent;
    border: 0;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    padding: 8px 12px;
    font: 600 13px/1.2 var(--font-sans);
    color: var(--color-fg-muted);
    cursor: pointer;
    white-space: nowrap;
    transition: color 140ms ease-out, border-color 140ms ease-out;
  }
  .ctabs__tab:hover { color: var(--color-fg); }
  .ctabs__tab[aria-selected='true'] {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  .ctabs__tab:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }
</style>
