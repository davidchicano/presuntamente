---
// PersonaCard — card de persona dentro de una ficha de caso.
// Distinguible de OrgCard a primera vista: iniciales en cuadrado a la
// izquierda (la marca visual de Persona, ver DESIGN.md — "Component Stylings").
// El swimlane de trayectoria queda fuera del MVP de este lote (lo añade el
// Lote 4 con la ficha individual de Persona); aquí mostramos rol activo +
// metadata.
//
// El border-left de la card refleja el color del **rol más reciente** de
// esta persona en el caso: activo (sin fecha_fin) si existe; si no, el de
// fecha_inicio más reciente. Esto da una lectura inmediata del "estado
// actual" de cada persona en la sección de implicados, alineada con los
// tokens --color-rol-* del sistema de badges (DESIGN.md — "Sistema de badges").

import RolBadge from './RolBadge.astro';
import SourceLinkBadge from './SourceLinkBadge.astro';

interface RolView {
  rol: string;
  rolLabel: string;
  fecha_inicio: string;
  fecha_fin?: string;
  delitos?: string[];
}

interface RelacionView {
  naturalezaLabel: string;
  entidadLabel: string;
  entidadHref?: string;
  descripcion: string;
  periodo: string;
  documentoHref?: string;
}

interface Props {
  nombre: string;
  cargo?: string;
  esFiguraPublica: boolean;
  iniciales: string;
  href?: string;
  roles: RolView[];
  relaciones?: RelacionView[];
  notas?: string;
}

const { nombre, cargo, esFiguraPublica, iniciales, href, roles, relaciones = [], notas } = Astro.props;

// Rol más reciente: activos primero (sin fecha_fin), luego por fecha_inicio
// descendente. Si no hay roles, fallback a navy (--color-accent) vía el
// fallback en CSS.
function rolMasReciente(rs: RolView[]): string | null {
  if (rs.length === 0) return null;
  const activos = rs.filter((r) => !r.fecha_fin);
  const pool = activos.length > 0 ? activos : rs;
  return [...pool].sort((a, b) => b.fecha_inicio.localeCompare(a.fecha_inicio))[0].rol;
}
const rolReciente = rolMasReciente(roles);

// Roles ordenados para mostrar en la card: vigentes primero (por
// fecha_inicio descendente), cerrados después (por fecha_fin descendente).
// El primero de la lista es el "más reciente", coincide con el que pinta
// el border-left de la card. Visualmente los no-primeros se atenúan para
// que se lean como "anteriores" sin perder la información (decisión
// 2026-05-27: el lector veía un orden cronológico ASC que no destacaba el
// estado actual).
const rolesOrdenados = [...roles].sort((a, b) => {
  const aVig = a.fecha_fin ? 0 : 1;
  const bVig = b.fecha_fin ? 0 : 1;
  if (aVig !== bVig) return bVig - aVig;
  if (!a.fecha_fin && !b.fecha_fin) {
    return b.fecha_inicio.localeCompare(a.fecha_inicio);
  }
  const aRef = a.fecha_fin ?? a.fecha_inicio;
  const bRef = b.fecha_fin ?? b.fecha_inicio;
  return bRef.localeCompare(aRef);
});
---
<article class:list={['pcard', rolReciente && `pcard--rol-${rolReciente}`]}>
  <div class="pcard__init" aria-hidden="true">{iniciales}</div>
  <div class="pcard__body">
    <h4 class="pcard__name">
      {href ? <a href={href}>{nombre}</a> : nombre}
    </h4>
    <p class="pcard__meta">
      {cargo && <span>{cargo}</span>}
      {cargo && <span class="pcard__sep">·</span>}
      <span>{esFiguraPublica ? 'Figura pública' : 'Privado'}</span>
    </p>
    <ul class="pcard__roles">
      {rolesOrdenados.map((r) => (
        <li class:list={['pcard__role', r.fecha_fin && 'pcard__role--anterior']}>
          <RolBadge rol={r.rol} label={r.rolLabel} />
          <span class="pcard__role-dates">
            {r.fecha_inicio}
            {r.fecha_fin ? ` → ${r.fecha_fin}` : ' → vigente'}
          </span>
          {r.delitos && r.delitos.length > 0 && (
            <span class="pcard__delitos">
              {r.delitos.map((d) => <span class="pcard__delito">{d}</span>)}
            </span>
          )}
        </li>
      ))}
    </ul>
    {relaciones.length > 0 && (
      <div class="pcard__relaciones">
        <ul>
          {relaciones.map((rel) => (
            <li>
              <SourceLinkBadge label={rel.naturalezaLabel} href={rel.documentoHref} />
              <span class="pcard__relacion-body">
                {rel.entidadHref ? <a href={rel.entidadHref}>{rel.entidadLabel}</a> : <span>{rel.entidadLabel}</span>}
                <span class="pcard__relacion-date">{rel.periodo}</span>
                <span class="pcard__relacion-desc">{rel.descripcion}</span>
              </span>
            </li>
          ))}
        </ul>
      </div>
    )}
    {notas && <p class="pcard__notas">{notas}</p>}
  </div>
</article>

<style>
  .pcard {
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--pcard-rol, var(--color-accent));
    background: var(--color-surface);
    padding: 14px 16px;
    display: grid;
    grid-template-columns: 44px 1fr;
    gap: 14px;
    transition: border-left-width 160ms ease-out, background 160ms ease-out;
  }
  .pcard:hover {
    border-left-width: 5px;
    background: var(--color-bg-muted);
  }
  /* Color del border-left por rol más reciente. Reusa los tokens del sistema
   * de badges ([DESIGN.md → "Sistema de badges"](../../DESIGN.md#2bis-sistema-de-badges)) para coherencia con los RolBadge dentro de
   * la card. */
  .pcard--rol-investigado        { --pcard-rol: var(--color-rol-investigado); }
  .pcard--rol-procesado          { --pcard-rol: var(--color-rol-procesado); }
  .pcard--rol-acusado            { --pcard-rol: var(--color-rol-acusado); }
  .pcard--rol-condenado_no_firme { --pcard-rol: var(--color-rol-condenado-no-firme); }
  .pcard--rol-condenado_firme    { --pcard-rol: var(--color-rol-condenado-firme); }
  .pcard--rol-absuelto           { --pcard-rol: var(--color-rol-absuelto); }
  .pcard--rol-desimputado        { --pcard-rol: var(--color-rol-desimputado); }
  .pcard--rol-testigo            { --pcard-rol: var(--color-rol-testigo); }
  .pcard--rol-juez_instructor,
  .pcard--rol-juez_ponente,
  .pcard--rol-fiscal,
  .pcard--rol-magistrado,
  .pcard--rol-abogado_defensa,
  .pcard--rol-abogado_acusacion,
  .pcard--rol-perito_judicial,
  .pcard--rol-perito_parte,
  .pcard--rol-secretario_judicial { --pcard-rol: var(--color-rol-aparato); }
  .pcard--rol-denunciante,
  .pcard--rol-querellante,
  .pcard--rol-acusacion_particular,
  .pcard--rol-acusacion_popular,
  .pcard--rol-perjudicado        { --pcard-rol: var(--color-rol-acusacion-civil); }
  .pcard__init {
    width: 44px;
    height: 44px;
    background: var(--color-accent-soft);
    border: 1px solid var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font: 700 16px/1 var(--font-sans);
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
  }
  .pcard__name {
    font: 700 16px/1.2 var(--font-sans);
    margin: 0 0 4px;
    letter-spacing: -0.005em;
  }
  .pcard__name a { color: inherit; text-decoration: none; }
  .pcard__name a:hover { text-decoration: underline; }
  .pcard__meta {
    font: 400 12px/1.4 var(--font-sans);
    color: var(--color-fg-muted);
    margin: 0 0 10px;
  }
  .pcard__sep { color: var(--color-border); margin: 0 6px; }
  .pcard__roles {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .pcard__role {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }
  /* Los roles cerrados (fecha_fin presente) se ven debajo del rol vigente
     más reciente y bajan ligeramente de jerarquía visual: badge atenuado
     + fecha en cursiva. Pintamos así para que el "estado actual" de la
     persona sea lo primero que se lea en la card, y el histórico quede
     accesible pero secundario. */
  .pcard__role--anterior {
    opacity: 0.65;
  }
  .pcard__role--anterior .pcard__role-dates {
    font-style: italic;
  }
  .pcard__role-dates {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-fg-muted);
  }
  .pcard__delitos { display: inline-flex; flex-wrap: wrap; gap: 4px; }
  .pcard__delito {
    font: 400 10px/1 var(--font-mono);
    background: var(--color-surface-muted);
    color: var(--color-fg-muted);
    padding: 2px 5px;
    border: 1px solid var(--color-border);
  }
  .pcard__relaciones {
    margin-top: 12px;
    padding-top: 10px;
    border-top: 1px solid var(--color-border);
  }
  .pcard__relaciones ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 7px;
  }
  .pcard__relaciones li {
    display: flex;
    flex-wrap: wrap;
    gap: 7px 10px;
    align-items: flex-start;
  }
  .pcard__relacion-body {
    display: grid;
    gap: 2px;
    font: 400 12px/1.45 var(--font-sans);
    color: var(--color-fg-muted);
  }
  .pcard__relacion-body a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .pcard__relacion-date {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--color-fg-subtle);
  }
  .pcard__relacion-desc {
    color: var(--color-fg-muted);
  }
  .pcard__notas {
    margin: 10px 0 0;
    padding-top: 8px;
    border-top: 1px dashed var(--color-border);
    font: 400 12px/1.5 var(--font-sans);
    color: var(--color-fg-muted);
  }
</style>
