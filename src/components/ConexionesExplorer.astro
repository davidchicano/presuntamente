---
import type { GraphPayload } from '@/lib/conexiones';
import Aclaracion from '@/components/Aclaracion.astro';
import MultiSelectFilter from '@/components/MultiSelectFilter.astro';

interface Props {
  graph: GraphPayload;
}

const { graph } = Astro.props;
const json = JSON.stringify(graph).replace(/</g, '\\u003c');
const nodesByKind = {
  caso: graph.nodes.filter((n) => n.kind === 'caso'),
  persona: graph.nodes.filter((n) => n.kind === 'persona'),
  organizacion: graph.nodes.filter((n) => n.kind === 'organizacion'),
  documento: graph.nodes.filter((n) => n.kind === 'documento'),
};
---

<section class="graph-explorer" data-graph-root>
  <script is:inline type="application/json" data-graph-data set:html={json}></script>

  <div class="graph-stage">
    <div class="graph-canvas" data-graph-canvas aria-label="Grafo de conexiones y relaciones"></div>
  </div>

  <form class="graph-panel graph-panel--controls" data-graph-form aria-label="Controles del grafo">
    <div class="graph-panel__head">
      <div class="graph-panel__title-block">
        <p class="graph-panel__eyebrow">Grafo de conexiones y relaciones</p>
        <div class="graph-panel__title-row">
          <h1>Explorador de Conexiones</h1>
          <div class="graph-panel__stats" aria-label="Resumen visible">
            <span><strong data-graph-node-count>{graph.stats.casos + graph.stats.personas + graph.stats.organizaciones}</strong> nodos</span>
            <span><strong data-graph-visible-count>0</strong> relaciones</span>
          </div>
        </div>
      </div>
      <button
        type="button"
        class="graph-panel__collapse"
        data-graph-toggle-controls
        aria-expanded="true"
        aria-controls="graph-controls-body graph-filter-summary"
        aria-label="Minimizar controles del grafo"
      >
        <span data-graph-toggle-label>Minimizar</span>
      </button>
    </div>

    <div
      class="graph-panel__summary"
      id="graph-filter-summary"
      data-graph-filter-summary
      hidden
      aria-live="polite"
    ></div>

    <div class="graph-panel__body" id="graph-controls-body" data-graph-controls-body>
    <div class="graph-fields">
      <div class="field">
        <label for="graph-focus-type">Vista</label>
        <select id="graph-focus-type" name="focus" class="graph-native-select" data-graph-focus-type data-graph-select>
          <option value="inventario">Inventario completo</option>
          <option value="caso">Caso</option>
          <option value="persona">Persona</option>
          <option value="organizacion">Organización</option>
          <option value="documento">Documento</option>
        </select>
      </div>
      <div class="field field--wide">
        <label for="graph-focus-id">Foco</label>
        <div class="graph-focus-pickers" data-graph-focus-pickers>
          <div data-graph-focus-picker="caso" hidden>
            <MultiSelectFilter
              id="graph-focus-id"
              name="id_caso"
              options={nodesByKind.caso.map((node) => ({
                value: node.rawId,
                label: node.label,
                ...(node.sublabel ? { sublabel: node.sublabel } : {}),
              }))}
              placeholder="Seleccionar casos"
              ariaLabel="Seleccionar uno o varios casos"
              searchPlaceholder="Buscar caso…"
            />
          </div>
          <div data-graph-focus-picker="persona" hidden>
            <MultiSelectFilter
              id="graph-focus-persona"
              name="id_persona"
              options={nodesByKind.persona.map((node) => ({
                value: node.rawId,
                label: node.label,
                ...(node.sublabel ? { sublabel: node.sublabel } : {}),
              }))}
              placeholder="Seleccionar personas"
              ariaLabel="Seleccionar una o varias personas"
              searchPlaceholder="Buscar persona…"
            />
          </div>
          <div data-graph-focus-picker="organizacion" hidden>
            <MultiSelectFilter
              id="graph-focus-organizacion"
              name="id_organizacion"
              options={nodesByKind.organizacion.map((node) => ({
                value: node.rawId,
                label: node.label,
                ...(node.sublabel ? { sublabel: node.sublabel } : {}),
              }))}
              placeholder="Seleccionar organizaciones"
              ariaLabel="Seleccionar una o varias organizaciones"
              searchPlaceholder="Buscar organización…"
            />
          </div>
          <div data-graph-focus-picker="documento" hidden>
            <MultiSelectFilter
              id="graph-focus-documento"
              name="id_documento"
              options={nodesByKind.documento.map((node) => ({
                value: node.rawId,
                label: node.label,
                ...(node.sublabel ? { sublabel: node.sublabel } : {}),
              }))}
              placeholder="Seleccionar documentos"
              ariaLabel="Seleccionar uno o varios documentos"
              searchPlaceholder="Buscar documento…"
            />
          </div>
          <p class="graph-focus-pickers__all" data-graph-focus-all>Todo el inventario</p>
        </div>
      </div>
      <div class="field field--depth">
        <label for="graph-depth">Profundidad</label>
        <div class="graph-range-control graph-range-control--depth">
          <input id="graph-depth" name="depth" type="range" min="1" max="3" step="1" value="1" data-graph-depth />
          <output for="graph-depth" data-graph-depth-value>1</output>
        </div>
      </div>
      <div class="field field--layout">
        <label id="graph-layout-label" for="graph-layout" title="Cómo se disponen los nodos en el lienzo">Disposición</label>
        <select id="graph-layout" name="layout" class="graph-native-select" data-graph-layout>
          <option value="cose">Disposición orgánica</option>
          <option value="breadthfirst">Disposición jerárquica</option>
        </select>
        <div class="graph-layout-toggle" role="radiogroup" aria-labelledby="graph-layout-label">
          <button
            type="button"
            class="graph-layout-option"
            data-graph-layout-choice="cose"
            role="radio"
            aria-checked="true"
            aria-label="Disposición orgánica"
            title="Disposición orgánica"
          >
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="18" cy="5" r="3"></circle>
              <circle cx="6" cy="12" r="3"></circle>
              <circle cx="18" cy="19" r="3"></circle>
              <line x1="8.59" x2="15.42" y1="13.51" y2="17.49"></line>
              <line x1="15.41" x2="8.59" y1="6.51" y2="10.49"></line>
            </svg>
          </button>
          <button
            type="button"
            class="graph-layout-option"
            data-graph-layout-choice="breadthfirst"
            role="radio"
            aria-checked="false"
            aria-label="Disposición jerárquica"
            title="Disposición jerárquica"
          >
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="16" y="16" width="6" height="6" rx="1"></rect>
              <rect x="2" y="16" width="6" height="6" rx="1"></rect>
              <rect x="9" y="2" width="6" height="6" rx="1"></rect>
              <path d="M5 16v-3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3"></path>
              <path d="M12 12V8"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <details class="graph-filter-group" open>
      <summary>Relaciones</summary>
      <div class="graph-checks">
        <div class="graph-check-item">
          <label><input type="checkbox" value="procesal" data-edge-kind /> Procesales</label>
          <button
            type="button"
            class="graph-info"
            data-graph-info
            aria-label="Qué significa relación procesal"
            aria-expanded="false"
            aria-controls="graph-info-procesal"
          >i</button>
          <div class="graph-info-popover" id="graph-info-procesal" role="dialog" hidden>
            <span class="graph-info-popover__title">Relación procesal</span>
            <p>Conecta una persona u organización con un caso cuando el modelo recoge un rol formal en el procedimiento: investigado, procesado, acusado, condenado, absuelto, desimputado u otros roles jurídicos equivalentes.</p>
          </div>
        </div>
        <div class="graph-check-item">
          <label><input type="checkbox" value="institucional" data-edge-kind /> Institucionales</label>
          <button
            type="button"
            class="graph-info"
            data-graph-info
            aria-label="Qué significa relación institucional"
            aria-expanded="false"
            aria-controls="graph-info-institucional"
          >i</button>
          <div class="graph-info-popover" id="graph-info-institucional" role="dialog" hidden>
            <span class="graph-info-popover__title">Relación institucional</span>
            <p>Vínculo formal entre entidades del inventario: pertenencia, cargo, órgano, asociación, administración, empresa u otra conexión documentada que ayuda a contextualizar el caso.</p>
          </div>
        </div>
        <div class="graph-check-item">
          <label><input type="checkbox" value="caso_caso" data-edge-kind /> Entre casos</label>
          <button
            type="button"
            class="graph-info"
            data-graph-info
            aria-label="Qué significa relación entre casos"
            aria-expanded="false"
            aria-controls="graph-info-casos"
          >i</button>
          <div class="graph-info-popover" id="graph-info-casos" role="dialog" hidden>
            <span class="graph-info-popover__title">Relación entre casos</span>
            <p>Conexión explícita entre dos casos del inventario: pieza separada, procedimiento relacionado, solapamiento de hechos, personas u órganos, siempre modelado como relación editorial concreta.</p>
          </div>
        </div>
        <div class="graph-check-item">
          <label><input type="checkbox" value="documental" data-edge-kind /> Documentales</label>
          <button
            type="button"
            class="graph-info"
            data-graph-info
            aria-label="Qué significa relación documental"
            aria-expanded="false"
            aria-controls="graph-info-documental"
          >i</button>
          <div class="graph-info-popover" id="graph-info-documental" role="dialog" hidden>
            <span class="graph-info-popover__title">Relación documental</span>
            <p>Enlace hacia documentos que respaldan hitos, hechos o vínculos: autos, sentencias, BOE, notas oficiales, informes o cobertura catalogada. Se ocultan de inicio para no saturar el grafo.</p>
          </div>
        </div>
      </div>
    </details>

    <details class="graph-filter-group" open>
      <summary>Nodos</summary>
      <div class="graph-checks">
        <label><input type="checkbox" value="caso" data-node-kind /> Casos</label>
        <label><input type="checkbox" value="persona" data-node-kind /> Personas</label>
        <label><input type="checkbox" value="organizacion" data-node-kind /> Organizaciones</label>
        <label><input type="checkbox" value="documento" data-node-kind /> Documentos</label>
      </div>
      <div class="graph-tuning">
        <label for="graph-separation">Separación de nodos</label>
        <div class="graph-range-control">
          <input
            id="graph-separation"
            type="range"
            min="0.7"
            max="1.9"
            step="0.1"
            value="1"
            data-graph-separation
          />
          <output for="graph-separation" data-graph-separation-value>1.0x</output>
        </div>
        <p>Aumenta la separación entre nodos para facilitar la lectura cuando hay muchas conexiones.</p>
      </div>
    </details>

    <div class="graph-actions">
      <button type="button" class="btn graph-action-btn" data-graph-fit aria-pressed="false">
        <svg class="graph-action-btn__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <circle cx="12" cy="12" r="6" />
          <path d="M12 2v4M12 18v4M2 12h4M18 12h4" />
        </svg>
        <span data-graph-fit-label>Recentrar</span>
      </button>
      <button type="button" class="btn" data-graph-toggle-table aria-pressed="false">
        <span data-graph-table-label>Ver relaciones</span>
      </button>
      <label class="graph-detail-lock">
        <input type="checkbox" data-graph-suppress-details />
        <span>No mostrar detalle</span>
      </label>
    </div>
    <div class="graph-utilities">
      <button type="button" class="graph-link-action" data-graph-copy>Copiar enlace</button>
      <p class="graph-copy-status" data-graph-copy-status aria-live="polite"></p>
    </div>
    </div>
  </form>

  <aside class="graph-panel graph-panel--details" aria-label="Detalle de la selección">
    <div class="graph-details__content" data-graph-details>
      <div class="graph-details__head">
        <p class="graph-details__kind">Detalle</p>
        <button
          type="button"
          class="graph-panel__collapse graph-details__close"
          data-graph-close-details
          aria-label="Ocultar panel de detalle"
        >
          Cerrar
        </button>
      </div>
      <h2 class="graph-details__title">Sin selección</h2>
      <p class="graph-details__summary">Selecciona un nodo o una relación para ver sus datos básicos.</p>
    </div>
  </aside>

  <section class="graph-panel graph-panel--table" aria-labelledby="graph-textual-title">
    <div class="graph-panel__head">
      <div>
        <p class="graph-panel__eyebrow">Equivalente textual</p>
        <h2 id="graph-textual-title">Relaciones visibles</h2>
      </div>
      <button type="button" class="btn" data-graph-toggle-table aria-pressed="true">Cerrar relaciones</button>
    </div>
    <div class="tbl-scroll">
      <table class="tbl">
        <thead>
          <tr>
            <th style="width: 14%;">Tipo</th>
            <th style="width: 28%;">Origen</th>
            <th style="width: 22%;">Relación</th>
            <th style="width: 28%;">Destino</th>
            <th style="width: 8%;">Fecha</th>
          </tr>
        </thead>
        <tbody data-graph-table-body></tbody>
      </table>
    </div>
  </section>

  <div class="graph-hud">
    <div class="graph-zoom" data-graph-zoom aria-label="Zoom del grafo">
      <button type="button" class="graph-zoom__btn" data-graph-zoom-in aria-label="Acercar">+</button>
      <input
        type="range"
        class="graph-zoom__slider"
        data-graph-zoom-slider
        min="0.18"
        max="3"
        step="0.02"
        value="1"
        aria-label="Nivel de zoom"
        aria-valuemin="0.18"
        aria-valuemax="3"
      />
      <button type="button" class="graph-zoom__btn" data-graph-zoom-out aria-label="Alejar">−</button>
    </div>

    <div class="graph-legend" aria-label="Leyenda del grafo">
      <span><i class="dot dot--caso"></i> Caso</span>
      <span><i class="dot dot--persona"></i> Persona</span>
      <span><i class="dot dot--org"></i> Organización</span>
      <span><i class="dot dot--doc"></i> Documento</span>
    </div>
  </div>

  <noscript>
    <Aclaracion nivel="media">El explorador de conexiones requiere JavaScript activado. Para navegar el inventario sin JavaScript, consulta el listado de casos, personas y organizaciones desde el menú principal.</Aclaracion>
  </noscript>
</section>

<style>
  .graph-explorer {
    position: relative;
    width: 100vw;
    height: calc(100dvh - 72px);
    min-height: 560px;
    margin: calc(-1 * var(--space-5)) calc(50% - 50vw) calc(-1 * var(--space-7));
    overflow: hidden;
    background:
      radial-gradient(circle at center, color-mix(in srgb, var(--color-accent) 9%, transparent) 0 1px, transparent 1.4px),
      linear-gradient(180deg, var(--color-bg), color-mix(in srgb, var(--color-accent-soft) 28%, var(--color-bg)));
    background-size: 22px 22px, auto;
  }

  .graph-stage {
    position: absolute;
    inset: 0;
  }

  .graph-canvas {
    width: 100%;
    height: 100%;
    min-height: 100%;
  }

  .graph-panel {
    position: absolute;
    z-index: 2;
    border: 1px solid color-mix(in srgb, var(--color-border) 86%, transparent);
    background: color-mix(in srgb, var(--color-surface) 91%, transparent);
    box-shadow: 0 10px 32px rgba(15, 23, 42, 0.12);
    backdrop-filter: blur(12px);
  }

  .graph-panel--controls {
    top: 18px;
    left: 18px;
    width: min(620px, calc(100vw - 36px));
    min-width: 320px;
    max-width: calc(100vw - 36px);
    max-height: calc(100dvh - 108px);
    box-sizing: border-box;
    container-type: inline-size;
    display: grid;
    gap: 12px;
    padding: 14px;
    overflow-x: hidden;
    overflow-y: auto;
    opacity: 0.46;
    resize: both;
    transition:
      opacity 160ms ease,
      background 160ms ease,
      box-shadow 160ms ease;
  }

  .graph-panel--controls:hover,
  .graph-panel--controls:focus-within {
    opacity: 1;
    background: color-mix(in srgb, var(--color-surface) 95%, transparent);
    box-shadow: 0 14px 38px rgba(15, 23, 42, 0.16);
  }

  .graph-explorer[data-controls-minimized] .graph-panel--controls {
    width: min(320px, calc(100vw - 36px));
    gap: 0;
    opacity: 0.34;
    resize: none;
  }

  .graph-panel__head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: start;
    gap: 8px;
  }

  .graph-panel__title-block {
    min-width: 0;
  }

  .graph-panel__title-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 8px 14px;
  }

  .graph-panel__title-row h1 {
    margin: 0;
  }

  /* :global — también en HTML inyectado por renderDetails (sin scope Astro). */
  :global(.graph-panel__collapse) {
    align-self: start;
    margin: -6px -8px 0 0;
    padding: 0;
    border: 0;
    border-radius: 0;
    appearance: none;
    background: transparent;
    color: var(--color-fg-muted);
    cursor: pointer;
    font: 500 var(--font-size-0)/1.2 var(--font-sans);
    text-decoration: none;
    white-space: nowrap;
    box-shadow: none;
  }

  :global(.graph-panel__collapse:hover),
  :global(.graph-panel__collapse:focus-visible) {
    color: var(--color-accent);
    background: transparent;
    outline: none;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .graph-panel__body {
    display: grid;
    gap: 12px;
  }

  .graph-explorer[data-controls-minimized] .graph-panel__body {
    display: none;
  }

  .graph-panel__summary {
    display: none;
    margin-top: 4px;
    padding-top: 6px;
    border-top: 1px solid color-mix(in srgb, var(--color-border) 76%, transparent);
  }

  .graph-explorer[data-controls-minimized] .graph-panel__summary {
    display: block;
  }

  :global(.graph-panel__summary-line) {
    margin: 0;
    color: var(--color-fg-muted);
    font-size: 11px;
    line-height: 1.3;
    overflow-wrap: anywhere;
  }

  :global(.graph-panel__summary-line + .graph-panel__summary-line) {
    margin-top: 3px;
  }

  .graph-panel__eyebrow {
    margin: 0 0 2px;
    color: var(--color-accent-secondary-hover);
    font: 700 11px/1 var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0;
  }

  .graph-panel h1,
  .graph-panel h2 {
    margin: 0;
    font: 700 var(--font-size-4)/1.05 var(--font-sans);
    letter-spacing: 0;
  }

  .graph-panel__stats {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 8px 12px;
    min-width: 0;
    color: var(--color-fg-muted);
    font-size: var(--font-size-0);
  }

  .graph-panel__stats strong {
    color: var(--color-accent);
    font-family: var(--font-mono);
  }

  .graph-fields {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(148px, 100%), 1fr));
    gap: 8px;
  }

  .graph-fields .field--wide {
    grid-column: span 2;
  }

  .graph-fields .field {
    min-width: 0;
  }

  .graph-fields .field label {
    font-size: 11px;
  }

  .graph-range-control {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 7px;
    min-height: 26px;
  }

  .graph-range-control input {
    width: 100%;
    min-width: 0;
    height: 18px;
    accent-color: var(--color-accent);
    cursor: pointer;
  }

  .graph-range-control input:disabled {
    cursor: not-allowed;
    opacity: 0.42;
  }

  .graph-range-control output {
    display: grid;
    place-items: center;
    min-width: 26px;
    height: 20px;
    color: var(--color-accent);
    font: 700 11px/1 var(--font-mono);
  }

  .graph-range-control--depth {
    padding-top: 2px;
  }

  .graph-layout-toggle {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 28px;
    border: 1px solid var(--color-border-strong);
    background: color-mix(in srgb, var(--color-surface) 96%, transparent);
  }

  .graph-layout-option {
    display: grid;
    place-items: center;
    min-width: 0;
    min-height: 26px;
    padding: 4px;
    border: 0;
    border-right: 1px solid var(--color-border);
    border-radius: 0;
    background: transparent;
    color: var(--color-fg-muted);
    cursor: pointer;
  }

  .graph-layout-option:last-child {
    border-right: 0;
  }

  .graph-layout-option[aria-checked="true"] {
    background: var(--color-accent);
    color: var(--color-surface);
  }

  .graph-layout-option:hover,
  .graph-layout-option:focus-visible {
    color: var(--color-accent);
    outline: none;
  }

  .graph-layout-option[aria-checked="true"]:hover,
  .graph-layout-option[aria-checked="true"]:focus-visible {
    color: var(--color-surface);
  }

  .graph-layout-option svg {
    width: 15px;
    height: 15px;
    pointer-events: none;
  }

  :global(.graph-native-select) {
    position: absolute;
    width: 1px;
    height: 1px;
    min-width: 1px;
    min-height: 1px;
    opacity: 0;
    overflow: hidden;
    pointer-events: none;
  }

  :global(.gsel) {
    position: relative;
    min-width: 0;
  }

  :global(.gsel__trigger) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    width: 100%;
    min-height: 36px;
    padding: 7px 10px;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-1);
    background: color-mix(in srgb, var(--color-surface) 96%, transparent);
    color: var(--color-fg);
    cursor: pointer;
    font: 600 12px/1.25 var(--font-sans);
    text-align: left;
    transition:
      border-color 150ms ease,
      background 150ms ease,
      box-shadow 150ms ease;
  }

  :global(.gsel__trigger:focus-visible) {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-accent) 16%, transparent);
    outline: none;
  }

  :global(.gsel--open .gsel__trigger),
  :global(.gsel__trigger[aria-expanded="true"]) {
