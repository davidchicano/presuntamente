---
// Hecho — card de afirmación verificable.
// Regla P-02: cada Hecho lleva su(s) fuente(s) y nivel **visibles en línea**,
// no escondidos. El estado epistémico se transmite con el EpistemicBadge y el
// borde fino del contenedor, sin barra lateral gruesa.

import EpistemicBadge from './EpistemicBadge.astro';
import LevelBadge from './LevelBadge.astro';
import RichProse from './RichProse.astro';

interface Fuente {
  nivel: 1 | 2 | 3 | 4;
  titulo: string;
  href?: string;
  pasaje?: string;
}

interface Props {
  tipo: 'acreditado' | 'investigado' | 'atribuido' | 'exculpatorio' | 'desmentido' | 'no_concluyente';
  enunciado: string;
  fechaTexto?: string;
  fuentes: Fuente[];
  excludeOrgIds?: string[];
  excludePersonaIds?: string[];
  /** id de ancla (#hecho-<slug>). Va en el <article> real, no en el wrapper
   *  `display:contents`, para que la navegación por fragmento aterrice aquí. */
  id?: string;
}

const { tipo, enunciado, fechaTexto, fuentes, excludeOrgIds, excludePersonaIds, id } = Astro.props;
---
<article class:list={['hecho', `hecho--${tipo}`]} id={id}>
  <header class="hecho__head">
    <EpistemicBadge tipo={tipo} />
    {fechaTexto && <span class="hecho__date">{fechaTexto}</span>}
  </header>
  <RichProse
    text={enunciado}
    class="hecho__text"
    excludeOrgIds={excludeOrgIds}
    excludePersonaIds={excludePersonaIds}
  />
  <ul class="hecho__sources">
    {fuentes.map((f) => (
      <li class="hecho__source">
        <LevelBadge nivel={f.nivel} />
        {f.href ? (
          <a href={f.href}>{f.titulo}</a>
        ) : (
          <span>{f.titulo}</span>
        )}
        {f.pasaje && <span class="hecho__pasaje">{f.pasaje}</span>}
      </li>
    ))}
  </ul>
</article>

<style>
  .hecho {
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 14px 16px;
    transition:
      background 200ms ease-out,
      transform 200ms ease-out;
  }
  .hecho:hover {
    background: color-mix(in srgb, var(--color-surface) 92%, var(--color-accent-secondary-soft));
    transform: translateX(-2px);
  }
  .hecho--acreditado    { border-color: var(--color-acreditado-border); }
  .hecho--investigado   { border-color: var(--color-investigado-border); }
  .hecho--atribuido     { border-color: var(--color-investigado-border); }
  .hecho--exculpatorio  { border-color: var(--color-exculpatorio-border); }
  .hecho--desmentido    { border-color: var(--color-desmentido-border); }
  .hecho--no_concluyente{ border-color: var(--color-desmentido-border); }
  @media (prefers-reduced-motion: reduce) {
    .hecho { transition: none; }
    .hecho:hover { transform: none; }
  }

  .hecho__head {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 8px;
  }
  .hecho__date {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-fg-muted);
  }
  .hecho__text {
    font: 400 15px/1.6 var(--font-sans);
    color: var(--color-fg);
    margin: 0 0 10px;
  }
  .hecho__sources {
    list-style: none;
    padding: 8px 0 0;
    margin: 0;
    border-top: 1px dashed var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .hecho__source {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-fg-muted);
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }
  .hecho__source a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .hecho__pasaje { color: var(--color-fg-subtle); }
</style>
