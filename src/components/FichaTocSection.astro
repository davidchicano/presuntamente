---
// FichaTocSection — bloque numerado de una ficha (caso, persona, org, delito).
// El wrapper data-toc-section existe en el HTML servido para que el ritmo
// vertical no dependa del JS del PageToc ni de márgenes que no colapsan.
//
// Slot nombrado `filters`: si se pasa, se renderiza una fila de chips/pills
// JUSTO DEBAJO del header de la sección (no dentro del <header>). Pensada
// para filtros visuales en línea (estado epistémico, rol procesal, familia
// de hito) usando el componente ChipFilterGroup. Mantiene el slot por
// defecto libre para el contenido de la sección.

import SectionH from '@/components/SectionH.astro';

interface Props {
  num?: string;
  title: string;
  id: string;
  right?: string;
  orderToggle?: boolean;
}

const { num, title, id, right, orderToggle } = Astro.props;
const hasFilters = Astro.slots.has('filters');
// Slot `header-actions`: si se pasa, se reenvía al slot por defecto de SectionH,
// que lo renderiza dentro del propio header sticky de la sección (extremo
// derecho). Útil para conmutadores que deben seguir accesibles tras scroll sin
// duplicar el título de la sección en una barra aparte.
const hasHeaderActions = Astro.slots.has('header-actions');
---
<section class="ficha-toc-section" data-toc-section={id}>
  {hasHeaderActions ? (
    <SectionH {num} {title} {id} {right} {orderToggle}>
      <slot name="header-actions" />
    </SectionH>
  ) : (
    <SectionH {num} {title} {id} {right} {orderToggle} />
  )}
  {hasFilters && (
    <div class="ficha-toc-section__filters" role="region" aria-label="Filtros de la sección">
      <slot name="filters" />
    </div>
  )}
  <slot />
</section>

<style>
  .ficha-toc-section__filters {
    margin: -4px 0 var(--space-3);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px 12px;
  }
</style>
