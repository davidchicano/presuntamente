---
// SectionH — encabezado de sección administrativo numerado.
// Markup canónico en /.claude/skills/presuntamente-design/preview/comp_section_h.html.
// Usa la regla del global.css; este componente sólo asegura la estructura.
//
// `orderToggle`: cuando es true, renderiza un chip "⇅ Más reciente primero"
// en el extremo derecho del header. Al pulsarlo, el listener delegado en
// BaseLayout.astro invierte el orden visual del PRÓXIMO hermano del .sec-h
// (típicamente la `.timeline`, pero también puede ser cualquier contenedor
// que defina su propia regla `.is-reversed { flex-direction: column-reverse }`).
// El header sigue siendo click-to-top: el listener salta clicks que cayeron
// sobre el botón vía el guard de descendientes interactivos.
//
// Slot por defecto (sin nombre): cualquier hijo se renderiza al final del
// header, empujado a la derecha. Pensado para acciones contextuales tipo
// botón "Limpiar filtros" en la sección de Filtros, que va asociada al form
// mediante `form="id-del-form"` para no estar anidada en él.
interface Props {
  num?: string;
  title: string;
  right?: string;
  id?: string;
  orderToggle?: boolean;
}
const { num, title, right, id, orderToggle = false } = Astro.props;
const hasActions = Astro.slots.has('default');
---
<header class="sec-h" id={id}>
  {num && <span class="num">{num}</span>}
  <h2>{title}</h2>
  {right && <span class="right">{right}</span>}
  {orderToggle && (
    <button
      type="button"
      class="sec-h__order"
      data-order="desc"
      aria-pressed="false"
      aria-label="Invertir orden cronológico"
    >
      <span class="sec-h__order-icon" aria-hidden="true">⇅</span>
      <span class="sec-h__order-label">Más reciente primero</span>
    </button>
  )}
  {hasActions && (
    <div class="sec-h__actions">
      <slot />
    </div>
  )}
</header>
