---
// Cite — citación inline visible (no tooltip-hidden).
// Regla P-02 del doc 02 §4: badge de nivel SIEMPRE visible. Renderiza un
// <kbd> compacto con N{nivel} + título corto del documento, opcionalmente
// como link a la ficha del documento.
interface Props {
  nivel: 1 | 2 | 3 | 4;
  titulo: string;
  href?: string;
}
const { nivel, titulo, href } = Astro.props;
const Tag = href ? 'a' : 'span';
---
<Tag class:list={['cite', `cite--n${nivel}`]} href={href}>
  <span class="cite__nivel">N{nivel}</span>
  <span class="cite__sep">·</span>
  <span class="cite__title">{titulo}</span>
</Tag>

<style>
  .cite {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 1px 6px;
    border: 1px solid;
    border-radius: 0;
    font: 600 11px/1.5 var(--font-mono);
    vertical-align: 1px;
    color: inherit;
    text-decoration: none;
  }
  .cite__nivel { font-weight: 700; }
  .cite__sep { opacity: 0.5; }
  .cite--n1 { color: var(--color-nivel-1-fg); background: var(--color-nivel-1-bg); border-color: var(--color-nivel-1-border); }
  .cite--n2 { color: var(--color-nivel-2-fg); background: var(--color-nivel-2-bg); border-color: var(--color-nivel-2-border); }
  .cite--n3 { color: var(--color-nivel-3-fg); background: var(--color-nivel-3-bg); border-color: var(--color-nivel-3-border); }
  .cite--n4 { color: var(--color-nivel-4-fg); background: transparent; border-color: var(--color-nivel-4-border); }
  a.cite:hover { filter: brightness(0.95); text-decoration: underline; text-underline-offset: 2px; }
</style>
