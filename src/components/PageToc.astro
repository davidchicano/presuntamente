---
// PageToc — índice interactivo de secciones para la página actual.
//
// El markup es un esqueleto vacío. El script al pie de BaseLayout escanea
// los .sec-h[id] del <main> al cargar y rellena tanto la lista <ol> como
// activa o no el componente entero.
//
// En desktop (≥1280px) la cápsula vive sticky a la derecha del contenido,
// fuera del flujo principal. En desktops más estrechos / móvil (<1280px) se
// colapsa a un botón flotante abajo a la derecha que abre un panel overlay.
//
// El propio componente añade aria-hidden hasta que el JS confirma que hay
// secciones, para que páginas sin .sec-h (listados, /buscar) no muestren
// ningún chrome residual.
---
<aside class="page-toc" data-state="empty" aria-hidden="true" data-pagefind-ignore>
  <button
    type="button"
    class="page-toc__fab"
    aria-controls="page-toc-panel"
    aria-expanded="false"
    aria-label="Abrir índice de la página"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="M4 6h16M4 12h12M4 18h8" />
    </svg>
    <span class="page-toc__fab-label">Índice</span>
  </button>
  <div
    id="page-toc-panel"
    class="page-toc__panel"
    role="navigation"
    aria-label="Índice de la página"
  >
    <div class="page-toc__head">
      <span class="page-toc__eye">En esta página</span>
      <button
        type="button"
        class="page-toc__close"
        aria-label="Cerrar índice"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M6 6l12 12M6 18L18 6" />
        </svg>
      </button>
    </div>
    <ol class="page-toc__list" role="list"></ol>
    <button type="button" class="page-toc__top">
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M12 19V5M5 12l7-7 7 7" />
      </svg>
      <span>Subir arriba</span>
    </button>
  </div>
</aside>
