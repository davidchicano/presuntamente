---
// CifrasTotalBox — caja-total homogénea para cifras económicas. Borde superior
// grueso (acento) + borde lateral marcado, con HoverCard opcional que explica
// la metodología de la cifra (presunción de inocencia, cómo se suma). Se reusa
// en: ficha de caso (CifrasCasoBloque), /graficas (CifrasEconomicasCharts) y
// fichas de sujeto (CifrasSujetoBloque). Tono `objeto` (acento) | `consecuencia`
// (acento secundario). Sólo presentación; tokens --color-* (dark mode incluido).
import HoverCard from '@/components/HoverCard.astro';
import { formatEurosCompact, formatEurosFull } from '@/lib/money';

interface Props {
  label: string;
  value: number;
  /** Matiz bajo la cifra (naturalezas, base de cálculo…). */
  note?: string;
  /** Color del borde superior: objeto/atribuido (navy), perjuicio (gris
   *  neutro, lectura de víctima no acusatoria), consecuencia (mostaza) o
   *  firme (rojo = condena, RESERVADO a dinero acreditado por sentencia firme). */
  tone?: 'objeto' | 'perjuicio' | 'consecuencia' | 'firme';
  /** Texto del HoverCard sobre la cifra (metodología / cautela). Si falta, sin hover. */
  hint?: string;
  /** Tamaño de la cifra. `lg` para bloques de caso/sección; `md` para cubetas de sujeto. */
  size?: 'lg' | 'md';
}
const { label, value, note, tone = 'objeto', hint, size = 'lg' } = Astro.props;
const full = formatEurosFull(value);
const compact = formatEurosCompact(value);
---
<div class="ctb" data-tone={tone} data-size={size}>
  <p class="ctb__label">{label}</p>
  {hint ? (
    <HoverCard side="bottom" align="start">
      <span slot="trigger" class="ctb__value ctb__value--hint" title={full}>
        <span class="ctb__num">{compact}</span>
        <svg class="ctb__info" width="13" height="13" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2" />
          <line x1="12" y1="11" x2="12" y2="16.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          <circle cx="12" cy="7.6" r="1.2" fill="currentColor" />
        </svg>
      </span>
      <div slot="content" class="ctb__hint">{hint}</div>
    </HoverCard>
  ) : (
    <p class="ctb__value" title={full}>{compact}</p>
  )}
  {note && <p class="ctb__note">{note}</p>}
</div>

<style>
  .ctb {
    border: 1.5px solid var(--color-border-strong);
    border-top: 4px solid var(--color-accent);
    background: var(--color-surface);
    padding: 14px 16px;
  }
  .ctb[data-tone='perjuicio'] { border-top-color: var(--color-border-strong); }
  .ctb[data-tone='consecuencia'] { border-top-color: var(--color-accent-secondary); }
  .ctb[data-tone='firme'] { border-top-color: var(--color-rol-condenado-firme); }

  .ctb__label {
    margin: 0 0 4px;
    font: 600 10.5px/1.2 var(--font-mono);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
  }
  .ctb__value {
    margin: 0;
    font: 700 clamp(1.5rem, 1.2rem + 1.3vw, 2rem) / 1.1 var(--font-mono);
    font-variant-numeric: tabular-nums;
    color: var(--color-fg);
  }
  .ctb[data-size='md'] .ctb__value {
    font-size: clamp(1.25rem, 1.05rem + 0.8vw, 1.6rem);
  }
  .ctb__value--hint {
    display: inline-flex;
    align-items: flex-start;
    gap: 5px;
    cursor: help;
  }
  .ctb__info {
    color: var(--color-fg-subtle);
    margin-top: 0.32em;
    flex: none;
  }
  .ctb__value--hint:hover .ctb__info { color: var(--color-accent); }
  .ctb__note {
    margin: 6px 0 0;
    font: 400 12.5px/1.5 var(--font-sans);
    color: var(--color-fg-subtle);
  }
  .ctb__hint {
    font: 400 12px/1.5 var(--font-sans);
    color: var(--color-fg);
    max-width: 260px;
  }
</style>
