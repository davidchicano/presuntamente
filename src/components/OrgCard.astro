---
// OrgCard — card de organización implicada.
// Distinguible de PersonaCard a primera vista: glyph geométrico por tipo
// a la izquierda (NO iniciales — esa es la marca de Persona).

import OrgGlyph from './OrgGlyph.astro';
import RolBadge from './RolBadge.astro';
import SourceLinkBadge from './SourceLinkBadge.astro';

interface RolView {
  rol: string;
  rolLabel: string;
  fecha_inicio: string;
  fecha_fin?: string;
}

interface RelacionView {
  naturalezaLabel: string;
  entidadLabel: string;
  entidadHref?: string;
  descripcion: string;
  periodo: string;
  documentoHref?: string;
}

interface Props {
  nombre: string;
  tipo: string;
  tipoLabel: string;
  localidad?: string;
  href?: string;
  roles: RolView[];
  relaciones?: RelacionView[];
  notas?: string;
}

const { nombre, tipo, tipoLabel, localidad, href, roles, relaciones = [], notas } = Astro.props;
---
<article class="ocard">
  <OrgGlyph tipo={tipo} size={44} />
  <div class="ocard__body">
    <h4 class="ocard__name">
      {href ? <a href={href}>{nombre}</a> : nombre}
    </h4>
    <p class="ocard__meta">
      <span>{tipoLabel}</span>
      {localidad && <><span class="ocard__sep">·</span><span>{localidad}</span></>}
    </p>
    <ul class="ocard__roles">
      {roles.map((r) => (
        <li class="ocard__role">
          <RolBadge rol={r.rol} label={r.rolLabel} />
          <span class="ocard__role-dates">
            {r.fecha_inicio}
            {r.fecha_fin ? ` → ${r.fecha_fin}` : ' → vigente'}
          </span>
        </li>
      ))}
    </ul>
    {relaciones.length > 0 && (
      <div class="ocard__relaciones">
        <ul>
          {relaciones.map((rel) => (
            <li>
              <SourceLinkBadge label={rel.naturalezaLabel} href={rel.documentoHref} />
              <span class="ocard__relacion-body">
                {rel.entidadHref ? <a href={rel.entidadHref}>{rel.entidadLabel}</a> : <span>{rel.entidadLabel}</span>}
                <span class="ocard__relacion-date">{rel.periodo}</span>
                <span class="ocard__relacion-desc">{rel.descripcion}</span>
              </span>
            </li>
          ))}
        </ul>
      </div>
    )}
    {notas && <p class="ocard__notas">{notas}</p>}
  </div>
</article>

<style>
  .ocard {
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 14px 16px;
    display: grid;
    grid-template-columns: 44px 1fr;
    gap: 14px;
    transition:
      border-color 200ms ease-out,
      background 200ms ease-out,
      transform 200ms ease-out;
  }
  .ocard:hover {
    border-color: var(--color-accent-secondary-border);
    background: color-mix(in srgb, var(--color-surface) 92%, var(--color-accent-secondary-soft));
    transform: translateX(-2px);
  }
  @media (prefers-reduced-motion: reduce) {
    .ocard { transition: none; }
    .ocard:hover { transform: none; }
  }
  .ocard__name {
    font: 700 16px/1.2 var(--font-sans);
    margin: 0 0 4px;
    letter-spacing: -0.005em;
    transition: color 200ms ease-out;
  }
  .ocard:hover .ocard__name {
    color: color-mix(in srgb, var(--color-accent-secondary-hover) 72%, var(--color-fg));
  }
  .ocard__name a { color: inherit; text-decoration: none; }
  .ocard__name a:hover { text-decoration: underline; }
  .ocard__meta {
    font: 400 12px/1.4 var(--font-sans);
    color: var(--color-fg-muted);
    margin: 0 0 10px;
  }
  .ocard__sep { color: var(--color-border); margin: 0 6px; }
  .ocard__roles {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .ocard__role {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }
  .ocard__role-dates {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-fg-muted);
  }
  .ocard__relaciones {
    margin-top: 12px;
    padding-top: 10px;
    border-top: 1px solid var(--color-border);
  }
  .ocard__relaciones ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 7px;
  }
  .ocard__relaciones li {
    display: flex;
    flex-wrap: wrap;
    gap: 7px 10px;
    align-items: flex-start;
  }
  .ocard__relacion-body {
    display: grid;
    gap: 2px;
    font: 400 12px/1.45 var(--font-sans);
    color: var(--color-fg-muted);
  }
  .ocard__relacion-body a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .ocard__relacion-date {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--color-fg-subtle);
  }
  .ocard__relacion-desc {
    color: var(--color-fg-muted);
  }
  .ocard__notas {
    margin: 10px 0 0;
    padding-top: 8px;
    border-top: 1px dashed var(--color-border);
    font: 400 12px/1.5 var(--font-sans);
    color: var(--color-fg-muted);
  }
</style>
