---
// OrgGlyph — glyph monocromo por tipo de Organización.
// Tres familias de fondo (DESIGN.md §4):
//   - navy soft: sistema judicial / fiscal / policial
//   - mostaza soft: organismo público
//   - blanco: partido, empresa, asociación
// Canónico en preview/brand_org_glyphs.html. Persona NUNCA usa glyph
// (usa iniciales en cuadrado); esa es la marca visual que distingue
// Persona vs Organización.

interface Props {
  tipo: string;
  size?: number;
}
const { tipo, size = 36 } = Astro.props;

type Family = 'judicial' | 'organismo' | 'neutro';
function family(t: string): Family {
  if (t === 'juzgado' || t === 'tribunal' || t === 'fiscalia' || t === 'policia_judicial_unidad') return 'judicial';
  if (t === 'organismo_publico') return 'organismo';
  return 'neutro';
}
const fam = family(tipo);
const px = `${size}px`;
const innerPx = `${Math.round(size * 0.5)}px`;
---
<div class:list={['org-glyph', `org-glyph--${fam}`]} style={`width:${px};height:${px};`} aria-hidden="true">
  {tipo === 'juzgado' || tipo === 'tribunal' ? (
    <svg viewBox="0 0 24 24" style={`width:${innerPx};height:${innerPx};`}>
      <line x1="12" y1="3" x2="12" y2="21" />
      <line x1="4" y1="6" x2="20" y2="6" />
      <line x1="8" y1="21" x2="16" y2="21" />
      <line x1="6" y1="6" x2="6" y2="11" />
      <line x1="18" y1="6" x2="18" y2="11" />
      <path d="M2 13 a 4 4 0 0 0 8 0" />
      <path d="M14 13 a 4 4 0 0 0 8 0" />
    </svg>
  ) : tipo === 'fiscalia' ? (
    <svg viewBox="0 0 24 24" style={`width:${innerPx};height:${innerPx};`}>
      <line x1="6" y1="22" x2="6" y2="6" />
      <line x1="12" y1="22" x2="12" y2="6" />
      <line x1="18" y1="22" x2="18" y2="6" />
      <polygon points="3 6 21 6 19 2 5 2" />
      <line x1="3" y1="22" x2="21" y2="22" />
    </svg>
  ) : tipo === 'policia_judicial_unidad' ? (
    <svg viewBox="0 0 24 24" style={`width:${innerPx};height:${innerPx};`}>
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
    </svg>
  ) : tipo === 'partido_politico' ? (
    <svg viewBox="0 0 24 24" style={`width:${innerPx};height:${innerPx};`}>
      <circle cx="9" cy="8" r="3" />
      <path d="M3 20v-1a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v1" />
      <circle cx="17" cy="9" r="2.5" />
      <path d="M16 14.5a3.5 3.5 0 0 1 5 3.5V20" />
    </svg>
  ) : tipo === 'empresa' || tipo === 'consultora' || tipo === 'entidad_financiera' ? (
    <svg viewBox="0 0 24 24" style={`width:${innerPx};height:${innerPx};`}>
      <rect x="3" y="8" width="18" height="12" />
      <path d="M8 8V6a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
      <line x1="3" y1="13" x2="21" y2="13" />
    </svg>
  ) : tipo === 'organismo_publico' ? (
    <svg viewBox="0 0 24 24" style={`width:${innerPx};height:${innerPx};`}>
      <rect x="4" y="2" width="16" height="20" />
      <path d="M9 22V12h6v10" />
      <line x1="8" y1="6" x2="9" y2="6" />
      <line x1="12" y1="6" x2="13" y2="6" />
      <line x1="16" y1="6" x2="17" y2="6" />
    </svg>
  ) : tipo === 'asociacion_acusacion_popular' || tipo === 'sindicato' || tipo === 'fundacion' ? (
    <svg viewBox="0 0 24 24" style={`width:${innerPx};height:${innerPx};`}>
      <line x1="12" y1="6" x2="12" y2="18" />
      <line x1="6" y1="8.5" x2="18" y2="15.5" />
      <line x1="6" y1="15.5" x2="18" y2="8.5" />
    </svg>
  ) : (
    <svg viewBox="0 0 24 24" style={`width:${innerPx};height:${innerPx};`}>
      <rect x="4" y="4" width="16" height="16" />
    </svg>
  )}
</div>

<style>
  .org-glyph {
    border: 1px solid var(--color-border-strong);
    background: var(--color-surface-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .org-glyph svg {
    stroke: currentColor;
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .org-glyph--judicial { background: var(--color-accent-soft); border-color: var(--color-accent); color: var(--color-accent); }
  .org-glyph--organismo { background: var(--color-accent-secondary-soft); border-color: var(--color-accent-secondary-border); color: #6b4d00; }
  .org-glyph--neutro { color: var(--color-fg-muted); }
</style>
