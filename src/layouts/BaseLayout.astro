---
import '@/styles/global.css';
import 'open-props/style';
import { ClientRouter } from 'astro:transitions';
import PresuntamenteLogo from '@/components/PresuntamenteLogo.astro';

type NavKey = 'casos' | 'personas' | 'organizaciones' | 'delitos' | 'biblioteca' | 'sobre';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  lang: 'es' | 'ca';
  description?: string;
  /** Pestaña de navegación marcada como activa en el header. */
  activeNav?: NavKey;
  /** Migas administrativas para la sub-banda gris. Por defecto solo "Inicio". */
  breadcrumb?: BreadcrumbItem[];
  /** Permite ocultar la sub-banda en páginas que ya tienen su propio breadcrumb (p.ej. ficha). */
  hideSubstrip?: boolean;
}

const {
  title,
  lang,
  description = 'Inventario interactivo de casos de corrupción en España.',
  activeNav,
  breadcrumb = [{ label: 'Inicio', href: lang === 'ca' ? '/cat' : '/' }],
  hideSubstrip = false,
} = Astro.props;

// TODO i18n: cuando se active el catalán, traducir nav y subtítulo institucional.
// Convención ministerial: el brand block del header es el ancla a "/"
// (la landing PgInicio). El nav lista SECCIONES, no incluye "Inicio".
const tabs: { key: NavKey; label: string; href: string }[] = [
  { key: 'casos',          label: 'Casos',          href: lang === 'ca' ? '/cat/casos'          : '/casos' },
  { key: 'personas',       label: 'Personas',       href: lang === 'ca' ? '/cat/personas'       : '/personas' },
  { key: 'organizaciones', label: 'Organizaciones', href: lang === 'ca' ? '/cat/organizaciones' : '/organizaciones' },
  { key: 'delitos',        label: 'Delitos',        href: lang === 'ca' ? '/cat/delitos'        : '/delitos' },
  { key: 'biblioteca',     label: 'Biblioteca',     href: lang === 'ca' ? '/cat/biblioteca'     : '/biblioteca' },
  { key: 'sobre',          label: 'Sobre',          href: lang === 'ca' ? '/cat/sobre'          : '/sobre' },
];

const buildTime = new Date().toISOString().slice(0, 16).replace('T', ' ') + ' UTC';
// El subtítulo del bloque de marca es sólo el descriptor institucional;
// la versión y el build hash viven exclusivamente en el footer (.site-footer .meta).
const brandSub = 'Inventario público de casos de corrupción en España';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · presuntamente</title>
    <meta name="description" content={description} />

    <link rel="icon" type="image/png" href="/branding/logo.png" />
    <link rel="apple-touch-icon" href="/branding/logo.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&family=Source+Sans+3:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
    <ClientRouter fallback="animate" />
  </head>
  <body class="page">
    <a href="#main" class="skip">Saltar al contenido</a>

    <header class="site-header">
      <div class="site-header__inner">
        <a href={lang === 'ca' ? '/cat' : '/'} class="site-brand" aria-label="Ir a la portada">
          <PresuntamenteLogo variant="wordmark+isotipo" sub={brandSub} />
        </a>
        <nav class="site-nav" aria-label="Principal">
          {tabs.map((t) => (
            <a href={t.href} class:list={[activeNav === t.key && 'is-active']}>
              <span class="site-nav__label">{t.label}</span>
            </a>
          ))}
        </nav>
        <a class="site-search" href={lang === 'ca' ? '/cat/buscar' : '/buscar'} aria-label="Buscar">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <circle cx="11" cy="11" r="7" />
            <path d="m21 21-4.35-4.35" />
          </svg>
          <span>Buscar</span>
        </a>
        <div class="site-lang" aria-label="Idioma">
          <a href="/" class:list={[lang === 'es' && 'is-on']} lang="es">ES</a>
          <span class="sep">/</span>
          <a href="/cat" class:list={[lang === 'ca' && 'is-on']} lang="ca">CAT</a>
        </div>
        <button
          type="button"
          class="site-menu-btn"
          aria-controls="site-menu-panel"
          aria-expanded="false"
          aria-label="Abrir menú"
        >
          <svg class="site-menu-btn__open" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M4 7h16M4 12h16M4 17h16" />
          </svg>
          <svg class="site-menu-btn__close" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M6 6l12 12M6 18L18 6" />
          </svg>
        </button>
      </div>
      <div
        id="site-menu-panel"
        class="site-menu-panel"
        role="dialog"
        aria-label="Menú de navegación"
        data-open="false"
        aria-hidden="true"
      >
        <nav class="site-menu-panel__nav" aria-label="Principal (menú móvil)">
          {tabs.map((t) => (
            <a
              href={t.href}
              class:list={['site-menu-panel__link', activeNav === t.key && 'is-active']}
            >
              {t.label}
            </a>
          ))}
        </nav>
        <div class="site-menu-panel__lang" aria-label="Idioma">
          <a href="/" class:list={[lang === 'es' && 'is-on']} lang="es">ES</a>
          <span class="sep">/</span>
          <a href="/cat" class:list={[lang === 'ca' && 'is-on']} lang="ca">CAT</a>
        </div>
      </div>
    </header>

    {!hideSubstrip && (
      <div class="site-substrip">
        <div class="site-substrip__inner">
          <span>
            {breadcrumb.map((c, i) => (
              <>
                {i > 0 && <span> / </span>}
                {i === breadcrumb.length - 1 || !c.href
                  ? <span style="color: var(--color-fg);">{c.label}</span>
                  : <a href={c.href}>{c.label}</a>}
              </>
            ))}
          </span>
          <span>Última actualización · {buildTime}</span>
        </div>
      </div>
    )}

    <main id="main" class="main" data-pagefind-body>
      <slot />
    </main>

    <script>
      // Botón hamburguesa (mobile <720px) + panel desplegable.
      // Event-delegation desde document para sobrevivir al swap de
      // ClientRouter sin re-attach manual. `astro:before-preparation` cierra
      // el panel ante una navegación para que no quede abierto en la página
      // destino.
      let __menuListenersAttached = false;
      function __ensureMenuListeners() {
        if (__menuListenersAttached) return;
        __menuListenersAttached = true;

        const setOpen = (btn: Element, open: boolean) => {
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
          btn.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
          const panel = document.getElementById(btn.getAttribute('aria-controls') ?? '');
          if (panel) {
            panel.dataset.open = open ? 'true' : 'false';
            panel.setAttribute('aria-hidden', open ? 'false' : 'true');
          }
          document.body?.classList.toggle('has-menu-open', open);
        };
        const closeAny = () => {
          document.querySelectorAll('.site-menu-btn[aria-expanded="true"]').forEach((btn) => setOpen(btn, false));
        };

        document.addEventListener('click', (e) => {
          const target = e.target;
          if (!(target instanceof Element)) return;
          const btn = target.closest('.site-menu-btn');
          if (btn) {
            setOpen(btn, btn.getAttribute('aria-expanded') !== 'true');
            return;
          }
          // Click en un link del panel: dejar que navegue + cerrar inmediatamente
          // (la transición de ClientRouter también dispara close vía before-preparation).
          if (target.closest('.site-menu-panel a')) {
            closeAny();
            return;
          }
          // Click fuera del panel y fuera del botón → cerrar.
          const openBtn = document.querySelector('.site-menu-btn[aria-expanded="true"]');
          if (!openBtn) return;
          const panel = document.getElementById(openBtn.getAttribute('aria-controls') ?? '');
          if (panel && !panel.contains(target)) closeAny();
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') closeAny();
        });

        document.addEventListener('astro:before-preparation', closeAny);
      }
      __ensureMenuListeners();
      document.addEventListener('astro:page-load', __ensureMenuListeners);

      // Filas clicables de las tablas de listado. Cualquier `tr.is-link`
      // navega al primer `<a href>` de la fila al hacer click en una celda
      // no-interactiva. Clicks sobre anchors o controles dentro de la celda
      // (un nombre de organización linkado, un badge accionable, etc.)
      // siguen su comportamiento natural y NO se interceptan. Modifier keys
      // y middle-click abren nueva pestaña.
      let __rowLinkAttached = false;
      function __ensureRowLinkListener() {
        if (__rowLinkAttached) return;
        __rowLinkAttached = true;
        const navigate = (e: MouseEvent | KeyboardEvent, row: Element) => {
          const sel = window.getSelection();
          if (sel && sel.toString().length > 0) return;
          const a = row.querySelector<HTMLAnchorElement>('a[href]');
          if (!a) return;
          const href = a.getAttribute('href');
          if (!href) return;
          const mouse = e instanceof MouseEvent;
          if (mouse && (e.metaKey || e.ctrlKey || e.shiftKey || e.button === 1)) {
            window.open(href, '_blank', 'noopener');
          } else {
            a.click();
          }
        };
        const isInteractive = (el: Element | null) =>
          !!el && !!el.closest('a, button, input, select, textarea, label, summary, [role="button"]');
        document.addEventListener('click', (e) => {
          const target = e.target;
          if (!(target instanceof Element)) return;
          if (isInteractive(target)) return;
          const row = target.closest<HTMLTableRowElement>('.tbl tbody tr.is-link');
          if (!row) return;
          navigate(e, row);
        });
        document.addEventListener('auxclick', (e) => {
          if (e.button !== 1) return;
          const target = e.target;
          if (!(target instanceof Element)) return;
          if (isInteractive(target)) return;
          const row = target.closest<HTMLTableRowElement>('.tbl tbody tr.is-link');
          if (!row) return;
          navigate(e, row);
          e.preventDefault();
        });
      }
      __ensureRowLinkListener();
      document.addEventListener('astro:page-load', __ensureRowLinkListener);
    </script>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div>
          <h6>presuntamente.org</h6>
          <p>Inventario público, interactivo y open-source de los casos de corrupción más relevantes en España.</p>
          <p class="meta">© 2026 · v0.0.0-alpha · build {buildTime}</p>
        </div>
        <div>
          <h6>Marco</h6>
          <a href="/aviso-legal">Aviso legal</a>
          <a href="/sobre">Política editorial</a>
          <a href="/sobre#redaccion">Cómo se redacta esto</a>
        </div>
        <div>
          <h6>Licencias</h6>
          <a href="https://www.gnu.org/licenses/agpl-3.0.html">Código · AGPL-3.0</a>
          <a href="https://creativecommons.org/licenses/by-sa/4.0/">Contenido · CC BY-SA 4.0</a>
          <a href="https://github.com/davidchicano/presuntamente">Repositorio público</a>
        </div>
        <div>
          <h6>Rectificación</h6>
          <a href="/rectificar">Proponer corrección ↗</a>
          <a href="https://github.com/davidchicano/presuntamente/issues">Abrir issue</a>
          <a href="https://github.com/davidchicano/presuntamente/blob/main/CONTRIBUTING.md">CONTRIBUTING.md</a>
        </div>
      </div>
    </footer>
  </body>
</html>
