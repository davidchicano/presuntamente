---
import '@/styles/global.css';
import 'open-props/style';
import PresuntamenteLogo from '@/components/PresuntamenteLogo.astro';
import PageToc from '@/components/PageToc.astro';

type NavKey = 'casos' | 'personas' | 'organizaciones' | 'delitos' | 'biblioteca' | 'cifras' | 'sobre';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  lang: 'es' | 'ca';
  description?: string;
  /** Pestaña de navegación marcada como activa en el header. */
  activeNav?: NavKey;
  /** Migas administrativas para la sub-banda gris. Por defecto solo "Inicio". */
  breadcrumb?: BreadcrumbItem[];
  /** Permite ocultar la sub-banda en páginas que ya tienen su propio breadcrumb (p.ej. ficha). */
  hideSubstrip?: boolean;
  /**
   * Path absoluto (con `/` inicial) del PNG OG a usar como og:image. Por
   * defecto `/og/default.png` (cifras agregadas del inventario). Las fichas
   * (Pg*Detalle) lo sobreescriben con su PNG propio en `/og/casos/<slug>.png`,
   * `/og/personas/<slug>.png`, `/og/organizaciones/<slug>.png`.
   * Ver `docs/web/features/og-images.md`.
   */
  ogImage?: string;
  /** `website` por defecto; las fichas usan `article`. */
  ogType?: 'website' | 'article';
}

const {
  title,
  lang,
  description = 'Inventario interactivo de casos de corrupción en España.',
  activeNav,
  breadcrumb = [{ label: 'Inicio', href: lang === 'ca' ? '/cat' : '/' }],
  hideSubstrip = false,
  ogImage = '/og/default.png',
  ogType = 'website',
} = Astro.props;

// URLs absolutas para los meta tags Open Graph / Twitter Card. Los
// scrapers (X, Facebook, WhatsApp, Telegram, LinkedIn, Slack, Discord)
// requieren URL absoluta para `og:image` — no leen rutas relativas.
// `Astro.site` se configura en astro.config.mjs como 'https://presuntamente.org'.
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;
const ogTitle = `${title} · presuntamente`;

// La `description` puede venir de un block scalar YAML (`|`) con saltos de
// línea internos. X corta `og:description` en el primer `\n` y Facebook
// los renderiza como espacios extra. La aplanamos a un párrafo y la
// truncamos a 220 caracteres (margen razonable bajo el límite suave de
// X / Twitter Card ~200 y por debajo del corte habitual de WhatsApp).
const ogDescription = (() => {
  const flat = (description ?? '').replace(/\s+/g, ' ').trim();
  if (flat.length <= 220) return flat;
  return flat.slice(0, 219).trimEnd() + '…';
})();

// TODO i18n: cuando se active el catalán, traducir nav, grupos y subtítulo institucional.
// Convención ministerial: el brand block del header es el ancla a "/"
// (la landing PgInicio). El nav lista SECCIONES, no incluye "Inicio".
// Agrupación IA: núcleo · entidades · referencia (incl. Sobre). Tres clusters
// en desktop evitan que Sobre quede como grupo huérfano al hacer wrap.
// Ver docs/web/features/navegacion-principal.md.
interface NavTab { key: NavKey; label: string; href: string }
interface NavGroup { id: string; heading?: string; items: NavTab[] }

const navGroups: NavGroup[] = [
  {
    id: 'core',
    items: [
      { key: 'casos', label: 'Casos', href: lang === 'ca' ? '/cat/casos' : '/casos' },
    ],
  },
  {
    id: 'inventario',
    heading: 'Inventario',
    items: [
      { key: 'personas',       label: 'Personas',       href: lang === 'ca' ? '/cat/personas'       : '/personas' },
      { key: 'organizaciones', label: 'Organizaciones', href: lang === 'ca' ? '/cat/organizaciones' : '/organizaciones' },
      { key: 'delitos',        label: 'Delitos',        href: lang === 'ca' ? '/cat/delitos'        : '/delitos' },
    ],
  },
  {
    id: 'referencia',
    heading: 'Referencia',
    items: [
      { key: 'biblioteca', label: 'Biblioteca', href: lang === 'ca' ? '/cat/biblioteca' : '/biblioteca' },
      { key: 'cifras',     label: 'Cifras',     href: lang === 'ca' ? '/cat/cifras'     : '/cifras' },
      { key: 'sobre',      label: 'Sobre',      href: lang === 'ca' ? '/cat/sobre'      : '/sobre' },
    ],
  },
];

const buildTime = new Date().toISOString().slice(0, 16).replace('T', ' ') + ' UTC';
// El subtítulo del bloque de marca es sólo el descriptor institucional;
// la versión y el build hash viven exclusivamente en el footer (.site-footer .meta).
const brandSub = 'Inventario público de casos de corrupción en España';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · presuntamente</title>
    <meta name="description" content={ogDescription} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph (X, Facebook, WhatsApp, LinkedIn, Telegram, Slack, Discord) -->
    <meta property="og:site_name" content="presuntamente.org" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:locale" content={lang === 'ca' ? 'ca_ES' : 'es_ES'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="alternate" type="application/atom+xml" title="presuntamente · Hitos recientes (Atom)" href="/feed.xml" />
    <link rel="alternate" type="application/rss+xml" title="presuntamente · Hitos recientes (RSS)" href="/rss.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700&family=Source+Sans+3:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
    {import.meta.env.CF_ANALYTICS_TOKEN && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token":"${import.meta.env.CF_ANALYTICS_TOKEN}"}`}
      ></script>
    )}
  </head>
  <body class="page">
    <a href="#main" class="skip">Saltar al contenido</a>

    <header class="site-header">
      <div class="site-header__inner">
        <a href={lang === 'ca' ? '/cat' : '/'} class="site-brand" aria-label="Ir a la portada">
          <PresuntamenteLogo variant="wordmark+isotipo" sub={brandSub} />
        </a>
        <nav class="site-nav" aria-label="Principal">
          {navGroups.map((group) => (
            <div class="site-nav__group" data-nav-group={group.id}>
              {group.items.map((t) => (
                <a href={t.href} class:list={[activeNav === t.key && 'is-active']}>
                  <span class="site-nav__label">{t.label}</span>
                </a>
              ))}
            </div>
          ))}
        </nav>
        <a class="site-search" href={lang === 'ca' ? '/cat/buscar' : '/buscar'} aria-label="Buscar">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <circle cx="11" cy="11" r="7" />
            <path d="m21 21-4.35-4.35" />
          </svg>
          <span>Buscar</span>
        </a>
        <div class="site-lang-wrap">
          <button
            type="button"
            class="site-lang-btn"
            aria-controls="site-lang-panel"
            aria-expanded="false"
            aria-haspopup="menu"
            aria-label="Cambiar idioma"
          >
            <span class="site-lang-btn__current">{lang === 'ca' ? 'CAT' : 'ES'}</span>
            <svg class="site-lang-btn__chev" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M6 9l6 6 6-6" />
            </svg>
          </button>
          <div
            id="site-lang-panel"
            class="site-lang-panel"
            role="menu"
            data-open="false"
            aria-hidden="true"
          >
            <a href="/" class:list={[lang === 'es' && 'is-on']} lang="es" role="menuitem">
              <span class="site-lang-panel__code">ES</span>
              <span class="site-lang-panel__name">Castellano</span>
            </a>
            <a href="/cat" class:list={[lang === 'ca' && 'is-on']} lang="ca" role="menuitem">
              <span class="site-lang-panel__code">CAT</span>
              <span class="site-lang-panel__name">Català</span>
            </a>
          </div>
        </div>
        <a class="site-aportar" href={lang === 'ca' ? '/cat/aportar' : '/aportar'}>
          <span>Aportar</span>
        </a>
        <button
          type="button"
          class="site-menu-btn"
          aria-controls="site-menu-panel"
          aria-expanded="false"
          aria-label="Abrir menú"
        >
          <svg class="site-menu-btn__open" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M4 7h16M4 12h16M4 17h16" />
          </svg>
          <svg class="site-menu-btn__close" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M6 6l12 12M6 18L18 6" />
          </svg>
        </button>
      </div>
      <div
        id="site-menu-panel"
        class="site-menu-panel"
        role="dialog"
        aria-label="Menú de navegación"
        data-open="false"
        aria-hidden="true"
      >
        <nav class="site-menu-panel__nav" aria-label="Principal (menú móvil)">
          {navGroups.map((group) => (
            <div class="site-menu-panel__group" data-nav-group={group.id}>
              {group.heading && (
                <p class="site-menu-panel__heading">{group.heading}</p>
              )}
              {group.items.map((t) => (
                <a
                  href={t.href}
                  class:list={['site-menu-panel__link', activeNav === t.key && 'is-active']}
                >
                  {t.label}
                </a>
              ))}
            </div>
          ))}
        </nav>
        <a
          class="site-menu-panel__aportar"
          href={lang === 'ca' ? '/cat/aportar' : '/aportar'}
        >
          <span>Aportar</span>
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
        <div class="site-menu-panel__lang" aria-label="Idioma">
          <a href="/" class:list={[lang === 'es' && 'is-on']} lang="es">ES</a>
          <span class="sep">/</span>
          <a href="/cat" class:list={[lang === 'ca' && 'is-on']} lang="ca">CAT</a>
        </div>
      </div>
    </header>

    {!hideSubstrip && (
      <div class="site-substrip">
        <div class="site-substrip__inner">
          <span>
            {breadcrumb.map((c, i) => (
              <>
                {i > 0 && <span> / </span>}
                {i === breadcrumb.length - 1 || !c.href
                  ? <span style="color: var(--color-fg);">{c.label}</span>
                  : <a href={c.href}>{c.label}</a>}
              </>
            ))}
          </span>
          <span>Última actualización · {buildTime}</span>
        </div>
      </div>
    )}

    <main id="main" class="main" data-pagefind-body>
      <PageToc />
      <slot />
    </main>

    <script>
      // Botón hamburguesa (mobile <720px) + panel desplegable.
      // Event-delegation desde document; en navegación normal la página
      // recarga, pero este patrón también evita listeners duplicados.
      let __menuListenersAttached = false;
      function __ensureMenuListeners() {
        if (__menuListenersAttached) return;
        __menuListenersAttached = true;

        // Selector unificado: hamburguesa del header móvil (.site-menu-btn) y
        // dropdown del idioma (.site-lang-btn) comparten contrato (aria-controls
        // → panel con data-open). El handler reusa el mismo listener para no
        // duplicar lógica de click-fuera / ESC / before-preparation.
        const TRIGGER_SEL = '.site-menu-btn, .site-lang-btn';
        const PANEL_LINK_SEL = '.site-menu-panel a, .site-lang-panel a';

        const isMenuBtn = (btn: Element) => btn.classList.contains('site-menu-btn');
        const setOpen = (btn: Element, open: boolean) => {
          if (open) {
            // Solo un trigger abierto a la vez: cierra los demás antes de abrir éste.
            document.querySelectorAll(TRIGGER_SEL).forEach((other) => {
              if (other !== btn && other.getAttribute('aria-expanded') === 'true') {
                setOpen(other, false);
              }
            });
          }
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
          if (isMenuBtn(btn)) {
            // El a11y label del hamburguesa cambia ("Abrir menú" / "Cerrar menú");
            // el botón de idioma mantiene su label fijo ("Cambiar idioma").
            btn.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
          }
          const panel = document.getElementById(btn.getAttribute('aria-controls') ?? '');
          if (panel) {
            panel.dataset.open = open ? 'true' : 'false';
            panel.setAttribute('aria-hidden', open ? 'false' : 'true');
          }
          // Bloqueo de scroll solo cuando el panel grande está abierto; el
          // dropdown del idioma no debe bloquear scroll.
          if (isMenuBtn(btn)) {
            document.body?.classList.toggle('has-menu-open', open);
          }
        };
        const closeAny = () => {
          document.querySelectorAll(TRIGGER_SEL).forEach((btn) => {
            if (btn.getAttribute('aria-expanded') === 'true') setOpen(btn, false);
          });
        };

        document.addEventListener('click', (e) => {
          const target = e.target;
          if (!(target instanceof Element)) return;
          const btn = target.closest(TRIGGER_SEL);
          if (btn) {
            setOpen(btn, btn.getAttribute('aria-expanded') !== 'true');
            return;
          }
          // Click en un link de cualquier panel: dejar que navegue + cerrar inmediatamente.
          if (target.closest(PANEL_LINK_SEL)) {
            closeAny();
            return;
          }
          // Click fuera de cualquier panel y de su trigger → cerrar.
          const openBtns = document.querySelectorAll(`${TRIGGER_SEL.split(', ').map((s) => `${s}[aria-expanded="true"]`).join(', ')}`);
          if (openBtns.length === 0) return;
          let shouldClose = true;
          openBtns.forEach((openBtn) => {
            const panel = document.getElementById(openBtn.getAttribute('aria-controls') ?? '');
            if (panel && panel.contains(target)) shouldClose = false;
            if (openBtn.contains(target)) shouldClose = false;
          });
          if (shouldClose) closeAny();
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') closeAny();
        });

        document.addEventListener('astro:before-preparation', closeAny);
      }
      __ensureMenuListeners();
      document.addEventListener('astro:page-load', __ensureMenuListeners);

      // Filas clicables de las tablas de listado. Cualquier `tr.is-link`
      // navega al primer `<a href>` de la fila al hacer click en una celda
      // no-interactiva. Clicks sobre anchors o controles dentro de la celda
      // (un nombre de organización linkado, un badge accionable, etc.)
      // siguen su comportamiento natural y NO se interceptan. Modifier keys
      // y middle-click abren nueva pestaña.
      let __rowLinkAttached = false;
      function __ensureRowLinkListener() {
        if (__rowLinkAttached) return;
        __rowLinkAttached = true;
        const navigate = (e: MouseEvent | KeyboardEvent, row: Element) => {
          const sel = window.getSelection();
          if (sel && sel.toString().length > 0) return;
          const a = row.querySelector<HTMLAnchorElement>('a[href]');
          if (!a) return;
          const href = a.getAttribute('href');
          if (!href) return;
          const mouse = e instanceof MouseEvent;
          if (mouse && (e.metaKey || e.ctrlKey || e.shiftKey || e.button === 1)) {
            window.open(href, '_blank', 'noopener');
          } else {
            a.click();
          }
        };
        const isInteractive = (el: Element | null) =>
          !!el && !!el.closest('a, button, input, select, textarea, label, summary, [role="button"]');
        document.addEventListener('click', (e) => {
          const target = e.target;
          if (!(target instanceof Element)) return;
          if (isInteractive(target)) return;
          const row = target.closest<HTMLTableRowElement>('.tbl tbody tr.is-link');
          if (!row) return;
          navigate(e, row);
        });
        document.addEventListener('auxclick', (e) => {
          if (e.button !== 1) return;
          const target = e.target;
          if (!(target instanceof Element)) return;
          if (isInteractive(target)) return;
          const row = target.closest<HTMLTableRowElement>('.tbl tbody tr.is-link');
          if (!row) return;
          navigate(e, row);
          e.preventDefault();
        });
      }
      __ensureRowLinkListener();
      document.addEventListener('astro:page-load', __ensureRowLinkListener);

      // Toggle de orden integrado en SectionH (`orderToggle` prop). El
      // botón `.sec-h__order` vive dentro del .sec-h; al pulsarlo se invierte
      // el orden visual del PRÓXIMO hermano del .sec-h (típicamente la
      // `.timeline`, pero el patrón es agnóstico al tipo de contenedor:
      // basta con que el target defina su regla `.is-reversed { … }`).
      // Sin re-render, sin tocar DOM — sólo flex-direction.
      let __orderToggleAttached = false;
      function __ensureOrderToggleListener() {
        if (__orderToggleAttached) return;
        __orderToggleAttached = true;
        document.addEventListener('click', (e) => {
          const target = e.target;
          if (!(target instanceof Element)) return;
          const btn = target.closest<HTMLButtonElement>('.sec-h__order');
          if (!btn) return;
          const secH = btn.closest<HTMLElement>('.sec-h');
          const container = secH?.nextElementSibling as HTMLElement | null;
          if (!container) return;
          const wasAsc = btn.dataset.order === 'asc';
          const label = btn.querySelector<HTMLElement>('.sec-h__order-label');
          if (wasAsc) {
            btn.dataset.order = 'desc';
            btn.setAttribute('aria-pressed', 'false');
            container.classList.remove('is-reversed');
            if (label) label.textContent = 'Más reciente primero';
          } else {
            btn.dataset.order = 'asc';
            btn.setAttribute('aria-pressed', 'true');
            container.classList.add('is-reversed');
            if (label) label.textContent = 'Más antiguo primero';
          }
        });
      }
      __ensureOrderToggleListener();
      document.addEventListener('astro:page-load', __ensureOrderToggleListener);

      // Case masthead flip. Kept in the layout so the behavior is centralized
      // and idempotent across pages that include a flippable masthead.
      const __setCaseFlipHeight = (flip: HTMLElement) => {
        const inner = flip.querySelector<HTMLElement>('.ficha-flip__inner');
        const front = flip.querySelector<HTMLElement>('.ficha-flip__face--front');
        const back = flip.querySelector<HTMLElement>('.ficha-flip__face--back');
        if (!inner || !front || !back) return;
        const target = flip.dataset.flipped === 'true' ? back : front;
        const height = Math.max(target.scrollHeight, target.getBoundingClientRect().height);
        inner.style.minHeight = `${Math.ceil(height)}px`;
      };

      const __setCaseFlipState = (flip: HTMLElement, flipped: boolean) => {
        const toggle = flip.querySelector<HTMLButtonElement>('.ficha-flip__toggle');
        const front = flip.querySelector<HTMLElement>('.ficha-flip__face--front');
        const back = flip.querySelector<HTMLElement>('.ficha-flip__face--back');
        if (!toggle || !front || !back) return;

        flip.dataset.flipped = flipped ? 'true' : 'false';
        toggle.setAttribute('aria-pressed', flipped ? 'true' : 'false');
        front.setAttribute('aria-hidden', flipped ? 'true' : 'false');
        back.setAttribute('aria-hidden', flipped ? 'false' : 'true');
        toggle.setAttribute(
          'aria-label',
          flipped ? 'Volver' : 'Ver detalles del desarrollo editorial de esta ficha',
        );

        const label = toggle.querySelector<HTMLElement>('.ficha-flip__toggle-label');
        if (label) label.textContent = flipped ? 'Volver' : 'Ver detalles de desarrollo';
        __setCaseFlipHeight(flip);
      };

      const __initCaseFlips = () => {
        document.querySelectorAll<HTMLElement>('.ficha-flip').forEach((flip) => {
          __setCaseFlipHeight(flip);
          if (flip.dataset.flipReady === 'true') return;

          const front = flip.querySelector<HTMLElement>('.ficha-flip__face--front');
          const back = flip.querySelector<HTMLElement>('.ficha-flip__face--back');
          if (!front || !back) return;

          if (typeof ResizeObserver !== 'undefined') {
            const ro = new ResizeObserver(() => __setCaseFlipHeight(flip));
            ro.observe(front);
            ro.observe(back);
            __caseFlipResizeObservers.push(ro);
          } else {
            window.addEventListener('resize', () => __setCaseFlipHeight(flip));
          }

          flip.dataset.flipReady = 'true';
        });
      };

      let __caseFlipAttached = false;
      let __caseFlipResizeObservers: ResizeObserver[] = [];
      function __ensureCaseFlipListeners() {
        if (!__caseFlipAttached) {
          __caseFlipAttached = true;
          document.addEventListener('click', (e) => {
            const target = e.target;
            if (!(target instanceof Element)) return;
            const toggle = target.closest<HTMLButtonElement>('.ficha-flip__toggle');
            const flip = toggle?.closest<HTMLElement>('.ficha-flip');
            if (!toggle || !flip) return;
            __setCaseFlipState(flip, flip.dataset.flipped !== 'true');
          });

          document.addEventListener('keydown', (e) => {
            if (e.key !== 'Escape') return;
            const flip = document.querySelector<HTMLElement>('.ficha-flip[data-flipped="true"]');
            if (!flip) return;
            __setCaseFlipState(flip, false);
            flip.querySelector<HTMLButtonElement>('.ficha-flip__toggle')?.focus();
          });

          document.addEventListener('astro:before-preparation', () => {
            __caseFlipResizeObservers.forEach((observer) => observer.disconnect());
            __caseFlipResizeObservers = [];
          });
        }
        __initCaseFlips();
      }
      __ensureCaseFlipListeners();
      document.addEventListener('astro:page-load', __ensureCaseFlipListeners);

      // Click sobre un `.sec-h[id]` lleva al inicio natural de la sección.
      // Cuando el header sticky está pegado al top del viewport (se scrolleó
      // dentro de su sección), pulsarlo devuelve al usuario al arranque de
      // la sección. Si la sección ya está en su posición natural (no stuck),
      // el scrollTo no causa movimiento; coste cero.
      // Detalle clave: `sec.offsetTop` devuelve la posición *perturbada* del
      // sticky cuando está stuck (≈ scrollY), no la natural. La posición
      // natural se obtiene del wrapper `[data-toc-section]` que el JS del
      // PageToc envuelve alrededor de cada .sec-h + siblings al cargar la
      // página. Si el wrapper no existe todavía (página con <2 .sec-h, o
      // listener de PageToc aún no corrido), fallback al `offsetTop` del
      // sec-h restando scrollY (ajuste cuando está stuck).
      // Skip si: hay selección de texto, el click salió de un descendiente
      // interactivo, o se pulsa con modificador (Cmd/Ctrl/Shift/Alt).
      let __secHAttached = false;
      function __ensureSecHListener() {
        if (__secHAttached) return;
        __secHAttached = true;
        document.addEventListener('click', (e) => {
          const target = e.target;
          if (!(target instanceof Element)) return;
          if (target.closest('a, button, input, select, textarea, label, summary, [role="button"]')) return;
          const sec = target.closest<HTMLElement>('.main .sec-h[id]');
          if (!sec) return;
          if (e instanceof MouseEvent && (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey)) return;
          const sel = window.getSelection();
          if (sel && sel.toString().length > 0) return;
          const wrapper = sec.closest<HTMLElement>('[data-toc-section]');
          const naturalTop = wrapper
            ? wrapper.offsetTop
            : sec.getBoundingClientRect().top + window.scrollY;
          const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          window.scrollTo({ top: naturalTop, behavior: prefersReduced ? 'auto' : 'smooth' });
        });
      }
      __ensureSecHListener();
      document.addEventListener('astro:page-load', __ensureSecHListener);

      // Índice de página (PageToc) — escanea los .sec-h[id] del <main>,
      // construye la lista, activa el scrollspy con IntersectionObserver y
      // gestiona el FAB en móvil.
      let __pageTocObserver: IntersectionObserver | null = null;
      let __pageTocClickAttached = false;

      // Agrupa cada .sec-h con sus siblings hasta el siguiente .sec-h en un
      // <section data-toc-section="ID">. Sin este scope, varios .sec-h
      // position:sticky se apilan a top:0 a la vez (uno por cada padre que
      // alcanza el viewport top). Con sections separadas, cada .sec-h solo
      // está sticky mientras su section es visible.
      function __wrapPageSections() {
        const main = document.querySelector('main');
        if (!main) return;
        const sectionRoot = main.querySelector('.ficha-detail') ?? main;
        const headers = Array.from(sectionRoot.querySelectorAll<HTMLElement>(':scope > .sec-h[id]'));
        for (const h of headers) {
          // Ya envuelto en servidor (<FichaTocSection />) o por una pasada previa.
          if (h.closest('[data-toc-section]')) continue;
          // Solo procesar headers hijos directos del contenedor de ficha o del main.
          if (h.parentElement !== sectionRoot) continue;

          const section = document.createElement('section');
          section.className = 'ficha-toc-section';
          section.dataset.tocSection = h.id;
          // Reunir el header + siblings hasta el próximo .sec-h o el fin.
          const toMove: Element[] = [h];
          let n: Element | null = h.nextElementSibling;
          while (n && !n.classList.contains('sec-h')) {
            const next: Element | null = n.nextElementSibling;
            toMove.push(n);
            n = next;
          }
          h.parentNode?.insertBefore(section, h);
          for (const node of toMove) section.appendChild(node);
        }
      }

      function __buildPageToc() {
        const aside = document.querySelector<HTMLElement>('.page-toc');
        if (!aside) return;
        const list = aside.querySelector<HTMLOListElement>('.page-toc__list');
        if (!list) return;

        // Reset visual + observer al rebuild.
        if (__pageTocObserver) {
          __pageTocObserver.disconnect();
          __pageTocObserver = null;
        }
        list.innerHTML = '';

        __wrapPageSections();

        const headers = Array.from(
          document.querySelectorAll<HTMLElement>('main .sec-h[id]')
        );

        if (headers.length < 2) {
          aside.dataset.state = 'empty';
          aside.setAttribute('aria-hidden', 'true');
          // Cierra el panel si quedaba abierto al cambiar de página.
          aside.dataset.open = 'false';
          const fab = aside.querySelector('.page-toc__fab');
          fab?.setAttribute('aria-expanded', 'false');
          document.body?.classList.remove('has-toc-open');
          document.body?.classList.remove('has-page-toc');
          return;
        }

        aside.dataset.state = 'ready';
        aside.setAttribute('aria-hidden', 'false');
        document.body?.classList.add('has-page-toc');

        const linkById = new Map<string, HTMLAnchorElement>();
        for (const h of headers) {
          const id = h.id;
          if (!id) continue;
          const numEl = h.querySelector('.num');
          const titleEl = h.querySelector('h2');
          const num = numEl?.textContent?.trim() ?? '';
          const title = titleEl?.textContent?.trim() ?? id;
          const li = document.createElement('li');
          li.className = 'page-toc__item';
          const a = document.createElement('a');
          a.className = 'page-toc__link';
          a.href = '#' + id;
          a.dataset.tocTarget = id;
          if (num) {
            const numSpan = document.createElement('span');
            numSpan.className = 'page-toc__num';
            numSpan.textContent = num;
            a.appendChild(numSpan);
          }
          const titleSpan = document.createElement('span');
          titleSpan.className = 'page-toc__title';
          titleSpan.textContent = title;
          a.appendChild(titleSpan);
          li.appendChild(a);
          list.appendChild(li);
          linkById.set(id, a);
        }

        // Scrollspy: el último .sec-h cuya top haya cruzado un offset
        // (~120px desde el top del viewport) es la sección activa. Usamos
        // IntersectionObserver con un rootMargin que define esa franja.
        const setActive = (id: string | null) => {
          for (const a of linkById.values()) a.classList.remove('is-active');
          if (id) linkById.get(id)?.classList.add('is-active');
        };

        const visible = new Set<string>();
        __pageTocObserver = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              const id = (e.target as HTMLElement).id;
              if (e.isIntersecting) visible.add(id);
              else visible.delete(id);
            }
            // De los visibles, el primero en orden de aparición es el activo.
            const ordered = headers
              .map((h) => h.id)
              .filter((id) => visible.has(id));
            if (ordered.length > 0) {
              setActive(ordered[0]);
              return;
            }
            // Si ninguno está dentro de la franja, marca el más cercano
            // por encima del viewport (estamos a media sección).
            let lastAbove: string | null = null;
            for (const h of headers) {
              const top = h.getBoundingClientRect().top;
              if (top < 140) lastAbove = h.id;
              else break;
            }
            setActive(lastAbove);
          },
          {
            // Franja activa: entre 80px desde el top (debajo del header)
            // y un punto a 60% del viewport. Una sección entra/sale de
            // esta franja conforme se hace scroll.
            rootMargin: '-80px 0px -60% 0px',
            threshold: 0,
          }
        );
        for (const h of headers) __pageTocObserver.observe(h);

        // Estado inicial: forzar evaluación tras el primer paint.
        requestAnimationFrame(() => {
          let lastAbove: string | null = null;
          for (const h of headers) {
            const top = h.getBoundingClientRect().top;
            if (top < 140) lastAbove = h.id;
            else break;
          }
          if (lastAbove) setActive(lastAbove);
          else setActive(headers[0].id);
        });
      }

      function __ensurePageTocClickHandler() {
        if (__pageTocClickAttached) return;
        __pageTocClickAttached = true;

        const setOpen = (open: boolean) => {
          const aside = document.querySelector<HTMLElement>('.page-toc');
          if (!aside) return;
          aside.dataset.open = open ? 'true' : 'false';
          const fab = aside.querySelector('.page-toc__fab');
          fab?.setAttribute('aria-expanded', open ? 'true' : 'false');
          document.body?.classList.toggle('has-toc-open', open);
        };

        document.addEventListener('click', (e) => {
          const target = e.target;
          if (!(target instanceof Element)) return;

          // FAB → toggle.
          const fab = target.closest('.page-toc__fab');
          if (fab) {
            const open = fab.getAttribute('aria-expanded') !== 'true';
            setOpen(open);
            return;
          }
          // Botón de cerrar dentro del panel.
          if (target.closest('.page-toc__close')) {
            setOpen(false);
            return;
          }
          // Botón de volver al inicio de la página.
          if (target.closest('.page-toc__top')) {
            e.preventDefault();
            const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            window.scrollTo({ top: 0, behavior: prefersReduced ? 'auto' : 'smooth' });
            history.replaceState(null, '', window.location.pathname + window.location.search);
            setOpen(false);
            return;
          }
          // Click en un link del índice → smooth scroll + cerrar panel
          // (en móvil). Se navega al wrapper natural de la sección para que
          // el inicio del apartado quede arriba, no al header sticky ya fijado.
          const link = target.closest<HTMLAnchorElement>('a.page-toc__link');
          if (link) {
            const id = link.dataset.tocTarget;
            const el = id ? document.getElementById(id) : null;
            if (el) {
              e.preventDefault();
              const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
              const section = el.closest<HTMLElement>('[data-toc-section]');
              const naturalTop = section?.offsetTop ?? el.getBoundingClientRect().top + window.scrollY;
              window.scrollTo({ top: naturalTop, behavior: prefersReduced ? 'auto' : 'smooth' });
              // Actualiza hash sin saltar (replaceState para no inundar history).
              if (id) history.replaceState(null, '', '#' + id);
              setOpen(false);
            }
            return;
          }
          // Click fuera del panel mientras está abierto → cerrar.
          const aside = document.querySelector<HTMLElement>('.page-toc[data-open="true"]');
          if (!aside) return;
          const panel = aside.querySelector('.page-toc__panel');
          if (panel && !panel.contains(target) && !target.closest('.page-toc__fab')) {
            setOpen(false);
          }
        });

        document.addEventListener('keydown', (e) => {
          if (e.key !== 'Escape') return;
          const aside = document.querySelector<HTMLElement>('.page-toc[data-open="true"]');
          if (aside) setOpen(false);
        });

        document.addEventListener('astro:before-preparation', () => setOpen(false));
      }

      __ensurePageTocClickHandler();
      __buildPageToc();
      document.addEventListener('astro:page-load', () => {
        __ensurePageTocClickHandler();
        __buildPageToc();
      });
    </script>

