{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://presuntamente.org/schemas/caso.schema.json",
  "title": "Caso",
  "description": "Un procedimiento o agrupación de procedimientos. Recursivo: un Caso puede ser pieza de otro Caso. Ver docs/diseno/01-modelo-de-datos.md §2.1.",
  "type": "object",
  "required": [
    "id",
    "nombre_oficial",
    "nombre_mediatico",
    "organo_judicial_id",
    "fase_actual",
    "fecha_apertura",
    "origen_denuncia",
    "estado_publicacion"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+(/[a-z0-9-]+)*$",
      "description": "Slug human-readable. Para piezas hijas, se usa notación jerárquica padre/hijo (ej. 'koldo/cerdan')."
    },
    "nombre_oficial": { "type": "string", "minLength": 1 },
    "nombre_mediatico": { "type": "string", "minLength": 1 },
    "nombres_alternativos": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "descripcion_corta": { "type": "string" },
    "sintesis_caso": {
      "type": "object",
      "description": "Síntesis accesible y estructurada de la ficha. Debe conservar presunción de inocencia y no sustituye al resumen ejecutivo.",
      "additionalProperties": false,
      "required": ["que_se_investiga", "hechos_clave", "estado_actual"],
      "properties": {
        "que_se_investiga": { "type": "string", "minLength": 1 },
        "hechos_clave": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 2,
          "maxItems": 4
        },
        "estado_actual": { "type": "string", "minLength": 1 },
        "cifras_clave": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        }
      }
    },

    "caso_padre_id": { "type": "string" },
    "tipo_pieza": {
      "type": "string",
      "enum": ["pieza_separada", "derivada_factual", "causa_conexa", "pieza_principal"]
    },

    "organo_judicial_id": { "type": "string" },
    "numero_procedimiento": { "type": "string" },
    "tipo_procedimiento": {
      "type": "string",
      "enum": [
        "diligencias_previas",
        "procedimiento_abreviado",
        "sumario_ordinario",
        "tribunal_jurado",
        "causa_especial_aforado",
        "recurso_amparo_tc",
        "recurso_casacion_ts",
        "otro"
      ]
    },
    "ponente_actual_id": { "type": "string" },

    "fase_actual": {
      "type": "string",
      "enum": [
        "denuncia_o_querella",
        "instruccion",
        "fase_intermedia",
        "juicio_oral",
        "sentencia_primera_instancia",
        "recurso",
        "sentencia_firme",
        "ejecucion",
        "archivo_provisional",
        "archivo_libre"
      ]
    },
    "fecha_apertura": { "type": "string", "format": "date" },
    "fecha_cierre": { "type": "string", "format": "date" },

    "origen_denuncia": {
      "type": "string",
      "enum": [
        "fiscalia_anticorrupcion",
        "fiscalia_ordinaria",
        "oficio_judicial",
        "querella_particular",
        "querella_partido_politico",
        "querella_asociacion_acusacion_popular",
        "denuncia_organismo_publico",
        "denuncia_periodistica",
        "comparecencia_congreso",
        "otro"
      ]
    },
    "querellante_inicial_id": { "type": "string" },
    "delitos_atribuidos_en_la_causa": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "resumen_cifras": { "type": "string" },

    "estado_publicacion": {
      "type": "string",
      "description": "Estado de desarrollo + visibilidad pública de la ficha. `pendiente`: caso listado pero sin trabajo iniciado. `borrador`: en desarrollo, NO público (en producción la ruta /casos/<slug> no se genera). `beta_publica`: publicable con cosillas / huecos editoriales aceptados. `en_revision`: revisión interna pre-publicación. `publicado`: ficha terminada al máximo de lo que el producto sabe hacer hoy (no implica caso jurídico cerrado). `retirado_*`: estaba publicado y se retiró.",
      "enum": [
        "pendiente",
        "borrador",
        "beta_publica",
        "en_revision",
        "publicado",
        "retirado_temporalmente",
        "retirado_definitivamente"
      ]
    },
    "ultima_revision_editorial": { "type": "string", "format": "date" },
    "nivel_relevancia_editorial": {
      "type": "string",
      "enum": ["baja", "media", "alta", "capital"]
    },

    "estado_ficha": {
      "type": "object",
      "description": "Checklist público de completitud editorial y técnica de la ficha. NO mide el procedimiento judicial — habla del estado del trabajo del inventario. Ver docs/web/features/estado-ficha-caso.md.",
      "additionalProperties": false,
      "required": [
        "cronologia",
        "roles_procesales",
        "documentos_primarios",
        "hechos_modelados",
        "fuentes_cruzadas",
        "composicion_fuentes_citadas",
        "vinculos_institucionales",
        "grafo_relaciones",
        "cobertura_mediatica_general",
        "revision_editorial"
      ],
      "properties": {
        "cronologia": { "$ref": "#/$defs/estadoChequeo" },
        "roles_procesales": { "$ref": "#/$defs/estadoChequeo" },
        "documentos_primarios": { "$ref": "#/$defs/estadoChequeo" },
        "hechos_modelados": { "$ref": "#/$defs/estadoChequeo" },
        "fuentes_cruzadas": { "$ref": "#/$defs/estadoChequeo" },
        "composicion_fuentes_citadas": { "$ref": "#/$defs/estadoChequeo" },
        "vinculos_institucionales": { "$ref": "#/$defs/estadoChequeo" },
        "grafo_relaciones": { "$ref": "#/$defs/estadoChequeo" },
        "cobertura_mediatica_general": { "$ref": "#/$defs/estadoChequeo" },
        "revision_editorial": { "$ref": "#/$defs/estadoChequeo" },
        "notas": {
          "type": "string",
          "description": "Justificación corta de por qué algún check está `parcial` o `pendiente`. Visible al lector."
        },
        "fecha_actualizacion": { "type": "string", "format": "date" }
      }
    }
  },

  "$defs": {
    "estadoChequeo": {
      "type": "string",
      "enum": ["completo", "parcial", "pendiente", "no_aplica"],
      "description": "completo: trabajado y revisado. parcial: hay algo pero falta cerrar. pendiente: aún no trabajado. no_aplica: el check no procede para este caso (justificar en notas)."
    }
  },

  "allOf": [
    {
      "if": { "required": ["caso_padre_id"] },
      "then": { "required": ["tipo_pieza"] }
    }
  ]
}
